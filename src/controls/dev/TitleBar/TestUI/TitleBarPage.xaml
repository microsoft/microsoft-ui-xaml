<local:TestPage
    x:Class="MUXControlsTestApp.TitleBarPage"
    x:Name="TitleBarTestPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MUXControlsTestApp"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:exp="using:Microsoft.Experimental.UI.Xaml.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}" Padding="12">
        <StackPanel Orientation="Vertical">
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="TitleBar OutputDebugString Levels:"
                           VerticalAlignment="Center"
                           Margin="2" />
                <ComboBox x:Name="cmbTitleBarOutputDebugStringLevel"
                          Margin="2"
                          Width="120"
                          HorizontalAlignment="Left"
                          SelectedIndex="0"
                          Grid.Column="1"
                          SelectionChanged="CmbTitleBarOutputDebugStringLevel_SelectionChanged">
                    <ComboBoxItem>None</ComboBoxItem>
                    <ComboBoxItem>Info</ComboBoxItem>
                    <ComboBoxItem>Verbose</ComboBoxItem>
                </ComboBox>
            </Grid>
            
            <TitleBar x:Name="WindowingTitleBar" Title="Windowing TitleBar">
                <TitleBar.IconSource>
                    <SymbolIconSource Symbol="Home"/>
                </TitleBar.IconSource>

                <AutoSuggestBox 
                    x:Name="AutoSuggestBoxInTitleBar"
                    PlaceholderText="Search pictures, videos or places..."
                    QueryIcon="Find"
                    MinWidth="300" 
                    MaxWidth="500"
                    Margin="8"/>
                <TitleBar.RightHeader>
                    <PersonPicture Initials="JD" Width="30" Height="30"/>
                </TitleBar.RightHeader>
            </TitleBar>

            <Button Content="New Window with Custom TitleBar" Click="TitleBarWindowingButton_Click"/>

            <!-- Drag Region API Test Controls -->
            <TextBlock Text="--- Drag Region API Tests ---" FontWeight="Bold" Margin="0,16,0,8" />

            <Button x:Name="GetAutoRefreshValueButton"
                    AutomationProperties.Name="GetAutoRefreshValueButton"
                    Content="Get AutoRefreshDragRegions Value"
                    Click="GetAutoRefreshValueButton_Click" />

            <Button x:Name="SetAutoRefreshTrueButton"
                    AutomationProperties.Name="SetAutoRefreshTrueButton"
                    Content="Set AutoRefreshDragRegions=True"
                    Click="SetAutoRefreshTrueButton_Click" />

            <Button x:Name="SetAutoRefreshFalseButton"
                    AutomationProperties.Name="SetAutoRefreshFalseButton"
                    Content="Set AutoRefreshDragRegions=False"
                    Click="SetAutoRefreshFalseButton_Click" />

            <Button x:Name="RecomputeDragRegionsButton"
                    AutomationProperties.Name="RecomputeDragRegionsButton"
                    Content="RecomputeDragRegions"
                    Click="RecomputeDragRegionsButton_Click" />

            <Button x:Name="SetIsDragRegionTrueButton"
                    AutomationProperties.Name="SetIsDragRegionTrueButton"
                    Content="Set IsDragRegion=True on AutoSuggestBox"
                    Click="SetIsDragRegionTrueButton_Click" />

            <Button x:Name="SetIsDragRegionFalseButton"
                    AutomationProperties.Name="SetIsDragRegionFalseButton"
                    Content="Set IsDragRegion=False on AutoSuggestBox"
                    Click="SetIsDragRegionFalseButton_Click" />

            <Button x:Name="GetIsDragRegionValueButton"
                    AutomationProperties.Name="GetIsDragRegionValueButton"
                    Content="Get IsDragRegion Value"
                    Click="GetIsDragRegionValueButton_Click" />

            <Button x:Name="ClearIsDragRegionButton"
                    AutomationProperties.Name="ClearIsDragRegionButton"
                    Content="Clear IsDragRegion"
                    Click="ClearIsDragRegionButton_Click" />

            <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock Text="Status:" VerticalAlignment="Center" />
                <TextBlock x:Name="DragRegionStatusTextBlock"
                           AutomationProperties.Name="DragRegionStatusTextBlock"
                           Foreground="Blue" VerticalAlignment="Center" />
            </StackPanel>
        </StackPanel>
    </Grid>
</local:TestPage>
