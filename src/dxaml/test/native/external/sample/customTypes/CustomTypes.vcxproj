<Project DefaultTargets="Build" ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup Label="Globals">
    <ProjectGuid>{760516A0-E9DB-4A65-B463-774814047298}</ProjectGuid>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />
  <Import Condition="'$(BuildingWithBuildExe)'!='true'" Project="$([MSBuild]::GetPathOfFileAbove(Xaml.NTLegacy.Cpp.props))" />
  <PropertyGroup>
    <!-- We can't place the generated type metadata in the Windows namespace, so keeping with the convention
      the private infrastructure uses to work around this we place it in the private namespace -->
    <!-- Update these to the namespace used by your tests. -->
    <RootNamespace>Private.Tests.Sample</RootNamespace>
    <ProjectName>Microsoft.UI.Xaml.Tests.Sample</ProjectName>
  </PropertyGroup>
  <Import Project="$(ProjectRoot)\dxaml\test\native\external\CustomTypeBase.props" />
  <ItemGroup>
    <ClInclude Include="pch.h" />
    <ClCompile Include="pch.cpp">
      <PrecompiledHeader>Create</PrecompiledHeader>
    </ClCompile>
    <!-- This magic group of includes is used to instruct the XamlCompiler to do everything
      it needs to do for a type that is backed by XAML. It will generate the code needed to
      load and apply the XAML to the custom type and perform XBF generation -->
    <ClInclude Include="Sample.CustomPage.xaml.h">
      <DependentUpon>Sample.CustomPage.xaml</DependentUpon>
    </ClInclude>
    <ClCompile Include="Sample.CustomPage.xaml.cpp">
      <DependentUpon>Sample.CustomPage.xaml</DependentUpon>
    </ClCompile>
    <Page Include="Sample.CustomPage.xaml">
      <SubType>Designer</SubType>
    </Page>
    <!-- This include will instruct the XamlCompiler to parse the following type
      for WinRT goodness and add their information to the exported type info table. -->
    <ClInclude Include="Sample.CustomButton.h" />
    <ClCompile Include="Sample.CustomButton.cpp" />
  </ItemGroup>
  <Import Condition="'$(BuildingWithBuildExe)'!='true'" Project="$([MSBuild]::GetPathOfFileAbove(Xaml.NTLegacy.Cpp.targets))"/>
</Project>
