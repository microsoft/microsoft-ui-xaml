<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Tests.Tools.Shared">
   
    <Grid x:Name="root">
        <Grid.Resources>
            <SolidColorBrush x:Key="blueBrush" Color="Blue" />
        </Grid.Resources>
        
        <local:CustomUserControl x:Name="userControl1" CustomInt="3" CustomDouble="NaN" Width="Auto" CustomUnknown="" CustomBrushNonDP="Orange" CustomDoubleNonDP="2"/>
        <local:CustomUserControl x:Name="userControl2" CustomBrushNonDP="{StaticResource blueBrush}" />
        <TextBlock x:Name="dataBound" HorizontalAlignment="Center" VerticalAlignment="Center" Text="{Binding ElementName=userControl1, Path=CustomInt}" />
    </Grid>
</Page>