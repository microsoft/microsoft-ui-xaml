<Page
    x:Class="Tests.Tools.Shared.PageWithTemplatedParentBinding"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Tests.Tools.Shared">

    <Page.Resources>
      <ResourceDictionary>
        <ResourceDictionary.MergedDictionaries>
            <ResourceDictionary Source="CommonStyles.xaml"/>
        </ResourceDictionary.MergedDictionaries>
      </ResourceDictionary>
    </Page.Resources>

    <Grid x:Name="LayoutRoot" Background="Transparent" Margin="0,-20,0,0">
        <ContentControl Content="Smile" Style="{StaticResource Icon}"/>
    </Grid>
</Page>

