<Page
    x:Class="Tests.Native.External.Framework.XDefer.CustomPageResourcesDT"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Tests.Native.External.Framework.XDefer">

    <Page.Resources>
        <DataTemplate x:Key="template">
            <StackPanel x:Name="rootPanel">
                <TextBlock x:Name="textBlock"
                           x:DeferLoadStrategy="Lazy"
                           Text="{Binding}"/>
            </StackPanel>
        </DataTemplate>
        <SolidColorBrush x:Key="trigger" Color="Black"/>
    </Page.Resources>
    
    <StackPanel>
        <ContentControl x:Name="contentControl0"
                        Content="abc">
            <ContentControl.ContentTemplate>
                <DataTemplate>
                    <StackPanel x:Name="rootPanel">
                        <StackPanel.Resources>
                            <SolidColorBrush x:Key="RedBrush" Color="Red"/>
                        </StackPanel.Resources>
                        <Button x:Name="element1" x:DeferLoadStrategy="Lazy" Background="{StaticResource RedBrush}"/>
                        <Button x:Name="element2" x:DeferLoadStrategy="Lazy">
                            <Button.Resources>
                                <SolidColorBrush x:Key="GreenBrush" Color="Green"/>
                            </Button.Resources>
                            <Rectangle x:Name="rectangle1" Fill="{StaticResource GreenBrush}"/>
                        </Button>
                    </StackPanel>
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>

        <ContentControl x:Name="contentControl1"
                        Content="abc"
                        ContentTemplate="{StaticResource template}"/>
    </StackPanel>
</Page>