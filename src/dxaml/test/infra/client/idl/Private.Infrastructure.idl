        HRESULT VerifySourceInfo([in] unsigned int infoIndex, [in] Microsoft.Diagnostics.AppAnalysis.SourceInfo sourceInfo);
        HRESULT VerifyCanLinkToLVT([in] unsigned int infoIndex, [in] unsigned long long lvtHandle);
        HRESULT VerifyDescription([in] unsigned int infoIndex, [in] Microsoft.Diagnostics.AppAnalysis.ResourceString* description);
        HRESULT DisableCurrentRule();
    }

