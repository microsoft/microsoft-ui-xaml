    } DCompRendering;

    #pragma region Utilities class

    [version(NTDDI_WINTHRESHOLD)]
    typedef [v1_enum] enum DesignMode
    {
        None = 0,
        V2 = 2,
    } DesignMode;

    [version(NTDDI_WINTHRESHOLD)]
    typedef [v1_enum] enum DisplayDPIRange
    {
        PreviousDefaultSecond = -2,
        PreviousDefaultFirst = -1,
        Default = 0,
        AboveDefaultFirst = 1,
        AboveDefaultSecond = 2,
    } DisplayDPIRange;

    runtimeclass Utilities;

    [version(NTDDI_WINTHRESHOLD)]
    [uuid(61CD4B0B-15E7-4B7E-91BA-35760DB3991C)]
    [exclusiveto(Utilities)]
    interface IUtilities : IInspectable
    {
        [propget] HRESULT IsOneCore([out, retval] BOOLEAN* isOneCore);
        [propget] HRESULT IsXBox([out, retval] BOOLEAN* isXBox);
        HRESULT SetRegKey([in] HSTRING path, [in] HSTRING name, [in] DWORD dwValue, [out] BOOLEAN* nameExisted, [in] BOOLEAN currentUser);
        HRESULT DeleteRegKey([in] HSTRING path, [in] HSTRING name, [in] BOOLEAN currentUser);

        HRESULT EnableChangingTimeZone([in] BOOLEAN enable);
        HRESULT SetTimeZone([in] HSTRING timezoneId);

        [overload("RunCommandLine"), default_overload]
        HRESULT RunCommandLine([in] HSTRING commandLine);
        [overload("RunCommandLine")]
        HRESULT RunCommandLineWithExitCode([in] HSTRING commandLine, [out] DWORD* pExitCode);

        HRESULT TerminateProcess([in] HSTRING processName);

        [overload("VerifyMockDCompOutput"), default_overload]
        HRESULT VerifyMockDCompOutput(
            [in] MockDComp.SurfaceComparison surfaceComparison
            );

        [overload("VerifyMockDCompOutput")]
        HRESULT VerifyMockDCompOutputWithOptions(
            [in] MockDComp.SurfaceComparison surfaceComparison,
            [in] MockDComp.SaveToFileOptions xmlOptions
            );

        [overload("VerifyMockDCompOutput")]
        HRESULT VerifyMockDCompOutputWithAnimation(
            [in] MockDComp.AnimationComparison animationComparison,
            [in] HSTRING variation
            );

        [overload("VerifyMockDCompOutput"), default_overload]
        HRESULT VerifyMockDCompOutputForVariation(
            [in] MockDComp.SurfaceComparison surfaceComparison,
            [in] HSTRING variation
            );

        [overload("VerifyMockDCompOutput")]
        HRESULT VerifyMockDCompOutputForVariationWithOptions(
            [in] MockDComp.SurfaceComparison surfaceComparison,
            [in] HSTRING variation,
            [in] MockDComp.SaveToFileOptions xmlOptions
            );

        [overload("VerifyMockDCompOutput")]
        HRESULT VerifyMockDCompOutputForVariationWithDataCollectionOnFailure(
            [in] MockDComp.AnimationComparison animationComparison,
            [in] MockDComp.SurfaceComparison surfaceComparison,
            [in] HSTRING variation,
            [in] BOOLEAN captureProcessDumpOnFailure
            );

        [overload("VerifyMockDCompOutput"), default_overload]
        HRESULT VerifyMockDCompOutputForVariationWithSucceededFlag(
            [in] MockDComp.SurfaceComparison surfaceComparison,
            [in] HSTRING variation,
            [in] BOOLEAN ignoreVerification,
            [out] BOOLEAN* succeeded
            );

        HRESULT SaveMockDCompOutput(
            [in] MockDComp.AnimationComparison animationComparison,
            [in] MockDComp.SurfaceComparison surfaceComparison,
            [in] HSTRING variation
            );

        [overload("VerifyUIElementTree"), default_overload]
        HRESULT VerifyUIElementTree([out, retval] BOOLEAN* result);

        HRESULT VerifyUIElementTreeWithRoot([in] Microsoft.UI.Xaml.DependencyObject* root, [out, retval] BOOLEAN* result);

        [overload("VerifyUIElementTree"), default_overload]
        HRESULT VerifyUIElementTreeForVariation([in] HSTRING variation, [out, retval] BOOLEAN* result);

        [overload("VerifyUIElementTreeWithRules"), default_overload]
        HRESULT VerifyUIElementTreeWithRules([in] HSTRING rulesFilename, [out, retval] BOOLEAN* result);

        [overload("VerifyUIElementTreeWithRules")]
        HRESULT VerifyUIElementTreeForVariationWithRules([in] HSTRING variation, [in] HSTRING rulesFilename, [out, retval] BOOLEAN* result);

        [overload("VerifyUIElementTreeWithRulesInline"), default_overload]
        HRESULT VerifyUIElementTreeWithRulesInline([in] HSTRING inlineRulesXml, [out, retval] BOOLEAN* result);

        [overload("VerifyUIElementTreeWithRulesInline")]
        HRESULT VerifyUIElementTreeForVariationWithRulesInline([in] HSTRING variation, [in] HSTRING inlineRulesXml, [out, retval] BOOLEAN* result);

        [overload("VerifyUIElementTreeWithRulesInline")]
        HRESULT VerifyUIElementTreeForVariationWithRulesInlineWithIgnorePopupsOption([in] HSTRING variation, [in] HSTRING inlineRulesXml, [in] BOOLEAN ignorePopups, [out, retval] BOOLEAN* result);

        // Verifies that the UIElement tree only contains the colors that are specified in the given set.
        HRESULT VerifyUIElementTreeContainsOnlyValidColors([in] HSTRING variation, [in]  Windows.Foundation.Collections.IVector<unsigned int>* validColors);

        HRESULT SetRuntimeEnabledFeatureOverride([in] INT feature, [in] BOOLEAN enabled, [out] BOOLEAN* wasPreviouslyEnabled);
        HRESULT ClearAllRuntimeEnabledFeatureOverrides();
        HRESULT OverrideTrimImageResourceDelay([in] BOOLEAN enabled);

        // This method assumes that one of the primary validation methods was called prior to
        // calling this and has generated an output file in the app's temp folder.
        HRESULT VerifyOutputFileHighContrastColors([in] HSTRING variation, [in] HighContrastTheme theme);

        // Some CommandBars (such as ones from PickerFlyouts) are hidden and can't be queried by
        // using the VisualTreeHelper.  This method provides a mechanism to work around that.
        HRESULT RetrieveOpenBottomCommandBar([in] Microsoft.UI.Xaml.XamlRoot* xamlRoot, [out, retval] Microsoft.UI.Xaml.Controls.CommandBar** cmdBar);
        HRESULT SetMockDCompSwapChainIdentifier([in] unsigned __int64 identifierValue, [in] unsigned int identifierID);
        HRESULT SetMockDCompSurfaceIdMode([in] MockDComp.SurfaceIdMode mode);
        HRESULT ResetMockDCompSurfaceId();
        HRESULT SimulateAllSurfacesDiscarded();
        HRESULT SetReturnDeviceLostWhenCreatingSurfaces([in] BOOLEAN returnDeviceLostWhenCreatingSurfaces);

        // This method will simulate a device lost from DComp during an attempt to
        // create a surface.
        HRESULT ResetMockDCompGraphicsDevice();
        HRESULT SimulateDeviceLostOnOffThreadImageUpload();
        HRESULT SimulateSwallowedDeviceLostOnStartup();
        HRESULT SimulateDeviceLostOnMetadataParse();
        HRESULT SimulateDeviceLostOnCreatingSvgDecoder();

        HRESULT SetDCompDeviceLeakDetectionEnabled([in] BOOLEAN enableLeakDetection);

        HRESULT ResetWasCommitInvoked();
        [propget] HRESULT WasCommitInvoked([out, retval] BOOLEAN* wasCommitInvoked);

        HRESULT VerifyAreSurfaceResourcesOffered([in] BOOLEAN value);

        HRESULT ResetMetadata();

        HRESULT CreateLoopingSelector([out] IInspectable** ppLoopingSelector);

        // Simulates a Back button pressed event.
        // On Phone the Back button is the hardware back button on the device.
        // On Desktop, the Back button is an optional piece of Shell Chrome drawn in the title bar.
        // This test hook injects the back pressed event directly into the Xaml layer. It does not call out to the shell to trigger the event.
        HRESULT InjectBackButtonPress([out] BOOLEAN* pHandled);

        HRESULT ResetAtlasSizeHint();

        HRESULT ShrinkApplicationViewVisibleBounds([in] BOOLEAN enabled);

        HRESULT ClearDefaultLanguageString();

        HRESULT IsWindowFocused([out] BOOLEAN* isFocused, [in] Microsoft.UI.Xaml.XamlRoot* xamlRoot);

        HRESULT GetPopupOverlayElement([in] Microsoft.UI.Xaml.Controls.Primitives.Popup* popup, [out, retval] Microsoft.UI.Xaml.FrameworkElement** overlayElement);

        HRESULT DeletePlatformFamilyCache();

        HRESULT DeleteResourceDictionaryCaches();

        HRESULT CreateRenderingScopeGuard(
            [in] DCompRendering rendering,
            [in] BOOLEAN resizeWindow,
            [in] BOOLEAN injectMockDComp,
            [in] BOOLEAN resetDevice,
            [in] BOOLEAN resetWindowContent,
            [out, retval] Windows.Foundation.IClosable** pGuard);

        HRESULT CaptureScreenAndProcess([in] HSTRING variation);

        HRESULT CaptureScreen([in] HSTRING variation);

        [propget] HRESULT IsMockDCompDisabled([out, retval] BOOLEAN* isMockDCompDisabled);

        HRESULT SetMockUIAClientsListening();
        HRESULT ClearMockUIAClientsListening();

        [propget] HRESULT IsDesktop([out, retval] BOOLEAN* isDesktop);

        HRESULT SetGenericXamlFilePathForMUX([in] HSTRING filePath);

        HRESULT RestoreDefaultFlipViewScrollWheelDelay();
        HRESULT SetFlipViewScrollWheelDelay([in] int scrollWheelDelayMS);

        HRESULT SetMockEnergySaverStatus([in] Windows.System.Power.EnergySaverStatus energyStatus);

        HRESULT SetMockPowerSupplyStatus([in] Windows.System.Power.PowerSupplyStatus powerStatus);

        HRESULT SetMockBatteryStatus([in] Windows.System.Power.BatteryStatus batteryStatus);

        HRESULT SetMockRemainingChargePercent([in] int value);

        HRESULT SetMockRemainingDischargeTime([in] Windows.Foundation.TimeSpan value);

        HRESULT SetApplicationLanguageOverride([in] HSTRING languageName);
        HRESULT ClearApplicationLanguageOverride();

        HRESULT SetDpi(
            [in] Windows.Graphics.DisplayAdapterId displayAdapterId,
            [in] UINT DisplayAdapterTargetId,
            [in] DisplayDPIRange dpiRange,
            [out, retval] Windows.Foundation.IClosable** pRestoreDpi);

        HRESULT SetForceDebugSettingsTracingEvents([in] BOOLEAN value);

        [propget] HRESULT IsWPF([out, retval] BOOLEAN* isWPF);

        // XamlOptionalChanges test hooks
        HRESULT ResetOptionalChanges();
   }

