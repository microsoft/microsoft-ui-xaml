    interface IAppAnalysisClientHelperStatics : IInspectable
    {
        // NOTE: These methods should all take [in] parameters rather than [out]. The reason being is that the out-of-proc server
        // is where the tracing session is being controlled from and has the ability to save the .etl log for investigation
        // if one of these methods throws. If you gather information from the out-of-proc server and fail the test in-proc, you will
        // lose this ability, which is a shame. This is because the server assumes your wrote a test that succeeds (it tends to be a little
        // too trustworthy at times) and will delete the .etl log unless it explicitly throws.
        HRESULT EnableRule([in] HSTRING ruleId, [in] HSTRING testIdentifier, [in] BOOLEAN shouldHaveSourceInfo);
        HRESULT VerifyRuleTriggered([in] unsigned int expectedCount);
        HRESULT VerifyRuleNotTriggered();
