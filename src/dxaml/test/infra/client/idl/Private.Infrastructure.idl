    runtimeclass InputHelper;

    [version(NTDDI_WINTHRESHOLD)]
    typedef [v1_enum] enum FlickDirection
    {
        NorthWest,
        North,
        NorthEast,
        East,
        SouthEast,
        South,
        SouthWest,
        West
    } FlickDirection;

    // NB: This must be kept in sync with MouseButton in InputManager.h in the WinUIDetails repo.
    [version(NTDDI_WINTHRESHOLD)]
    typedef[v1_enum] enum MouseButton
    {
        Left = 0,
        Right = 1,
        Middle = 2
    } MouseButton;

    [version(NTDDI_WINTHRESHOLD)]
    typedef[v1_enum] enum PointerFinger
    {
        Finger1 = 1,
        Finger2 = 2,
        Finger3 = 3,
        Finger4 = 4
    } PointerFinger;

    [version(NTDDI_WINTHRESHOLD)]
    [uuid(414689F2-247E-473E-9A52-80C58549077B)]
    [exclusiveto(InputHelper)]
    interface IInputHelper : IInspectable
    {
        [overload("LeftMouseClick"), default_overload]
        HRESULT LeftMouseClick([in] Microsoft.UI.Xaml.FrameworkElement* element);
        [overload("LeftMouseClick")]
        HRESULT LeftMouseClickOnPoint([in] Windows.Foundation.Point position);

        HRESULT DoubleTap([in] Microsoft.UI.Xaml.FrameworkElement* element);

        [overload("Tap"), default_overload]
        HRESULT Tap([in] Microsoft.UI.Xaml.FrameworkElement* element);

        [overload("Tap")]
        HRESULT TapAtPercent([in] Microsoft.UI.Xaml.FrameworkElement* element, float fractionOfWidth, float fractionOfHeight);

        [overload("Tap")]
        HRESULT TapOnPoint([in] Windows.Foundation.Point point);

        [overload("Hold"), default_overload]
        HRESULT Hold([in] Microsoft.UI.Xaml.FrameworkElement* element);

        [overload("Hold")]
        HRESULT HoldOnPoint([in] Windows.Foundation.Point point);

        [overload("Hold")]
        HRESULT HoldForSpecifiedDuration([in] Microsoft.UI.Xaml.FrameworkElement* element, UINT32 holdDuration);

        [overload("MoveMouse"), default_overload]
        HRESULT MoveMouse([in] Microsoft.UI.Xaml.FrameworkElement* element);

        [overload("MoveMouse")]
        HRESULT MoveMouseFromCenter([in] Microsoft.UI.Xaml.FrameworkElement* element, INT relX, INT relY);

        [overload("MoveMouse")]
        HRESULT MoveMouseOnPoint([in] Windows.Foundation.Point point);

        [overload("ClickMouseButton"), default_overload]
        HRESULT ClickMouseButton(MouseButton button, [in] Microsoft.UI.Xaml.FrameworkElement* element);

        [overload("ClickMouseButton")]
        HRESULT ClickMouseButtonWithOffset(MouseButton button, [in] Microsoft.UI.Xaml.FrameworkElement* element, INT dx, INT dy);

        [overload("ClickMouseButton")]
        HRESULT ClickMouseButtonOnPoint(MouseButton button, Windows.Foundation.Point position);

        [overload("ScrollMouseWheel"), default_overload]
        HRESULT ScrollMouseWheel([in] Microsoft.UI.Xaml.FrameworkElement* element, INT numberOfWheelClicks);

        HRESULT Flick([in] Microsoft.UI.Xaml.FrameworkElement* element, FlickDirection direction);
        HRESULT PanFromCenter([in] Microsoft.UI.Xaml.FrameworkElement* element, INT relX, INT relY, DOUBLE velocityFactor);
        HRESULT PressHoldAndPanFromCenter([in] Microsoft.UI.Xaml.FrameworkElement* element, INT relX, INT relY, DOUBLE velocityFactor, UINT holdTime);
        HRESULT DragFromCenter([in] Microsoft.UI.Xaml.FrameworkElement* element, INT relX, INT relY, DOUBLE velocityFactor);
        HRESULT DragToCenter([in] Microsoft.UI.Xaml.FrameworkElement* element, INT relX, INT relY, DOUBLE velocityFactor);
        HRESULT DragBetweenElements([in] Microsoft.UI.Xaml.FrameworkElement* sourceElement, [in] Microsoft.UI.Xaml.FrameworkElement* targetElement, DOUBLE velocityFactor);
        HRESULT PenStrokeFromCenter([in] Microsoft.UI.Xaml.FrameworkElement* element, INT relX, INT relY, DOUBLE velocityFactor);
        HRESULT PenHold([in] Microsoft.UI.Xaml.FrameworkElement* element);
        HRESULT PenTap([in] Microsoft.UI.Xaml.FrameworkElement* element);
        HRESULT PenDoubleTap([in] Microsoft.UI.Xaml.FrameworkElement* element);
        HRESULT PenBarrelTap([in] Microsoft.UI.Xaml.FrameworkElement* element);
        HRESULT PenWriteLetterT([in] Microsoft.UI.Xaml.FrameworkElement* element);
        HRESULT PenWriteDash([in] Microsoft.UI.Xaml.FrameworkElement* element);
        HRESULT InjectDragWithPenBarrelDown([in] Microsoft.UI.Xaml.FrameworkElement* pElement, [in] INT32 relX, [in] INT32 relY, [in] DOUBLE velocityFactor);
        HRESULT ZoomInToEdges([in] Microsoft.UI.Xaml.FrameworkElement* element, UINT equidistanceFromEdges, Microsoft.UI.Xaml.Controls.Orientation orientation, DOUBLE velocityFactor);
        HRESULT ZoomOutFromEdges([in] Microsoft.UI.Xaml.FrameworkElement* element, UINT equidistanceFromEdges, Microsoft.UI.Xaml.Controls.Orientation orientation, DOUBLE velocityFactor);
        HRESULT InjectRotate([in] Microsoft.UI.Xaml.FrameworkElement* element, [in] Windows.Foundation.Point startFinger1, [in] Windows.Foundation.Point startFinger2, [in] DOUBLE rotationAngleDegrees,
            [in] UINT32 durationMs, [in] BOOLEAN pivotRotate);

        // Methods not relative to xaml elements.
        HRESULT Swipe(Windows.Foundation.Point start, Windows.Foundation.Point end);

        // More advanced "dynamic press" APIs, allow you to separately inject pointer down/up events
        HRESULT DynamicPressCenter([in] Microsoft.UI.Xaml.FrameworkElement* element, INT dx, INT dy, PointerFinger finger);
        HRESULT DynamicRelease(PointerFinger finger);

        HRESULT DynamicPenPressCenter([in] Microsoft.UI.Xaml.FrameworkElement* element, INT dx, INT dy);
        HRESULT DynamicPenRelease();

        // Allows to press a mouse button, drag and release.
        [overload("MouseButtonDown"), default_overload]
        HRESULT MouseButtonDown([in] Microsoft.UI.Xaml.FrameworkElement* element, INT dx, INT dy, MouseButton button);
        [overload("MouseButtonDown")]
        HRESULT MouseButtonDownOnPoint(Windows.Foundation.Point point, MouseButton button);
        [overload("MouseButtonUp"), default_overload]
        HRESULT MouseButtonUp([in] Microsoft.UI.Xaml.FrameworkElement* element, INT dx, INT dy, MouseButton button);
        [overload("MouseButtonUp")]
        HRESULT MouseButtonUpOnPoint(Windows.Foundation.Point point, MouseButton button);
        [overload("MouseDrag"), default_overload]
        HRESULT MouseDrag([in] Microsoft.UI.Xaml.FrameworkElement* elementSrc, INT dxSrc, INT dySrc, Microsoft.UI.Xaml.FrameworkElement* elementDest, INT dxDest, INT dyDest, MouseButton button);
        [overload("MouseDrag")]
        HRESULT MouseDragOnPoints(Windows.Foundation.Point pointSrc, Windows.Foundation.Point pointDest, MouseButton button);

        HRESULT SuppressGestureStateReset([out, retval]Windows.Foundation.IClosable** suppressionScope);
    }

