    [version(NTDDI_WINTHRESHOLD)]
    typedef[v1_enum] enum KeyboardWaitKind
    {
        None                      = 0x00,
        WaitForEvent              = 0x01,
        WaitForIdleBefore         = WaitForEvent | 0x02,
        WaitForIdleAfter          = WaitForEvent | 0x04,
        WaitForIdleBeforeAndAfter = WaitForIdleBefore | WaitForIdleAfter,
        Sleep                     = 0x08,
        Default                   = WaitForEvent,
    } KeyboardWaitKind;

    runtimeclass KeyboardHelper;

