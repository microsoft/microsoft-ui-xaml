// We're purposely avoiding putting this in the Windows.* namespace
// to avoid the restriction placed on consuming WinRT classes from
// the CLR that requires them to be placed in the system32 directory.
namespace Private.Infrastructure
{
    #pragma region ThemingHelper class

    runtimeclass ThemingHelper;

    [version(NTDDI_WINTHRESHOLD)]
    typedef [v1_enum] enum HighContrastTheme
    {
        None,
        Test,       // Sets an HC palette where all colors are different.
        Default,    // Sets an HC palette corresponding to the "High Contrast #1" theme from settings.
        Black,      // Sets an HC palette corresponding to the "High Contrast Black" theme from settings.
        White,      // Sets an HC palette corresponding to the "High Contrast White" theme from settings.
        Custom,     // Sets an HC palette corresponding to the "High Contrast Custom" theme from settings.

    } HighContrastTheme;

    [version(NTDDI_WINTHRESHOLD)]
    [uuid(07d9c510-11d4-403d-9aed-140a6a2be218)]
    [exclusiveto(ThemingHelper)]
    interface IThemingHelper : IInspectable
    {
        HRESULT SetApplicationRequestedTheme([in] Microsoft.UI.Xaml.ApplicationTheme theme);
        HRESULT UnsetApplicationRequestedTheme();
        HRESULT SimulateThemeChanged();
        HRESULT RestoreDefaultState();
        HRESULT RemoveThemingOverrides();

        [propput] HRESULT SystemTheme([in] Microsoft.UI.Xaml.ApplicationTheme theme);
        [propget] HRESULT SystemTheme([out, retval] Microsoft.UI.Xaml.ApplicationTheme* theme);
        [propput] HRESULT HighContrastTheme([in]HighContrastTheme theme);
        [propget] HRESULT HighContrastTheme([out, retval]HighContrastTheme* theme);
        [propput] HRESULT AccentColor([in] unsigned int accentColor);
        [propget] HRESULT AccentColor([out, retval] unsigned int* accentColor);
    }

    [version(NTDDI_WINTHRESHOLD)]
    runtimeclass ThemingHelper
    {
        [default]interface IThemingHelper;
    }

