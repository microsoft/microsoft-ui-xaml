    #pragma region VisualTreeVerifier class

    runtimeclass VisualTreeVerifier;

    [version(NTDDI_WINTHRESHOLD)]
    [uuid(0dfd28bd-a9da-4d78-bd49-347e1abebed8)]
    [exclusiveto(VisualTreeVerifier)]
    interface IVisualTreeVerifierStatics : IInspectable
    {
        HRESULT CreateFromElement([in] Microsoft.UI.Xaml.UIElement* element, [out, retval] VisualTreeVerifier** value);

        HRESULT CreateFromVisual([in] Microsoft.UI.Composition.Visual* visual, [out, retval] VisualTreeVerifier** value);
    }

    [version(NTDDI_WINTHRESHOLD)]
    [uuid(08d5b550-451a-4557-9e10-63c4fb54f9f4)]
    [exclusiveto(VisualTreeVerifier)]
    interface IVisualTreeVerifier : IInspectable
    {
        HRESULT WalkToTaggedChild(UINT tag, [out, retval] VisualTreeVerifier** value);
        HRESULT WalkThroughSimpleCompNode([out, retval] VisualTreeVerifier** value);
        HRESULT WalkToChildAtIndex(UINT childIndex, UINT expectedChildCount, [out, retval] VisualTreeVerifier** value);

        HRESULT VerifyNoTaggedChild(UINT tag);
        HRESULT VerifyChildCount(UINT childCount);

        HRESULT VerifyVisualOffset(float x, float y);
        HRESULT VerifyVisualSize(float width, float height);
        HRESULT VerifyTransformMatrix_Scale(float x, float y);
