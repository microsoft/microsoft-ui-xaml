<Project Sdk="Microsoft.NET.Sdk">
  <Sdk Name="Microsoft.Build.CentralPackageVersions" Version="2.0.1" />
  <PropertyGroup>
    <TargetFramework>$(DotNetCoreTargetFrameworkMoniker)</TargetFramework>
    <Platforms>x64;x86</Platforms>
    <RuntimeIdentifiers>win10-x86;win10-x64</RuntimeIdentifiers>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <UseWPF>true</UseWPF>
    <WebView2UseWinRT>true</WebView2UseWinRT>
  </PropertyGroup>
  
  <ItemGroup>
    <Compile Include="..\src\WindowsXamlHost.cs" />
    <Compile Include="..\src\WindowsXamlHostBase.cs" />
    <Compile Include="..\src\WindowsXamlHostBase.Focus.cs" />
    <Compile Include="..\src\WindowsXamlHostBase.Layout.cs" />
    <Compile Include="..\winmd\**\*.cs" />
    <Compile Include="..\..\winmd\AppDomainExceptionHandler.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Windows.CsWinRT" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="$(ProjectRoot)\src\projection\private\Microsoft.WinUI.csproj" />
    <ProjectReference Include="..\..\..\client\cswinrt\Private.Infrastructure.CsWinRT.csproj" />
    <ProjectReference Include="..\..\..\Win32Hosting\src\Microsoft.Toolkit.Win32.UI.XamlHost.csproj" />
  </ItemGroup>

</Project>
