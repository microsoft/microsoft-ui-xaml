<Page
    x:Class="CustomTypes.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Tests.DevProd.XamlCompiler"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <ControlTemplate TargetType="Button" x:Key="T1" x:ConnectionId="1">
          <Border x:ConnectionId="4">
              <TextBlock x:ConnectionId="2" />
          </Border>
        </ControlTemplate>
        <ControlTemplate TargetType="Button" x:Key="T2" >
          <Border x:ConnectionId="6">
              <TextBlock x:ConnectionId="7" />
          </Border>
        </ControlTemplate>
    </Page.Resources>
    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
      <Button x:Name="button" Template="{StaticResource T1}"/>
      <Button x:Name="button2" Template="{StaticResource T2}" x:ConnectionId="5"/>
    </Grid>
</Page>