<StackPanel  
    xmlns='http://schemas.microsoft.com/winfx/2006/xaml/presentation' 
    xmlns:x='http://schemas.microsoft.com/winfx/2006/xaml'
    Width="400" Height="400">
    <Grid Background="LightGray">
        <Grid.Resources>
            <CollectionViewSource x:Name="cvs" />
        </Grid.Resources>
        <ListView ScrollViewer.ZoomMode="Enabled"
                 x:Name="moco"
                 ItemsSource="{Binding Source={StaticResource cvs}}"
                 Width="400" Height="400" 
                 [[Moco_Properties]]
        >
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <[[ItemsPanel]] Orientation="[[ItemsPanel_Orientation]]"/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Background="DarkGray" Width="50" Height="50">
                        <StackPanel Orientation="Vertical"  Background="SlateBlue">
                            <StackPanel Background="Gray" >
                                <TextBlock Text="{Binding ItemContent0}" Foreground="Black" Margin="2"/>
                            </StackPanel>
                            <TextBlock Text="{Binding ItemContent1}" Foreground="Gray"  Margin="2"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.GroupStyle>
                <GroupStyle>
                    <GroupStyle.HeaderTemplate>
                        <DataTemplate>
                            <Grid Background="Black" Width="50">
                                <TextBlock Text='{Binding GroupName}' Foreground="White" />
                            </Grid>
                        </DataTemplate>
                    </GroupStyle.HeaderTemplate>
                </GroupStyle>
            </ListView.GroupStyle>
        </ListView>
    </Grid>
</StackPanel>