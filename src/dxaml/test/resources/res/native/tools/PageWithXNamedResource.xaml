<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Page.Resources>
        <SolidColorBrush x:Name="RedColor">Red</SolidColorBrush>
        <SolidColorBrush x:Key="BlueColor">Blue</SolidColorBrush>
    </Page.Resources>
    <StackPanel>
        <Rectangle Fill="{StaticResource RedColor}" Width="100" Height="119"/>
        <Rectangle Fill="{StaticResource BlueColor}" Width="100" Height="119"/>
    </StackPanel>
</Page>