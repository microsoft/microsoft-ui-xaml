<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="rootGrid">
        <Grid.Resources>
            <ResourceDictionary>
                <SolidColorBrush x:Key="resourceBrush" Color="Red" />
                <Style x:Key="testStyle" TargetType="Grid">
                    <Setter Property="Background" Value="{StaticResource resourceBrush}" />
                </Style>
            </ResourceDictionary>
        </Grid.Resources>
        <Grid x:Name="testGrid" Style="{StaticResource testStyle}" />
    </Grid>
</Page>