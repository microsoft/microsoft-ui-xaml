<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width=".5*"></ColumnDefinition>
            <ColumnDefinition Width=".5*"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Button x:Name="button" AutomationProperties.Name="ClickHere" Background="Yellow" Height="30" Width="30" Grid.Column="0"/>
        <TextBlock x:Name="textblock" AutomationProperties.Name="ClickHere" Text="Click Here!" Height="30" Width="30" Grid.Column="1"/>
    </Grid>
</Page>