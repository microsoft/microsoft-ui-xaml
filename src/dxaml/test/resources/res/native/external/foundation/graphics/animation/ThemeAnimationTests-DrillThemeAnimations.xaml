<Canvas xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Canvas.Resources>
        <Storyboard x:Name="_drillIn">
            <DrillInThemeAnimation EntranceTargetName="r" ExitTargetName="r2"/>
        </Storyboard>
        <Storyboard x:Name="_drillOut">
            <DrillOutThemeAnimation EntranceTargetName="r2" ExitTargetName="r"/>
        </Storyboard>
    </Canvas.Resources>

    <Rectangle Width="50" Height="50" Fill="Red" Canvas.Top="100" x:Name="r"/>
    <Rectangle Width="50" Height="50" Fill="Blue" Canvas.Top="100" x:Name="r2"/>

</Canvas>