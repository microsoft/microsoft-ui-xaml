<StackPanel xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Margin="20">
    <Canvas>
        <Canvas CompositeMode="SourceOver" Width="100" Height="100" Background="Red">
            <Canvas.Clip>
                <RectangleGeometry Rect="10,10,80,80">
                    <RectangleGeometry.Transform>
                        <TranslateTransform x:Name="myTransform"/>
                    </RectangleGeometry.Transform>
                </RectangleGeometry>
            </Canvas.Clip>
            <Canvas.Triggers>
                <EventTrigger RoutedEvent="Canvas.Loaded">
                    <BeginStoryboard>
                        <Storyboard x:Name="myStoryboard">
                            <DoubleAnimation Storyboard.TargetName="myTransform" Storyboard.TargetProperty="X" To="100" Duration="0:0:4" RepeatBehavior="Forever"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Canvas.Triggers>
        </Canvas>
    </Canvas>
</StackPanel>
