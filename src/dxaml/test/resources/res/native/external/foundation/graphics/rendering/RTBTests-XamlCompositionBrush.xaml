<StackPanel xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <StackPanel x:Name="colors" Orientation="Horizontal" HorizontalAlignment="Center">
    <Rectangle x:Name="BlueRectangle" Height="100" Width="40" />
    <Rectangle x:Name="WhiteRectangle" Height="100" Width="40" />
    <Rectangle x:Name="RedRectangle" Height="100" Width="40" />
  </StackPanel>
  <Image x:Name="img" HorizontalAlignment="Center"/>
</StackPanel>