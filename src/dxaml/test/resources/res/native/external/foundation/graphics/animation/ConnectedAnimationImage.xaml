<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid.Resources>
     </Grid.Resources>
    <Grid Margin="10,10,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="2*"/>
       </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <!-- Scale Test items-->
        <Image Grid.Row="0" Grid.Column="0" x:Name="NormalScale" Width="60" Height="60" Stretch="Uniform" Source="ms-appx:///resources/native/external/foundation/graphics/image/windows.png"/>
        <Grid Grid.Row="0" Grid.Column="1" HorizontalAlignment="Stretch">
            <Grid.RenderTransform>
                <ScaleTransform ScaleX=".5" ScaleY=".5"/>
            </Grid.RenderTransform>
            <Image x:Name="ParentScale" Height="60" Width="60" Stretch="Uniform" Source="ms-appx:///resources/native/external/foundation/graphics/image/barcelona.jpg"/>
        </Grid>
        <Grid Grid.Row="1" Grid.Column="0" HorizontalAlignment="Stretch">
            <Grid.RenderTransform>
                <ScaleTransform ScaleX=".5" ScaleY=".5"/>
            </Grid.RenderTransform>
            <Image x:Name="CombinedScale" Height="60" Width="60" Stretch="Uniform" Source="ms-appx:///resources/native/external/foundation/graphics/image/windows.png">
                <Image.RenderTransform>
                    <ScaleTransform ScaleX="2" ScaleY="2"/>
                </Image.RenderTransform>
            </Image>
        
        </Grid>
        <Image Grid.Row="1" Grid.Column="1" x:Name="LocalScale" Height="60" Width="60" Stretch="Uniform" Source="ms-appx:///resources/native/external/foundation/graphics/image/barcelona.jpg">
            <Image.RenderTransform>
                <ScaleTransform ScaleX="2" ScaleY="2"/>
            </Image.RenderTransform>
        </Image>

        <!-- Alignment Test items -->
        <Image Grid.Row="2" Grid.Column="0" x:Name="CenterAligned" Height="60" Width="60" Stretch="Uniform" HorizontalAlignment="Center" Source="ms-appx:///resources/native/external/foundation/graphics/image/windows.png"/>
        <Image Grid.Row="2" Grid.Column="1" x:Name="RightAligned" Height="60" Width="60" Stretch="Uniform" HorizontalAlignment="Right" Source="ms-appx:///resources/native/external/foundation/graphics/image/barcelona.jpg"/>

        <!-- Flipping Test items -->
        <Image Grid.Row="3" Grid.Column="0" x:Name="LocalFlip" Height="60" Width="60"  HorizontalAlignment="Center" Source="ms-appx:///resources/native/external/foundation/graphics/image/windows.png">
            <Image.RenderTransformOrigin>
                <Point X=".5" Y=".5"/>
            </Image.RenderTransformOrigin>

            <Image.RenderTransform>
                <ScaleTransform ScaleX="-2" ScaleY="-2"/>
            </Image.RenderTransform>
        </Image>
        <Grid Grid.Row="3" Grid.Column="1" HorizontalAlignment="Stretch" Width="390">
            <Grid.RenderTransformOrigin>
                <Point X=".5" Y=".5"/>
            </Grid.RenderTransformOrigin>
            <Grid.RenderTransform>
                <ScaleTransform ScaleX="-.5" ScaleY="-.5"/>
            </Grid.RenderTransform>
            <Image x:Name="ParentFlip" Height="60" Width="60" Stretch="Uniform" Source="ms-appx:///resources/native/external/foundation/graphics/image/barcelona.jpg"/>
        </Grid>

        <!-- RTL Test items -->
        <Image Grid.Row="4" Grid.Column="0" x:Name="LocalRTL" Height="60" Width="60" Stretch="Uniform" HorizontalAlignment="Left" Source="ms-appx:///resources/native/external/foundation/graphics/image/windows.png"/>
        <Grid Grid.Row="4" Grid.Column="1" HorizontalAlignment="Stretch" FlowDirection="RightToLeft">
            <Image x:Name="ParentRTL" Height="60" Width="60" Stretch="Uniform" HorizontalAlignment="Right" Source="ms-appx:///resources/native/external/foundation/graphics/image/barcelona.jpg"/>
        </Grid>

        <!-- Clipping Test items -->
        <Image Grid.Row="5" Grid.Column="0" x:Name="UnclippedImage" Height="120" Width="120" Stretch="Uniform" HorizontalAlignment="Left" Source="ms-appx:///resources/native/external/foundation/graphics/image/windows.png"/>
        <Grid Grid.Row="5" Grid.Column="1" Height="50" Width="50" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Image Grid.Row="5" Grid.Column="0" x:Name="ClippedImage" Height="120" Width="120" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Source="ms-appx:///resources/native/external/foundation/graphics/image/windows.png"/>
        </Grid>

    </Grid>

</Grid>

