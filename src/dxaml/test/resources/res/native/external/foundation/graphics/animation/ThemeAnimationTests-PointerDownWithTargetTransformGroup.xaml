<Canvas xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Canvas.Resources>
        <Storyboard x:Name="_pointerDownWithTransform">
            <PointerDownThemeAnimation Storyboard.TargetName="r" />
        </Storyboard>
    </Canvas.Resources>

    <ListViewItem Width="100" Height="50">
        <Rectangle x:Name="r" Width="500" Height="100" Fill="Blue"/>
    </ListViewItem>

</Canvas>