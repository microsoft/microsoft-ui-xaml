<Canvas xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Rectangle Width="50" Height="50" Fill="Blue">
        <Rectangle.RenderTransform><TranslateTransform x:Name="asdf"/></Rectangle.RenderTransform>
        <Rectangle.Triggers>
            <EventTrigger RoutedEvent="Rectangle.Loaded">
                <BeginStoryboard>
                    <Storyboard BeginTime="0:0:0.5">
                        <DoubleAnimation Storyboard.TargetName="asdf" Storyboard.TargetProperty="X" From="0" To="100" Duration="0:0:30" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Rectangle.Triggers>
    </Rectangle>

</Canvas>

