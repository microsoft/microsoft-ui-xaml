<StackPanel xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Margin="20">
    <!--
        We have an optimization that skips the rounded corner clip for elements without children (the
        corner will be baked into the mask), so give degenerate children to all these test elements.
    -->
    <Border Width="40" Height="40" Background="Red" CornerRadius="10"><Canvas/></Border>
    <Border Width="41" Height="41" Background="Red" CornerRadius="0"><Canvas/></Border>
    <Grid Width="42" Height="42" Background="Red" CornerRadius="10"><Canvas/></Grid>
    <ContentPresenter Width="43" Height="43" Background="Red" CornerRadius="10"><Canvas/></ContentPresenter>
    <RelativePanel Width="44" Height="44" Background="Red" CornerRadius="10"><Canvas/></RelativePanel>
    <StackPanel Width="45" Height="45" Background="Red" CornerRadius="10"><Canvas/></StackPanel>
</StackPanel>
