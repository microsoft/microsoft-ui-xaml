<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid.Resources>
        <Style x:Key="LeftTextBlock" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Foreground" Value="Yellow"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style x:Key="RightTextBlock" TargetType="TextBlock">
            <Setter Property="FontSize" Value="30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
    </Grid.Resources>
    <Grid Margin="10,10,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="2*"/>
       </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <!-- Scale Test items-->
        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LeftTextBlock}" x:Name="NormalScale" Text="Normal Scale"/>
        <Grid Grid.Row="0" Grid.Column="1" HorizontalAlignment="Stretch">
            <Grid.RenderTransform>
                <ScaleTransform ScaleX=".5" ScaleY=".5"/>
            </Grid.RenderTransform>
            <TextBlock  Style="{StaticResource RightTextBlock}" x:Name="ParentScale" Text="Parent Scale .5x"/>
        </Grid>
        <Grid Grid.Row="1" Grid.Column="0" HorizontalAlignment="Stretch">
            <Grid.RenderTransform>
                <ScaleTransform ScaleX=".5" ScaleY=".5"/>
            </Grid.RenderTransform>
            <TextBlock  Style="{StaticResource LeftTextBlock}" x:Name="CombinedScale" Text="Parent .5x Local 2x">
                <TextBlock.RenderTransform>
                    <ScaleTransform ScaleX="2" ScaleY="2"/>
                </TextBlock.RenderTransform>
            </TextBlock>
        </Grid>
        <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource RightTextBlock}" x:Name="LocalScale" Text="Local Scale 2X">
            <TextBlock.RenderTransform>
                <ScaleTransform ScaleX="2" ScaleY="2"/>
            </TextBlock.RenderTransform>
        </TextBlock>

        <!-- Alignment Test items -->
        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LeftTextBlock}" x:Name="CenterAligned" Text="Center Aligned" TextAlignment="Center"/>
        <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource RightTextBlock}" x:Name="RightAligned" Text="Right Aligned" TextAlignment="Right"/>

        <!-- Flipping Test items -->
        <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource LeftTextBlock}" Width="145" x:Name="LocalFlip" Text="Local Flip 2x" VerticalAlignment="Top">
            <TextBlock.RenderTransformOrigin>
                <Point X=".5" Y=".5"/>
            </TextBlock.RenderTransformOrigin>

            <TextBlock.RenderTransform>
                <ScaleTransform ScaleX="-2" ScaleY="-2"/>
            </TextBlock.RenderTransform>
        </TextBlock>
        <Grid Grid.Row="3" Grid.Column="1" HorizontalAlignment="Stretch" Width="390">
            <Grid.RenderTransformOrigin>
                <Point X=".5" Y=".5"/>
            </Grid.RenderTransformOrigin>
            <Grid.RenderTransform>
                <ScaleTransform ScaleX="-.5" ScaleY="-.5"/>
            </Grid.RenderTransform>
            <TextBlock Style="{StaticResource RightTextBlock}" x:Name="ParentFlip" Text="Parent Flip .5x"/>
        </Grid>

        <!-- RTL Test items -->
        <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource LeftTextBlock}" x:Name="LocalRTL" Text="Local RTL" FlowDirection="RightToLeft"/>
        <Grid Grid.Row="4" Grid.Column="1" HorizontalAlignment="Stretch" FlowDirection="RightToLeft">
            <TextBlock Style="{StaticResource RightTextBlock}" x:Name="ParentRTL" Text="Parent RTL"/>
        </Grid>

        <!-- Clipping Test items -->
        <TextBlock  Grid.Row="5" Grid.Column="0" x:Name="UnclippedText" Style="{StaticResource LeftTextBlock}" FontSize="30" Width="350" Text="Claude cleverly clipped countless coins while counting Carrie's cash" TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <Grid Grid.Row="5" Grid.Column="1" Height="50" Width="50" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock x:Name="ClippedText" Style="{StaticResource RightTextBlock}" Text="Claude cleverly clipped countless coins while counting Carrie's cash" Width="350" TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>

    </Grid>

</Grid>

