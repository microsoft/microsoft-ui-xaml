<Grid xmlns='http://schemas.microsoft.com/winfx/2006/xaml/presentation' xmlns:x='http://schemas.microsoft.com/winfx/2006/xaml' x:Name='Root' Background="Black">
  <Grid.RowDefinitions>
    <RowDefinition Height='Auto' />
    <RowDefinition Height='*' />
  </Grid.RowDefinitions>
  <TextBlock
    Text="Virtualized GridView"
    Margin="3"
    Foreground="White"
    FontFamily="Segoe UI Light"
    FontSize="40" />
  <GridView x:Name="ItemsControl" Grid.Row="1" Margin="3">
    <GridView.ItemTemplate>
      <DataTemplate>
        <Border BorderThickness="4">
          <Border.BorderBrush>
            <SolidColorBrush Color="{Binding ItemColor}" />
          </Border.BorderBrush>
          <Grid Height="200" Width="250">
            <Grid.ColumnDefinitions>
              <ColumnDefinition/>
              <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition/>
              <RowDefinition/>
            </Grid.RowDefinitions>
            <Rectangle Grid.ColumnSpan="2">
              <Rectangle.Fill>
                <SolidColorBrush Color="{Binding ItemColor}" />
              </Rectangle.Fill>
            </Rectangle>
            <Image Stretch="None" Margin="4">
              <Image.Source>
                <BitmapImage UriSource="{Binding ImagePath}" DecodePixelWidth="133" DecodePixelHeight="100"/>
              </Image.Source>
            </Image>
            <Grid Grid.Column="1">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
              </Grid.RowDefinitions>
              <TextBlock
                Text="{Binding ItemName}"
                Foreground="Black"
                FontFamily="Segoe UI Light"
                FontSize="18"
                HorizontalAlignment="Center"
                Margin="4" />
              <Button Content="{Binding ItemNumber}" Margin="0,0,4,0" Grid.Row="1" FontSize="40" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
            </Grid>
            <RichTextBlock Grid.ColumnSpan="2" Grid.Row="1" Margin="8">
              <Paragraph>
                <Run Text="{Binding Paragraph1}"/>
              </Paragraph>
              <Paragraph>
                <Run Text="{Binding Paragraph2}"/>
              </Paragraph>
            </RichTextBlock>
          </Grid>
        </Border>
      </DataTemplate>
    </GridView.ItemTemplate>
  </GridView>
</Grid>
