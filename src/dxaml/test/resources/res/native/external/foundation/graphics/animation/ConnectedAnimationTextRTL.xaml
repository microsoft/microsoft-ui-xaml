<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
        </Style>
        <Style x:Key="LeftTextBlock" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Foreground" Value="Yellow"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style x:Key="RightTextBlock" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
    </Grid.Resources>
    <Grid Margin="10,10,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <!-- Headers -->
        <TextBlock Grid.Row="0" Grid.Column="0" HorizontalAlignment="Center" Text="Parent RTL" Foreground="Yellow"/>
        <TextBlock Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center" Text="Local RTL"/>

        <!-- Parent Scaled Test items -->
        <Grid Grid.Row="1" Grid.Column="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" FlowDirection="RightToLeft">
            <Grid.RenderTransformOrigin>
                <Point X=".5" Y=".5"/>
            </Grid.RenderTransformOrigin>
            <Grid.RenderTransform>
                <ScaleTransform ScaleX=".75" ScaleY=".75"/>
            </Grid.RenderTransform>
            <TextBlock Style="{StaticResource LeftTextBlock}" x:Name="ParentRTLParentScale" Text="Parent Scale 75%" Margin="20,20,20,20"/>
        </Grid>
        <Grid Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Grid.RenderTransformOrigin>
                <Point X=".5" Y=".5"/>
            </Grid.RenderTransformOrigin>
            <Grid.RenderTransform>
                <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
            </Grid.RenderTransform>
            <TextBlock Style="{StaticResource RightTextBlock}" x:Name="LocalRTLParentScale" Text="Parent Scale 150%" Margin="20,20,20,20" FlowDirection="RightToLeft"/>
        </Grid>

        <!-- Local Scaled Test items -->
        <Grid Grid.Row="2" Grid.Column="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" FlowDirection="RightToLeft">
            <TextBlock Style="{StaticResource LeftTextBlock}" x:Name="ParentRTLLocalScale" Text="Local Scale 75%" Margin="20,20,20,20">
                <TextBlock.RenderTransformOrigin>
                    <Point X=".5" Y=".5"/>
                </TextBlock.RenderTransformOrigin>
                <TextBlock.RenderTransform>
                    <ScaleTransform ScaleX=".75" ScaleY=".75"/>
                </TextBlock.RenderTransform>
            </TextBlock>
        </Grid>
        <Grid Grid.Row="2" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <TextBlock Style="{StaticResource RightTextBlock}" x:Name="LocalRTLLocalScale" Text="Local Scale 150%" Margin="20,20,20,20" FlowDirection="RightToLeft">
                <TextBlock.RenderTransformOrigin>
                    <Point X=".5" Y=".5"/>
                </TextBlock.RenderTransformOrigin>
                <TextBlock.RenderTransform>
                    <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                </TextBlock.RenderTransform>
            
            </TextBlock>
        </Grid>

        <!-- Combined Scaled Test items -->
        <Grid Grid.Row="3" Grid.Column="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" FlowDirection="RightToLeft">
            <Grid.RenderTransformOrigin>
                <Point X=".5" Y=".5"/>
            </Grid.RenderTransformOrigin>
            <Grid.RenderTransform>
                <ScaleTransform ScaleX=".75" ScaleY=".75"/>
            </Grid.RenderTransform>
            <TextBlock Style="{StaticResource LeftTextBlock}" x:Name="ParentRTLCombinedScale" Text="Parent/Local Scale 75%/150%" Margin="20,20,20,20">
                <TextBlock.RenderTransformOrigin>
                    <Point X=".5" Y=".5"/>
                </TextBlock.RenderTransformOrigin>
                <TextBlock.RenderTransform>
                    <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                </TextBlock.RenderTransform>
            </TextBlock>
        </Grid>
        <Grid Grid.Row="3" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Grid.RenderTransformOrigin>
                <Point X=".5" Y=".5"/>
            </Grid.RenderTransformOrigin>
            <Grid.RenderTransform>
                <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
            </Grid.RenderTransform>
            <TextBlock Style="{StaticResource RightTextBlock}" x:Name="LocalRTLCombinedScale" Text="Parent/Local Scale 150%/75%" Margin="20,20,20,20" FlowDirection="RightToLeft">
                <TextBlock.RenderTransformOrigin>
                    <Point X=".5" Y=".5"/>
                </TextBlock.RenderTransformOrigin>
                <TextBlock.RenderTransform>
                    <ScaleTransform ScaleX=".75" ScaleY=".75"/>
                </TextBlock.RenderTransform>

            </TextBlock>
        </Grid>

        <!-- Parent Flip Test items -->
        <Grid Grid.Row="4" Grid.Column="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" FlowDirection="RightToLeft">
            <Grid.RenderTransformOrigin>
                <Point X=".5" Y=".5"/>
            </Grid.RenderTransformOrigin>
            <Grid.RenderTransform>
                <ScaleTransform ScaleX="-.75" ScaleY="-.75"/>
            </Grid.RenderTransform>
            <TextBlock Style="{StaticResource LeftTextBlock}" x:Name="ParentRTLParentFlip" Text="Parent Flip 75%" Margin="20,20,20,20"/>
        </Grid>
        <Grid Grid.Row="4" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Grid.RenderTransformOrigin>
                <Point X=".5" Y=".5"/>
            </Grid.RenderTransformOrigin>
            <Grid.RenderTransform>
                <ScaleTransform ScaleX="-1.5" ScaleY="-1.5"/>
            </Grid.RenderTransform>
            <TextBlock Style="{StaticResource RightTextBlock}" x:Name="LocalRTLParentFlip" Text="Parent Flip 150%" Margin="20,20,20,20" FlowDirection="RightToLeft"/>
        </Grid>

        <!-- Local Flip Test items -->
        <Grid Grid.Row="5" Grid.Column="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" FlowDirection="RightToLeft">
            <TextBlock Style="{StaticResource LeftTextBlock}" x:Name="ParentRTLLocalFlip" Text="Local Flip 75%" Margin="20,20,20,20">
                <TextBlock.RenderTransformOrigin>
                    <Point X=".5" Y=".5"/>
                </TextBlock.RenderTransformOrigin>
                <TextBlock.RenderTransform>
                    <ScaleTransform ScaleX="-.75" ScaleY="-.75"/>
                </TextBlock.RenderTransform>
            
            </TextBlock>
        </Grid>
        <Grid Grid.Row="5" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <TextBlock Style="{StaticResource RightTextBlock}" x:Name="LocalRTLLocalFlip" Text="Local Flip 150%" Margin="20,20,20,20" FlowDirection="RightToLeft">
                <TextBlock.RenderTransformOrigin>
                    <Point X=".5" Y=".5"/>
                </TextBlock.RenderTransformOrigin>
                <TextBlock.RenderTransform>
                    <ScaleTransform ScaleX="-1.5" ScaleY="-1.5"/>
                </TextBlock.RenderTransform>
            </TextBlock>
        </Grid>

        <!-- Inner RTL Test items -->
        <Grid Grid.Row="6" Grid.Column="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" FlowDirection="RightToLeft">
            <TextBlock Style="{StaticResource LeftTextBlock}" x:Name="ParentRTLLocalLTR" Text="Local LTR" Margin="20,20,20,20" FlowDirection="LeftToRight">
                <TextBlock.RenderTransformOrigin>
                    <Point X=".5" Y=".5"/>
                </TextBlock.RenderTransformOrigin>
                <TextBlock.RenderTransform>
                    <ScaleTransform ScaleX=".75" ScaleY=".75"/>
                </TextBlock.RenderTransform>
            </TextBlock>
        </Grid>
        <Grid Grid.Row="6" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" FlowDirection="RightToLeft">
            <Grid.RenderTransformOrigin>
                <Point X=".5" Y=".5"/>
            </Grid.RenderTransformOrigin>
            <Grid.RenderTransform>
                <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
            </Grid.RenderTransform>
            <TextBlock Style="{StaticResource LeftTextBlock}" x:Name="ParentRTLLocalLTRScale" Text="Local LTR with scale" Margin="20,20,20,20" FlowDirection="LeftToRight">
                <TextBlock.RenderTransformOrigin>
                    <Point X=".5" Y=".5"/>
                </TextBlock.RenderTransformOrigin>
                <TextBlock.RenderTransform>
                    <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                </TextBlock.RenderTransform>
            </TextBlock>
        </Grid>
   </Grid>
</Grid>

