<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      x:Name="RootGrid"
      HorizontalAlignment="Left"
      VerticalAlignment="Top"
      Margin="50"
      Width="300"
      Height="300"
      Background="#88FF0000">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <Button x:Name="TopLeftButton"
            Grid.Row="0"
            Grid.Column="0"
            Width="150"
            Height="150"
            Background="#8800FF00"
            Content="TopLeft"
            CornerRadius="0">
    </Button>
    <Button x:Name="TopRightButton"
            Grid.Row="0"
            Grid.Column="1"
            Width="150"
            Height="150"
            Background="#8800FF00"
            Content="TopRight"
            CornerRadius="0">
    </Button>
    <Button x:Name="BottomLeftButton"
            Grid.Row="1"
            Grid.Column="0"
            Width="150"
            Height="150"
            Background="#8800FF00"
            Content="BottomLeft"
            CornerRadius="0">
    </Button>
    <Button x:Name="BottomRightButton"
            Grid.Row="1"
            Grid.Column="1"
            Width="150"
            Height="150"
            Background="#8800FF00"
            Content="BottomRight"
            CornerRadius="0">
    </Button>
</Grid>