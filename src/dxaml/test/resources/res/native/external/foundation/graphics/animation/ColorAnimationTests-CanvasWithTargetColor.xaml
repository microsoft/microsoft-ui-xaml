<Canvas xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Width="300" Height="500" Background="Blue">

        <Canvas Width="50" Height="20">
            <Canvas.Background><SolidColorBrush x:Name="canvasBrush" /></Canvas.Background>
        </Canvas>

        <Border Width="50" Height="20" BorderThickness="2">
            <Border.Background><SolidColorBrush x:Name="backgroundBrush1" /></Border.Background>
        </Border>

        <Border Width="50" Height="20" BorderThickness="2">
            <Border.BorderBrush><SolidColorBrush x:Name="borderBrush1" /></Border.BorderBrush>
        </Border>

        <Border Width="50" Height="20" BorderThickness="2">
            <Border.Background><SolidColorBrush x:Name="backgroundBrush2" /></Border.Background>
            <Border.BorderBrush><SolidColorBrush x:Name="borderBrush2" /></Border.BorderBrush>
        </Border>

        <Border Width="50" Height="20" BorderThickness="2" CornerRadius="5">
            <Border.Background><SolidColorBrush x:Name="backgroundBrush3" /></Border.Background>
        </Border>

        <Border Width="50" Height="20" BorderThickness="2" CornerRadius="5">
            <Border.BorderBrush><SolidColorBrush x:Name="borderBrush3" /></Border.BorderBrush>
        </Border>

        <Border Width="50" Height="20" BorderThickness="2" CornerRadius="5">
            <Border.Background><SolidColorBrush x:Name="backgroundBrush4" /></Border.Background>
            <Border.BorderBrush><SolidColorBrush x:Name="borderBrush4" /></Border.BorderBrush>
        </Border>

        <Rectangle Width="50" Height="20" StrokeThickness="2">
            <Rectangle.Fill><SolidColorBrush x:Name="fillBrush1" /></Rectangle.Fill>
        </Rectangle>

        <Rectangle Width="50" Height="20" StrokeThickness="2">
            <Rectangle.Stroke><SolidColorBrush x:Name="strokeBrush1" /></Rectangle.Stroke>
        </Rectangle>

        <Rectangle Width="50" Height="20" StrokeThickness="2">
            <Rectangle.Fill><SolidColorBrush x:Name="fillBrush2" /></Rectangle.Fill>
            <Rectangle.Stroke><SolidColorBrush x:Name="strokeBrush2" /></Rectangle.Stroke>
        </Rectangle>

        <Rectangle Width="50" Height="20" RadiusX="5" RadiusY="5" StrokeThickness="2">
            <Rectangle.Fill><SolidColorBrush x:Name="fillBrush3" /></Rectangle.Fill>
        </Rectangle>

        <Rectangle Width="50" Height="20" RadiusX="5" RadiusY="5" StrokeThickness="2">
            <Rectangle.Stroke><SolidColorBrush x:Name="strokeBrush3" /></Rectangle.Stroke>
        </Rectangle>

        <Rectangle Width="50" Height="20" RadiusX="5" RadiusY="5" StrokeThickness="2">
            <Rectangle.Fill><SolidColorBrush x:Name="fillBrush4" /></Rectangle.Fill>
            <Rectangle.Stroke><SolidColorBrush x:Name="strokeBrush4" /></Rectangle.Stroke>
        </Rectangle>

        <Ellipse Width="50" Height="20" StrokeThickness="2">
            <Ellipse.Fill><SolidColorBrush x:Name="fillBrush5" /></Ellipse.Fill>
        </Ellipse>

        <Ellipse Width="50" Height="20" StrokeThickness="2">
            <Ellipse.Stroke><SolidColorBrush x:Name="strokeBrush5" /></Ellipse.Stroke>
        </Ellipse>

        <Ellipse Width="50" Height="20" StrokeThickness="2">
            <Ellipse.Fill><SolidColorBrush x:Name="fillBrush6" /></Ellipse.Fill>
            <Ellipse.Stroke><SolidColorBrush x:Name="strokeBrush6" /></Ellipse.Stroke>
        </Ellipse>

        <TextBlock Width="50" Height="20" Text="asdf">
            <TextBlock.Foreground><SolidColorBrush x:Name="textBlockBrush1" /></TextBlock.Foreground>
        </TextBlock>

        <!-- A Foreground brush on a Run can't be animated. This should draw red. -->
        <TextBlock Width="50" Height="20">
            <Run Text="asdf">
                <Run.Foreground><SolidColorBrush x:Name="textBlockBrush2" Color="Red" /></Run.Foreground>
            </Run>
        </TextBlock>

    </StackPanel>
</Canvas>