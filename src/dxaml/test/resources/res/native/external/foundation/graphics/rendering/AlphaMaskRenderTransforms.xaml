<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Width="800" Height="600" Background="RoyalBlue">
  <Grid.Resources>
    <Style TargetType="Border">
      <Setter Property="Margin" Value="1"/>
      <Setter Property="Background" Value="Beige"/>
      <Setter Property="VerticalAlignment" Value="Top"/>
    </Style>
    <Style x:Key="borderRotate" TargetType="Border">
      <Setter Property="VerticalAlignment" Value="Top"/>
      <Setter Property="HorizontalAlignment" Value="Left"/>
      <Setter Property="Margin" Value="5"/>
      <Setter Property="BorderBrush" Value="Red"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="RenderTransform">
        <Setter.Value>
          <RotateTransform Angle="10"/>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="borderScale" TargetType="Border">
      <Setter Property="Margin" Value="-3"/>
      <Setter Property="BorderBrush" Value="Green"/>
      <Setter Property="BorderThickness" Value="0.5"/>
      <Setter Property="RenderTransform">
        <Setter.Value>
          <ScaleTransform ScaleX="2" ScaleY="2"/>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="borderShift" TargetType="Border">
      <Setter Property="Margin" Value="-3"/>
      <Setter Property="BorderBrush" Value="Blue"/>
      <Setter Property="BorderThickness" Value="0.5"/>
      <Setter Property="RenderTransform">
        <Setter.Value>
          <TranslateTransform X="10" Y="-5"/>
        </Setter.Value>
      </Setter>
    </Style>
    <LinearGradientBrush x:Key="brushLGB" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="Yellow" Offset="0.0" />
      <GradientStop Color="#c0000000" Offset="0.25" />
      <GradientStop Color="Green" Offset="0.5" />
      <GradientStop Color="#40ffffff" Offset="0.75" />
      <GradientStop Color="LimeGreen" Offset="1.0" />
    </LinearGradientBrush>
  </Grid.Resources>
  <Border Grid.Column="0" Grid.Row="0" Height="70">
    <Border Style="{StaticResource borderRotate}">
      <Border Style="{StaticResource borderScale}">
        <Border Style="{StaticResource borderShift}">
          <TextBlock Margin="5" Text="The quick"/>
        </Border>
      </Border>
    </Border>
  </Border>
  <Border Grid.Column="1" Grid.Row="0" Height="70">
    <Border Style="{StaticResource borderRotate}">
      <Border Style="{StaticResource borderScale}">
        <Border Style="{StaticResource borderShift}">
          <Rectangle Width="50" Height="50"/>
        </Border>
      </Border>
    </Border>
  </Border>
  <Border Grid.Column="0" Grid.Row="1">
    <TextBlock FontFamily="Arial">
      The <Span Foreground="{StaticResource brushLGB}">quick brown</Span> fox
    </TextBlock>
  </Border>
  <Border Grid.Column="1" Grid.Row="1">
    <Rectangle Width="50" Height="50" Fill="{StaticResource brushLGB}" />
  </Border>
  <Border Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2">
    <Canvas Height="30">
      <TextBlock Canvas.Left="5" Canvas.Top="5">
        <Run Foreground="Red">The</Run> quick <Run Foreground="Green">brown</Run> fox <Run Foreground="Blue">jumps</Run> over <Bold Foreground="Blue">the</Bold> lazy dog.
      </TextBlock>
    </Canvas>
  </Border>
  <Border Grid.Column="1" Grid.Row="2" Grid.ColumnSpan="2">
    <Canvas Height="30">
      <Rectangle Canvas.Left="5" Canvas.Top="5" Width="50" Height="50" Fill="{StaticResource brushLGB}" />
    </Canvas>
  </Border>
  <Border Grid.Column="0" Grid.Row="3">
    <Canvas Height="65">
      <TextBlock>
        <TextBlock.RenderTransform>
          <ScaleTransform ScaleX="1.75" ScaleY="1.75" />
        </TextBlock.RenderTransform>
        The <Run Foreground="Blue">quick</Run><LineBreak/>brown <Run Foreground="Green">fox</Run>
      </TextBlock>
    </Canvas>
  </Border>
  <Border Grid.Column="1" Grid.Row="3">
    <Canvas Height="65">
      <Rectangle Width="50" Height="50" Fill="{StaticResource brushLGB}">
        <Rectangle.RenderTransform>
          <ScaleTransform ScaleX="1.75" ScaleY="1.75" />
        </Rectangle.RenderTransform>
      </Rectangle>
    </Canvas>
  </Border>
  <Border Grid.Column="0" Grid.Row="4" Height="70">
    <Border Style="{StaticResource borderRotate}">
      <Border Style="{StaticResource borderScale}">
        <Border Style="{StaticResource borderShift}">
          <Canvas Height="65">
            <TextBlock>
              <TextBlock.RenderTransform>
                <ScaleTransform ScaleX="1.75" ScaleY="1.75" />
              </TextBlock.RenderTransform>
              The <Span Foreground="{StaticResource brushLGB}">quick brown</Span> fox
            </TextBlock>
          </Canvas>
        </Border>
      </Border>
    </Border>
  </Border>
  <Border Grid.Column="1" Grid.Row="4" Height="70">
    <Border Style="{StaticResource borderRotate}">
      <Border Style="{StaticResource borderScale}">
        <Border Style="{StaticResource borderShift}">
          <Canvas Height="65">
            <Rectangle Width="50" Height="50" Fill="{StaticResource brushLGB}">
              <Rectangle.RenderTransform>
                <ScaleTransform ScaleX="1.75" ScaleY="1.75" />
              </Rectangle.RenderTransform>
            </Rectangle>
          </Canvas>
        </Border>
      </Border>
    </Border>
  </Border>
  <Border Grid.Column="0" Grid.Row="5" Height="70">
    <Border Style="{StaticResource borderRotate}">
      <Border Style="{StaticResource borderScale}">
        <Border Style="{StaticResource borderShift}">
          <Canvas Height="65">
            <TextBlock>
              <TextBlock.RenderTransform>
                <TransformGroup>
                  <ScaleTransform ScaleX="2" ScaleY="2" />
                  <RotateTransform Angle="15" />
                </TransformGroup>
              </TextBlock.RenderTransform>
              The <Span Foreground="{StaticResource brushLGB}">quick brown</Span> fox
            </TextBlock>
          </Canvas>
        </Border>
      </Border>
    </Border>
  </Border>
  <Border Grid.Column="1" Grid.Row="5" Height="70">
    <Border Style="{StaticResource borderRotate}">
      <Border Style="{StaticResource borderScale}">
        <Border Style="{StaticResource borderShift}">
          <Canvas Height="65">
            <Rectangle Width="50" Height="50" Fill="{StaticResource brushLGB}">
              <Rectangle.RenderTransform>
                <TransformGroup>
                  <ScaleTransform ScaleX="2" ScaleY="2" />
                  <RotateTransform Angle="15" />
                </TransformGroup>
              </Rectangle.RenderTransform>
            </Rectangle>
          </Canvas>
        </Border>
      </Border>
    </Border>
  </Border>
</Grid>