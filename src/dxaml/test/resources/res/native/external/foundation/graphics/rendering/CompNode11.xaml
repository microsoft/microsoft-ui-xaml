<StackPanel xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Margin="20">
    <Canvas>
        <Canvas CompositeMode="SourceOver" Width="100" Height="100" Background="Red">
            <Canvas.Clip>
                <RectangleGeometry Rect="10,20,30,40">
                    <RectangleGeometry.Transform>
                        <RotateTransform Angle="45"></RotateTransform>
                    </RectangleGeometry.Transform>
                </RectangleGeometry>
            </Canvas.Clip>
        </Canvas>
    </Canvas>
</StackPanel>
