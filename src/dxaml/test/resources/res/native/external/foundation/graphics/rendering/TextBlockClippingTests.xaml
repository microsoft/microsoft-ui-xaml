<StackPanel xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Margin="20">
    <!-- Test that the full text of the TextBlock is shown, given that it has enough horizontal space to display -->
    <TextBlock
        Padding="32,0"
        TextTrimming="CharacterEllipsis"
        HorizontalAlignment="Left"
        FontSize="12"
        Text="Properties">
    </TextBlock>

    <!-- Test that the full text of the RichTextBlock is shown, given that it has enough horizontal space to display -->
    <RichTextBlock
        Padding="32,0"
        TextTrimming="CharacterEllipsis"
        HorizontalAlignment="Left"
        FontSize="12">
        <Paragraph>
            Properties
        </Paragraph>
    </RichTextBlock>

    <!-- Test that the overflow text from the RichTextBlock displays correctly in the RichTextBlockOverflow given that it has enough space to display -->
    <RichTextBlock  
        OverflowContentTarget="{Binding ElementName=firstOverflowContainer}" 
        Width="0"
        Height="0"
        TextTrimming="CharacterEllipsis"
        FontSize="12">
    <!-- The first character of the paragraph is consumed by the RTB even with Width set to 0-->
    <Paragraph>
        .Properties
    </Paragraph>
    </RichTextBlock>
    <RichTextBlockOverflow
        x:Name="firstOverflowContainer"
        Padding="32,0"
        HorizontalAlignment="Left"              
    />
</StackPanel>