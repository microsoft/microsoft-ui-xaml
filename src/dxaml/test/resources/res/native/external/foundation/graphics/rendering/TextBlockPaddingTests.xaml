  <StackPanel xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Margin="20">
     <StackPanel>
         <TextBlock Padding="20" FontFamily="Segoe UI" FontSize="15" Text="TextBlock"/>
         <TextBlock Padding="10,20" FontFamily="Segoe UI" FontSize="15" Text="TextBlock"/>
         <TextBlock Padding="10,20,30,40" FontFamily="Segoe UI" FontSize="15" Text="TextBlock"/>
     </StackPanel>
     <StackPanel FlowDirection="RightToLeft">
         <TextBlock Padding="20" FontFamily="Segoe UI" FontSize="15" Text="TextBlock" TextAlignment="Left" TextReadingOrder="UseFlowDirection"/>
         <TextBlock Padding="10,20" FontFamily="Segoe UI" FontSize="15" Text="TextBlock" TextAlignment="Left" TextReadingOrder="UseFlowDirection"/>
         <TextBlock Padding="10,20,30,40" FontFamily="Segoe UI" FontSize="15" Text="TextBlock" TextAlignment="Left" TextReadingOrder="UseFlowDirection"/>
     </StackPanel>
</StackPanel>
