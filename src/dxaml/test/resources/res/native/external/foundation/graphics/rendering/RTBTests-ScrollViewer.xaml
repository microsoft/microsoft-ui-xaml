<StackPanel xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ScrollViewer x:Name="sv" HorizontalAlignment="Center" 
    HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden"
    Height="140" Width="140">
    <ScrollViewer.TopLeftHeader>
      <Rectangle Height="40" Width="60" Fill="White"/>
    </ScrollViewer.TopLeftHeader>
    <ScrollViewer.TopHeader>
      <StackPanel Orientation="Horizontal">
        <Rectangle Height="40" Width="50" Fill="Orange"/>
        <Rectangle Height="40" Width="150" Fill="Red"/>
      </StackPanel>
    </ScrollViewer.TopHeader>
    <ScrollViewer.LeftHeader>
      <StackPanel>
        <Rectangle Height="50" Width="60" Fill="Cyan"/>
        <Rectangle Height="160" Width="60" Fill="Blue"/>
      </StackPanel>
    </ScrollViewer.LeftHeader>
    <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top">
      <StackPanel Orientation="Horizontal">
        <Rectangle Height="50" Width="50" Fill="White"/>
        <Rectangle Height="50" Width="150" Fill="DarkGray"/>
      </StackPanel>
      <StackPanel Orientation="Horizontal">
        <Rectangle Height="160" Width="50" Fill="LightGray"/>
        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top">
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top">
            <Rectangle Height="80" Width="50" Fill="#FF444444"/>
            <Rectangle Height="80" Width="50" Fill="#FF555555"/>
            <Rectangle Height="80" Width="50" Fill="#FF666666"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top">
            <Rectangle Height="80" Width="50" Fill="#FF777777"/>
            <Rectangle Height="80" Width="50" Fill="#FF888888"/>
            <Rectangle Height="80" Width="50" Fill="#FF999999"/>
          </StackPanel>
        </StackPanel>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
  <Image x:Name="img" HorizontalAlignment="Center"/>
</StackPanel>