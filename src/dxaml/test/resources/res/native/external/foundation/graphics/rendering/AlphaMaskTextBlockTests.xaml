<StackPanel xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            Margin="20">
    <TextBlock FontSize="15" Text="EnglishRTL" FlowDirection="RightToLeft" TextReadingOrder="UseFlowDirection" TextAlignment="Left" Width="200"  FontFamily="Segoe UI" Margin="20,5,10,0"/>
    <TextBlock FontSize="15" Text="EnglishLTR" FlowDirection="LeftToRight" TextReadingOrder="UseFlowDirection" TextAlignment="Left" Width="200"  FontFamily="Segoe UI" Margin="20,5,10,0"/>
    <TextBlock FontSize="15" Text="RTLنسيايب123!" FlowDirection="RightToLeft" TextReadingOrder="UseFlowDirection" TextAlignment="Left" Width="200"  FontFamily="Segoe UI" Margin="20,5,10,0"/>
    <TextBlock FontSize="15" Text="LTRنسيايب123!" FlowDirection="LeftToRight" TextReadingOrder="UseFlowDirection" TextAlignment="Left" Width="200"  FontFamily="Segoe UI" Margin="20,5,10,0"/>
    <TextBlock FontSize="30" Text="TextBlock" TextDecorations="Underline"/>
    <TextBlock FontSize="15" TextTrimming="Clip" Typography.Variants="Subscript" FontFamily="Palatino Linotype" Text="Subscript"/>
    <TextBlock FontSize="16" Text="Hello World, Hello world, hello world hello world hello world ああああああああああああ" FontFamily="Segoe UI" Width="200" TextWrapping="Wrap" TextLineBounds="TrimToCapHeight"/>
    <TextBlock FontSize="15" Padding="10,20,30,40" FontFamily="Segoe UI" Text="TextBlock"/>
    <TextBlock FontSize="16" Text="Hello World, Hello world, hello world hello world hello world ああああああああああああ" FontFamily="Segoe UI" Width="200" TextWrapping="Wrap" LineStackingStrategy="BaselineToBaseline" />
    <TextBlock FontSize="15">
        <Run>Pre-hyperlink:</Run>
        <Hyperlink  x:Name="hyperlink" NavigateUri="www.bing.com">Bing</Hyperlink>
        <Run>Post-hyperlink</Run>
    </TextBlock>
</StackPanel>
