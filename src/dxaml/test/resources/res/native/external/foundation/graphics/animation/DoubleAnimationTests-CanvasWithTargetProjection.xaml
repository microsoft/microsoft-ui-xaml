<Canvas xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Canvas Width="200" Height="200" Background="Blue" Canvas.Top="100" x:Name="outerCanv">
        <Canvas.Projection>
            <PlaneProjection x:Name="outerProj" />
        </Canvas.Projection>

        <Canvas Width="100" Height="100" Background="Red" Canvas.Top="50" Canvas.Left="50" x:Name="canv">
            <Canvas.Projection>
                <PlaneProjection x:Name="proj" />
            </Canvas.Projection>
        </Canvas>
    </Canvas>

</Canvas>