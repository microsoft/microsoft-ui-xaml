<StackPanel xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Margin="20">
    <Canvas>
        <Canvas x:Name="myCanvas" CompositeMode="SourceOver" Width="100" Height="100" Background="Red">
            <Canvas.Transform3D>
                <CompositeTransform3D x:Name="myTransform" RotationZ="0"/>
            </Canvas.Transform3D>
            <Canvas.Triggers>
                <EventTrigger RoutedEvent="Canvas.Loaded">
                    <BeginStoryboard>
                        <Storyboard x:Name="myStoryboard">
                            <DoubleAnimation Storyboard.TargetName="myTransform" Storyboard.TargetProperty="RotationZ" To="45" Duration="0:0:4" RepeatBehavior="Forever"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Canvas.Triggers>
        </Canvas>
    </Canvas>
</StackPanel>
