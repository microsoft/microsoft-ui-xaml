<StackPanel xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Margin="20">
<!-- Test animation of shared transform used with different RenderTransformOrigins -->
    <Canvas>
        <Canvas.Resources>
            <TranslateTransform x:Name="tr1"/>
        </Canvas.Resources>
        <Canvas.Triggers>
            <EventTrigger RoutedEvent="Canvas.Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="tr1" Storyboard.TargetProperty="X" From="0" To="100" Duration="0:0:2" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Canvas.Triggers>

        <Canvas Width="10" Height="10" Background="Red" RenderTransform="{StaticResource tr1}" RenderTransformOrigin="0,0"/>

        <Canvas Width="10" Height="10" Background="Red" RenderTransform="{StaticResource tr1}" RenderTransformOrigin="0,1"/>

        <Canvas Width="10" Height="10" Background="Red" RenderTransform="{StaticResource tr1}" RenderTransformOrigin="0.5,0.5"/>

        <Canvas Width="10" Height="10" Background="Red" RenderTransform="{StaticResource tr1}" RenderTransformOrigin="1,0"/>

        <Canvas Width="10" Height="10" Background="Red" RenderTransform="{StaticResource tr1}" RenderTransformOrigin="1,1"/>
    </Canvas>
</StackPanel>
