<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Orientation="Horizontal">
        <Image x:Name="imageElement" Width="100" Height="100"/>
        <Ellipse x:Name="ellipseElement" Width="200" Height="200">
            <Ellipse.Fill>
                <ImageBrush x:Name="ellipseBrush"/>
            </Ellipse.Fill>
        </Ellipse>
    </StackPanel>
</Grid>