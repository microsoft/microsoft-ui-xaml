<StackPanel xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Margin="20">
    <Canvas Width="50" Height="50">
        <Rectangle x:Name="myRectangle" Width="100" Height="100" Fill="Red" Canvas.Top="25" Canvas.Left="25">
            <Rectangle.Triggers>
                <EventTrigger RoutedEvent="Rectangle.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="myRectangle" Storyboard.TargetProperty="(Canvas.Top)" To="50" Duration="0:0:4" RepeatBehavior="Forever"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Rectangle.Triggers>
        </Rectangle>
    </Canvas>
</StackPanel>
