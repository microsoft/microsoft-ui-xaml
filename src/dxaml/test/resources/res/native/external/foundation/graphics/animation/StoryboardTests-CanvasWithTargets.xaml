<Canvas xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Canvas Width="10" Height="10" Canvas.Top="100" x:Name="canv">
        <Canvas.RenderTransform>
            <TransformGroup>
                <TranslateTransform x:Name="tr1" />
                <TranslateTransform x:Name="tr2" />
                <TranslateTransform x:Name="tr3" />
                <TranslateTransform x:Name="tr4" />
                <TranslateTransform x:Name="tr5" />
                <TranslateTransform x:Name="tr6" />
                <TranslateTransform x:Name="tr7" />
                <TranslateTransform x:Name="tr8" />
                <TranslateTransform x:Name="tr9" />
                <TranslateTransform x:Name="tr10" />
                <TranslateTransform x:Name="tr11" />
                <TranslateTransform x:Name="tr12" />
                <TranslateTransform x:Name="tr13" />
                <TranslateTransform x:Name="tr14" />
                <TranslateTransform x:Name="tr15" />
            </TransformGroup>
        </Canvas.RenderTransform>
        <Canvas.Background>
            <SolidColorBrush x:Name="brush" Color="Red" />
        </Canvas.Background>
    </Canvas>

    <Canvas x:Name="collapsedCanvas" Width="10" Height="10" Background="Green" Visibility="Collapsed">
        <Canvas.RenderTransform>
            <TranslateTransform x:Name="trCollapsed" />
        </Canvas.RenderTransform>
        <Canvas.Transform3D>
            <CompositeTransform3D x:Name="tr3dCollapsed" />
        </Canvas.Transform3D>
        <Canvas.Projection>
            <PlaneProjection x:Name="projCollapsed" />
        </Canvas.Projection>
    </Canvas>

</Canvas>