<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      x:ConnectionId='0'>

    <StackPanel x:Name="sp1" x:ConnectionId='1'>
    
        <Button x:Name='btnNotDeferred2' x:ConnectionId='2'/>
        <Button x:Name='btnDeferred3' x:ConnectionId='3' x:DeferLoadStrategy='Lazy' />

        <ContentControl x:Name="ccouter" Content="outer" x:ConnectionId='4'>
            <ContentControl.ContentTemplate>
                <DataTemplate>
                    <StackPanel x:Name="sp100" x:ConnectionId='100'>
                    
                        <Button x:Name='btnNotDeferred101' x:ConnectionId='101'/>
                        <Button x:Name='btnDeferred102' x:ConnectionId='102' x:DeferLoadStrategy='Lazy' />

                        <ContentControl x:Name="ccinner" Content="inner" x:ConnectionId='103'>
                            <ContentControl.ContentTemplate>
                                <DataTemplate>
                                    <Grid x:Name="gr200" x:ConnectionId='200'>
                                        <Button x:Name='btnNotDeferred201' x:ConnectionId='201'/>
                                        <Button x:Name='btnDeferred202' x:ConnectionId='202' x:DeferLoadStrategy='Lazy' />
                                    </Grid>
                                </DataTemplate>
                            </ContentControl.ContentTemplate>
                        </ContentControl>

                        <Button x:Name='btnDeferred104' x:ConnectionId='104' x:DeferLoadStrategy='Lazy' />
                        <Button x:Name='btnNotDeferred105' x:ConnectionId='105'/>

                    </StackPanel>
                </DataTemplate>
            </ContentControl.ContentTemplate>
        </ContentControl>

        <Button x:Name='btnDeferred5' x:ConnectionId='5' x:DeferLoadStrategy='Lazy' />
        <Button x:Name='btnNotDeferred6' x:ConnectionId='6'/>
        
    </StackPanel>
</Page>
