<StackPanel xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
  <StackPanel.Resources>
    <ResourceDictionary>
      <Style TargetType="ListView" x:Key="ListViewStyle1">
        <Setter Property="ItemContainerStyle">
          <Setter.Value>
            <Style TargetType="ListViewItem">
              <Setter Property="Background" Value="Blue" />
            </Style>
          </Setter.Value>
        </Setter>
      </Style>
      <Style TargetType="ListView" x:Key="ListViewStyle2">
        <Setter Property="ItemContainerStyle">
          <Setter.Value>
            <Style TargetType="ListViewItem">
              <Setter Property="Background" Value="Red" />
            </Style>
          </Setter.Value>
        </Setter>
      </Style>
    </ResourceDictionary>
  </StackPanel.Resources>
  <ListView Style="{StaticResource ListViewStyle1}">
    <ListViewItem>Item1a</ListViewItem>
    <ListViewItem>Item1b</ListViewItem>
  </ListView>
  <ListView Style="{StaticResource ListViewStyle2}">
    <ListViewItem>Item2a</ListViewItem>
    <ListViewItem>Item2b</ListViewItem>
  </ListView>
</StackPanel>