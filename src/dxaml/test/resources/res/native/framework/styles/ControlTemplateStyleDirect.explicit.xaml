<Canvas xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:Tests.Native.External.Framework"
        Background="Yellow">
    <Canvas.Resources>
        <Style x:Key="myStyle" TargetType="local:CustomControl">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate>
                        <TextBlock x:Name="textBlockFromTemplate" Text="Monty Python"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Canvas.Resources>
    <local:CustomControl Style="{StaticResource myStyle}"/>
</Canvas>