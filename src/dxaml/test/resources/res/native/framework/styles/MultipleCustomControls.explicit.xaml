<Canvas xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:Tests.Native.External.Framework"
        Background="Yellow">
    <Canvas.Resources>
        <Style x:Key="myStyle" TargetType="local:CustomControl">
            <Setter Property="Width" Value="128" />
            <Setter Property="CustomString" Value="A string" />
            <Setter Property="CustomInt" Value="123" />
            <Setter Property="WorkingTag" Value="abc" />
            <Setter Property="Canvas.Top" Value="256" />
            <Setter Property="local:ControlWithAttachedProperty.CustomAttached" Value="customAttached" />
            <Setter Property="CustomThickness" Value="2" />
        </Style>
    </Canvas.Resources>
    <local:CustomControl Style="{StaticResource myStyle}"/>
    <local:CustomControl Style="{StaticResource myStyle}"/>
</Canvas>