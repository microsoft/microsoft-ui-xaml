<StackPanel xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation">
  <StackPanel.Resources>
    <ResourceDictionary>
      <!-- We define 1 resource here to force the case where the dictionary
           does NOT have custom runtime data via XBF. -->
      <Style TargetType="Button" x:Key="BlueButtonStyle">
        <Setter Property="Background" Value="Blue" />
      </Style>
    </ResourceDictionary>
  </StackPanel.Resources>
  <Button Style="{StaticResource BlueButtonStyle}" Content="Blue Button" />
</StackPanel>