<UserControl 
    x:Name="rootUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Width="400" Height="300">    
    <UserControl.Resources>
        <Storyboard x:Name="textBlockStoryboard" Duration="Automatic">
            <DoubleAnimation Storyboard.TargetName="textBlock" Storyboard.TargetProperty="Height"
                             From="20" To="64" FillBehavior="HoldEnd" Duration="0"/>
        </Storyboard>
    </UserControl.Resources>
    
    <StackPanel x:Name="layoutRoot">
        <StackPanel.Triggers>
            <EventTrigger RoutedEvent="StackPanel.Loaded">
                <BeginStoryboard>
                    <Storyboard x:Name="itemsControlStoryboard" Duration="Automatic">
                        <DoubleAnimation Storyboard.TargetName="itemsControl" Storyboard.TargetProperty="Width"
                                         From="10" To="128" FillBehavior="HoldEnd" Duration="0"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </StackPanel.Triggers>
        <Button x:Name="button">
            <ItemsControl x:Name="itemsControl">
                <TextBlock x:Name="textBlock"/>
            </ItemsControl>
        </Button>        
    </StackPanel>
</UserControl>
