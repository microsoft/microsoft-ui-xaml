<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Button x:Name="BeforeButton" Content="Before Button" Tag="B"/>

    <StackPanel Grid.Row="1">
      <ItemsControl x:Name="MainItemsControl" 
        IsTabStop="False" Visibility="Collapsed">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <StackPanel>
              <Button Content="{Binding}" Tag="{Binding}"/>
              <ItemsControl IsTabStop="False" TabNavigation="Once">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button Content="{Binding}" Tag="{Binding}"/>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
                <x:String>.1</x:String>
                <x:String>.2</x:String>
                <x:String>.3</x:String>
              </ItemsControl>
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
        <x:String>1</x:String>
        <x:String>2</x:String>
        <x:String>3</x:String>
      </ItemsControl>

      <ItemsControl x:Name="MainVirtualizedItemsControl"
        IsTabStop="False" Visibility="Collapsed" TabNavigation="Local" MaxHeight="250">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <ItemsStackPanel CacheLength="1"/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <StackPanel>
              <Button Content="{Binding}" Tag="{Binding}"/>
              <ItemsControl IsTabStop="False" TabNavigation="Once">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <ItemsWrapGrid
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        MaximumRowsOrColumns="1"
                        Orientation="Vertical"/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button Content="{Binding}" Tag="{Binding}"/>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
                <x:String>.1</x:String>
                <x:String>.2</x:String>
                <x:String>.3</x:String>
              </ItemsControl>
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
        <x:String>1</x:String>
        <x:String>2</x:String>
        <x:String>3</x:String>
        <x:String>4</x:String>
        <x:String>5</x:String>
        <x:String>6</x:String>
        <x:String>7</x:String>
        <x:String>8</x:String>
        <x:String>9</x:String>
        <x:String>10</x:String>
        <x:String>11</x:String>
        <x:String>12</x:String>
        <x:String>13</x:String>
        <x:String>14</x:String>
        <x:String>15</x:String>
      </ItemsControl>

      <ItemsControl x:Name="MainItemsControlWithVirtualizingStackPanel" 
        IsTabStop="False" Visibility="Collapsed">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <StackPanel>
              <Button Content="{Binding}" Tag="{Binding}"/>
              <ItemsControl IsTabStop="False" TabNavigation="Once">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button Content="{Binding}" Tag="{Binding}"/>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
                <x:String>.1</x:String>
                <x:String>.2</x:String>
                <x:String>.3</x:String>
              </ItemsControl>
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <VirtualizingStackPanel/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <x:String>1</x:String>
        <x:String>2</x:String>
        <x:String>3</x:String>
      </ItemsControl>

      <ItemsControl x:Name="MainItemsControlWithStackPanel" 
        IsTabStop="False" Visibility="Collapsed">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <StackPanel>
              <Button Content="{Binding}" Tag="{Binding}"/>
              <ItemsControl IsTabStop="False" TabNavigation="Once">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button Content="{Binding}" Tag="{Binding}"/>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
                <x:String>.1</x:String>
                <x:String>.2</x:String>
                <x:String>.3</x:String>
              </ItemsControl>
            </StackPanel>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <x:String>1</x:String>
        <x:String>2</x:String>
        <x:String>3</x:String>
      </ItemsControl>
    </StackPanel>

    <Button x:Name="AfterButton" Content="After Button" Tag="A" Grid.Row="2"/>
  </Grid>
</Page>

