<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ScrollViewer x:Name="scrollViewer"
      HorizontalScrollBarVisibility="Auto"
      VerticalScrollBarVisibility="Disabled"
      HorizontalScrollMode="Enabled"
      VerticalScrollMode="Disabled"
      Width="380"
      Height="380"
      Margin="10">
    <StackPanel Orientation="Horizontal">
      <Rectangle Fill="Cyan" Width="100" Height="100" VerticalAlignment="Center"/>
      <GridView
        x:Name="gridView"
        Background="Magenta"
        Height="300"
        VerticalAlignment="Center"
        ScrollViewer.HorizontalScrollBarVisibility="Auto"
        ScrollViewer.VerticalScrollBarVisibility="Disabled"
        ScrollViewer.HorizontalScrollMode="Enabled"
        ScrollViewer.IsHorizontalRailEnabled="True"
        ScrollViewer.VerticalScrollMode="Disabled"
        ScrollViewer.IsVerticalRailEnabled="False">
        <GridView.ItemsPanel>
          <ItemsPanelTemplate>
            <ItemsWrapGrid Orientation="Vertical"/>
          </ItemsPanelTemplate>
        </GridView.ItemsPanel>
        <Rectangle Fill="Blue" Width="300" Height="120"/>
        <Rectangle Fill="Green" Width="300" Height="120"/>
        <Rectangle Fill="Red" Width="300" Height="120"/>
        <Rectangle Fill="Yellow" Width="300" Height="120"/>
        <Rectangle Fill="Blue" Width="300" Height="120"/>
        <Rectangle Fill="Green" Width="300" Height="120"/>
        <Rectangle Fill="Red" Width="300" Height="120"/>
        <Rectangle Fill="Yellow" Width="300" Height="120"/>
        <Rectangle Fill="Blue" Width="300" Height="120"/>
        <Rectangle Fill="Green" Width="300" Height="120"/>
        <Rectangle Fill="Red" Width="300" Height="120"/>
        <Rectangle Fill="Yellow" Width="300" Height="120"/>
        <Rectangle Fill="Blue" Width="300" Height="120"/>
        <Rectangle Fill="Green" Width="300" Height="120"/>
        <Rectangle Fill="Red" Width="300" Height="120"/>
        <Rectangle Fill="Yellow" Width="300" Height="120"/>
      </GridView>
      <Rectangle Fill="Violet" Width="100" Height="100" VerticalAlignment="Center"/>
    </StackPanel>
  </ScrollViewer>
</Grid>

