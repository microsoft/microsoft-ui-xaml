<StackPanel xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:sys="using:System">
    <CommandingContainer x:Name="RichEditCommandingContainer" CommandingTarget="{Binding ElementName=CommandingClientPanel}">
        <CommandingContainer.Resources>
            <XamlUICommand x:Name="BoldCommand" Label="Bold">
                <XamlUICommand.IconSource>
                    <SymbolIconSource Symbol="Bold" />
                </XamlUICommand.IconSource>
                <XamlUICommand.KeyboardAccelerators>
                    <KeyboardAccelerator Key="B" Modifiers="Control" />
                </XamlUICommand.KeyboardAccelerators>
            </XamlUICommand>
            <XamlUICommand x:Name="ItalicCommand" Label="Italic">
                <XamlUICommand.IconSource>
                    <SymbolIconSource Symbol="Italic" />
                </XamlUICommand.IconSource>
                <XamlUICommand.KeyboardAccelerators>
                    <KeyboardAccelerator Key="I" Modifiers="Control" />
                </XamlUICommand.KeyboardAccelerators>
            </XamlUICommand>
        </CommandingContainer.Resources>
        <StackPanel Orientation="Horizontal">
            <AppBarToggleButton x:Name="BoldButton" Command="{StaticResource BoldCommand}" />
            <AppBarToggleButton x:Name="ItalicButton" Command="{StaticResource ItalicCommand}" />
        </StackPanel>
    </CommandingContainer>
    <StackPanel x:Name="CommandingClientPanel">
        <RichEditBox x:Name="FirstEditBox" Margin="10" />
        <RichEditBox x:Name="SecondEditBox" Margin="10" />
        <TextBox x:Name="TextBox" Margin="10" />
    </StackPanel>
    <CommandingContainer x:Name="ListViewCommandingContainer">
        <CommandingContainer.Resources>
            <XamlUICommand x:Name="DeleteItemsCommand" Label="Delete">
                <XamlUICommand.IconSource>
                    <SymbolIconSource Symbol="Delete" />
                </XamlUICommand.IconSource>
                <XamlUICommand.KeyboardAccelerators>
                    <KeyboardAccelerator Key="Delete" Modifiers="None" />
                </XamlUICommand.KeyboardAccelerators>
            </XamlUICommand>
        </CommandingContainer.Resources>
        <ListView x:Name="ListView" SelectionMode="Multiple" Width="400" Margin="10">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding}" />
                        <AppBarButton Command="{Binding ElementName=DeleteItemsCommand}" Grid.Column="1" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </CommandingContainer>
</StackPanel>