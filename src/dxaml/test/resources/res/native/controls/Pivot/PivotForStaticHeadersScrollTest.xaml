<Pivot x:Name="pivot" IsHeaderItemsCarouselEnabled="false" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Pivot.Resources>
    <Style TargetType="PivotHeaderItem">
      <Setter Property="Padding"  Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Stretch" />
    </Style>
  </Pivot.Resources>
  <Pivot.HeaderTemplate>
    <DataTemplate>
      <Border BorderBrush="Green" BorderThickness="2" Background="Crimson" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <TextBlock Text="{Binding}" />
      </Border>
    </DataTemplate>
  </Pivot.HeaderTemplate>
  <Pivot.ItemTemplate>
    <DataTemplate>
      <StackPanel Orientation="Horizontal" Background="DarkGray">
        <TextBlock>Content of item </TextBlock>
        <TextBlock Text="{Binding}" Margin="5 0 0 0" />
      </StackPanel>
    </DataTemplate>
  </Pivot.ItemTemplate>
</Pivot>