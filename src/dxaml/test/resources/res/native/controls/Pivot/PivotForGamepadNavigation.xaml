<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Width="400">
    <Grid.RowDefinitions>
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
    </Grid.ColumnDefinitions>
    <Button x:Name="LB" Content="LB" VerticalAlignment="Top" />
    <Pivot x:Name="P" Grid.Column="1">
        <Pivot.LeftHeader>
            <Button x:Name="LHB" Content="LHB" VerticalAlignment="Top" />
        </Pivot.LeftHeader>
        <Pivot.RightHeader>
            <Button x:Name="RHB" Content="RHB" VerticalAlignment="Top" />
        </Pivot.RightHeader>
        <PivotItem Header="1">
            <StackPanel>
                <Button x:Name="CB1" Content="CB1"  Margin="30,0,0,0"/>
                <TextBlock Text="Content" />
                <TextBox x:Name="TB1" />
            </StackPanel>
        </PivotItem>
        <PivotItem Header="2">
            <StackPanel>
                <TextBox x:Name="TB2" />
                <TextBlock Text="Content" />
                <Button x:Name="CB2" Content="CB2" />
            </StackPanel>
        </PivotItem>
        <PivotItem Header="3">
            <StackPanel>
                <TextBox x:Name="TB3" />
                <TextBlock Text="Content" />
                <Button x:Name="CB3" Content="CB3" />
            </StackPanel>
        </PivotItem>
    </Pivot>
    <Button x:Name="RB" Grid.Column="2" Content="RB" VerticalAlignment="Top" />
    <Button x:Name="BB" Grid.ColumnSpan="3" Grid.Row="1" Content="BB" HorizontalAlignment="Stretch" />
</Grid>