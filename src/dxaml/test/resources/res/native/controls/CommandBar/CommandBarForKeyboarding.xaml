<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Page.TopAppBar>
        <CommandBar ClosedDisplayMode="Minimal">
            <AppBarButton Icon="ReShare" Label="Share" Tag="AB1"/>
            <AppBarSeparator/>
            <AppBarToggleButton Icon="Favorite" Label="Favorite" Tag="AB2"/>
            <AppBarButton Icon="Edit" Label="Edit" Tag="AB3"/>
            <CommandBar.SecondaryCommands>
                <AppBarButton Icon="OpenWith" Label="Open with" Tag="SAB1"/>
                <AppBarButton Icon="Pictures" Label="Add to album" Tag="SAB2"/>
                <AppBarSeparator/>
                <AppBarButton Icon="SlideShow" Label="Slideshow" Tag="SAB3"/>
                <AppBarButton Icon="Save" Label="Save As" Tag="SAB4"/>
            </CommandBar.SecondaryCommands>
        </CommandBar>
    </Page.TopAppBar>

    <Page.BottomAppBar>
        <CommandBar ClosedDisplayMode="Compact">
            <AppBarButton Icon="ReShare" Label="Share" Tag="AB4"/>
            <AppBarSeparator/>
            <AppBarToggleButton Icon="Favorite" Label="Favorite" Tag="AB5"/>
            <AppBarButton Icon="Edit" Label="Edit" Tag="AB6"/>
            <CommandBar.SecondaryCommands>
                <AppBarButton Icon="OpenWith" Label="Open with" Tag="SAB5"/>
                <AppBarButton Icon="Pictures" Label="Add to album" Tag="SAB6"/>
                <AppBarSeparator/>
                <AppBarButton Icon="SlideShow" Label="Slideshow" Tag="SAB7"/>
                <AppBarButton Icon="Save" Label="Save As" Tag="SAB8"/>
            </CommandBar.SecondaryCommands>
        </CommandBar>
    </Page.BottomAppBar>

    <Grid>
        <Button x:Name="ExternalButton" Tag="B" Content="Button outside CommandBar" VerticalAlignment="Center" />
    </Grid>
</Page>