<Grid
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

<Grid x:Name="rootGrid">
    <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="500"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0">
            <Button Content="Back" Height="75" Width="100" x:Name="btn0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="10">
            <TextBlock FontSize="30" Text="Place Holder String 1" VerticalAlignment="Center"/>
            <TextBlock FontSize="30" Text="Place Holder String 2" VerticalAlignment="Center"/>
        </StackPanel>
        <StackPanel Grid.Row="2">
            <Button Width="100" Height="75" Content="Focus me" VerticalAlignment="Center" x:Name="btn1"/>
        </StackPanel>
</Grid>

</Grid>