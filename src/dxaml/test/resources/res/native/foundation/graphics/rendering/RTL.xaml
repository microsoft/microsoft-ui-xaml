<Canvas xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

<StackPanel Width="400" FlowDirection="RightToLeft">
    <StackPanel>
        <!-- Right aligned, forwards -->
        <TextBlock Text="asdf" HorizontalAlignment="Left" />
        <!-- Right aligned, forwards -->
        <Image Source="ms-appx:///resources/native/foundation/graphics/Rendering/ASDF.png" Width="150" Height="50" HorizontalAlignment="Left" />
    </StackPanel>
</StackPanel>

<StackPanel Width="400">
    <StackPanel FlowDirection="RightToLeft">
        <!-- Right aligned, forwards -->
        <TextBlock Text="asdf" HorizontalAlignment="Left" />
        <!-- Right aligned, forwards -->
        <Image Source="ms-appx:///resources/native/foundation/graphics/Rendering/ASDF.png" Width="150" Height="50" HorizontalAlignment="Left" />
    </StackPanel>
</StackPanel>

<StackPanel Width="400">
    <StackPanel>
        <!-- Left aligned, forwards -->
        <TextBlock Text="asdf" HorizontalAlignment="Left" FlowDirection="RightToLeft" />
        <!-- Left aligned, backwards -->
        <Image Source="ms-appx:///resources/native/foundation/graphics/Rendering/ASDF.png" Width="150" Height="50" HorizontalAlignment="Left" FlowDirection="RightToLeft" />
    </StackPanel>
</StackPanel>

<Canvas Width="400" x:Name="changeToRtl1">
    <Canvas CompositeMode="SourceOver" FlowDirection="RightToLeft"> <!-- RTL + comp node + no layout -->
        <TextBlock Text="asdf" HorizontalAlignment="Left"/>
    </Canvas>
</Canvas>

</Canvas>
