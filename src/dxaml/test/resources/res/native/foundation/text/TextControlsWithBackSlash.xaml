<StackPanel xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Margin="20" Orientation="Horizontal">
            <StackPanel>
                <TextBlock Text="A\B\C" FontFamily="XamlAutoFontFamily" TextTrimming="Clip" FontSize="50" HorizontalAlignment="Center"/>
                <TextBlock Text="A\B\C" FontFamily="XamlAutoFontFamily" FontSize="50" HorizontalAlignment="Center"/>
                <TextBlock Text="A\B\C" FontFamily="Segoe UI" FontSize="50"  HorizontalAlignment="Center"/>
                <TextBlock Text="A\B\C" FontFamily="Segoe UI" TextTrimming="Clip" FontSize="50"  HorizontalAlignment="Center"/>
            </StackPanel>
            <UserControl FontFamily="Segoe UI">
                <StackPanel>
                    <TextBlock Text="A\B\C" FontFamily="XamlAutoFontFamily" TextTrimming="Clip"  FontSize="50" HorizontalAlignment="Center"/>
                    <TextBlock Text="A\B\C" FontFamily="XamlAutoFontFamily" FontSize="50" HorizontalAlignment="Center"/>
                    <TextBlock Text="A\B\C" FontFamily="Segoe UI" FontSize="50"  HorizontalAlignment="Center"/>
                    <TextBlock Text="A\B\C" FontFamily="Segoe UI" TextTrimming="Clip"  FontSize="50"  HorizontalAlignment="Center"/>
                </StackPanel>
            </UserControl>
            <StackPanel>
                <TextBox Text="A\B\C" FontFamily="XamlAutoFontFamily" FontSize="50" HorizontalAlignment="Center"/>
                <TextBox Text="A\B\C" FontSize="50" FontFamily="Segoe UI" HorizontalAlignment="Center"/>
            </StackPanel>
            <UserControl FontFamily="Segoe UI">
                <StackPanel>
                    <TextBox Text="A\B\C" FontFamily="XamlAutoFontFamily" FontSize="50" HorizontalAlignment="Center"/>
                    <TextBox Text="A\B\C" FontSize="50" FontFamily="Segoe UI" HorizontalAlignment="Center"/>
                </StackPanel>
            </UserControl>
</StackPanel>