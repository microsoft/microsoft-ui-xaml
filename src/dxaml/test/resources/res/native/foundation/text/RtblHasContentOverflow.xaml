<StackPanel Background="White" Width="480" Height="700" 
  xmlns='http://schemas.microsoft.com/winfx/2006/xaml/presentation'
  xmlns:x='http://schemas.microsoft.com/winfx/2006/xaml'>
  
  <!-- basic 1 line tests --> 
  <RichTextBlock Name="rtb1" FontSize="11" Foreground="Black" MaxLines="1" MaxWidth="100" Padding="5" TextWrapping="NoWrap">
    <Paragraph>rtb1 : This paragraph has MaxLines = 1 and NoWrap. HasOverflowContent should be false. </Paragraph>
  </RichTextBlock>

  <RichTextBlock Name="rtb2" FontSize="11" Foreground="Black" MaxLines="1" MaxWidth="100" Padding="5">
    <Paragraph>rtb2 : This paragraph has MaxLines = 1 and Wrap. HasOverflowContent should be true. </Paragraph>
  </RichTextBlock>
  
  <RichTextBlock Name="rtb3" FontSize="11" Foreground="Black" MaxHeight="10" MaxWidth="100" Padding="5" TextWrapping="NoWrap">
    <Paragraph>rtb3 : This paragraph has MaxHeight=10 and NoWrap. HasOverflowContent should be false. </Paragraph>
  </RichTextBlock>
  
  <RichTextBlock Name="rtb4" FontSize="11" Foreground="Black" MaxHeight="10" MaxWidth="100" Padding="5" TextWrapping="Wrap">
    <Paragraph>rtb4 : This paragraph has MaxHeight=10 and Wrap. HasOverflowContent should be true. </Paragraph>
  </RichTextBlock>

  <!-- multi line test -->
  <RichTextBlock Name="rtb5" FontSize="11" Foreground="Black" MaxLines="3" MaxWidth="100" Padding="5" TextWrapping="NoWrap">
    <Paragraph>
      rtb5 : This paragraph has MaxLines=3 and NoWrap.<LineBreak/>
      HasOverflowContent should be false.<LineBreak/>
      Generic text here, lorem ipsum, etc.
    </Paragraph>
  </RichTextBlock>

  <RichTextBlock Name="rtb6" FontSize="11" Foreground="Black" MaxHeight="60" MaxWidth="100" Padding="5" TextWrapping="NoWrap">
    <Paragraph>
      rtb6 : This paragraph has MaxHeight=60 and NoWrap.<LineBreak/>
      HasOverflowContent should be false.<LineBreak/>
      Generic text here, lorem ipsum, etc.
    </Paragraph>
  </RichTextBlock>

  <!-- MultiParagraph tests  -->
  <RichTextBlock Name="rtb7" FontSize="11" Foreground="Black" MaxLines="3" Padding="5" TextWrapping="NoWrap">
    <Paragraph>
        rtb7 : Lorem ipsum dolor sit amet, consectetur adipisicing elit,<LineBreak/>
        sed do eiusmod tempor incididunt ut labore et dolore magna<LineBreak/>
        aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco
    </Paragraph>
    <Paragraph>
        rtb7 2nd paragraph: Excepteur sint occaecat cupidatat non proident,
    </Paragraph>
  </RichTextBlock>

  <RichTextBlock Name="rtb8" FontSize="11" Foreground="Black" MaxHeight="60" Padding="5" TextWrapping="NoWrap">
    <Paragraph>
      rtb8 : Lorem ipsum dolor sit amet, consectetur adipisicing elit,<LineBreak/>
      sed do eiusmod tempor incididunt ut labore et dolore magna<LineBreak/>
      aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco
    </Paragraph>
    <Paragraph>
      rtb8 2nd paragraph: sunt in culpa qui officia deserunt mollit anim id est laborum.
    </Paragraph>
  </RichTextBlock>
  
  <!-- RichTextBlockOverflow test -->
  <RichTextBlock Name="rtb9" FontSize="11" Foreground="Black" MaxLines="2" Padding="5" OverflowContentTarget="{Binding ElementName=rtblo1}">
    <Paragraph>
        rtb9 : Lorem ipsum dolor sit amet, consectetur adipisicing elit,<LineBreak/>
        sed do eiusmod tempor incididunt ut labore et dolore magna<LineBreak/>
        rtbo1 : aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco
    </Paragraph>
  </RichTextBlock>

  <RichTextBlockOverflow Name="rtblo1" MaxWidth="80"/>

  <RichTextBlock Name="rtb10" FontSize="11" Foreground="Black" MaxHeight="60" Padding="5" OverflowContentTarget="{Binding ElementName=rtblo2}">
    <Paragraph>
      rtb10 : Lorem ipsum dolor sit amet, consectetur adipisicing elit,<LineBreak/>
      sed do eiusmod tempor incididunt ut labore et dolore magna<LineBreak/>
      aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco<LineBreak/>
      rtblo2: this text should appear in rtblo2, because thats why its there.
    </Paragraph>
  </RichTextBlock>

  <RichTextBlockOverflow Name="rtblo2"/>
  
  <!-- RichTextBlockOverflow with multiple paragraphs test -->
  <RichTextBlock Name="rtb11" FontSize="11" Foreground="Black" MaxLines="3" Padding="5" OverflowContentTarget="{Binding ElementName=rtblo3}">
    <Paragraph>
      rtb11 : Lorem ipsum dolor sit amet, consectetur adipisicing elit,<LineBreak/>
      sed do eiusmod tempor incididunt ut labore et dolore magna<LineBreak/>
      aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco
    </Paragraph>
    <Paragraph>
      rtblo3: hola!
    </Paragraph>
  </RichTextBlock>

  <RichTextBlockOverflow Name="rtblo3" MaxWidth="80" MaxLines="1"/>

  <RichTextBlock Name="rtb12" FontSize="11" Foreground="Black" MaxHeight="60" Padding="5" OverflowContentTarget="{Binding ElementName=rtblo4}">
    <Paragraph>
      rtb12 : Lorem ipsum dolor sit amet, consectetur adipisicing elit,<LineBreak/>
      sed do eiusmod tempor incididunt ut labore et dolore magna<LineBreak/>
      Who actually reads the text in a test like this? You do, yes? :D
    </Paragraph>
    <Paragraph>
      rtblo4: aliqua. Ut enim ad minim veniam
    </Paragraph>
  </RichTextBlock>

  <RichTextBlockOverflow Name="rtblo4" MaxLines="1"/>

  <RichTextBlock Name="rtb13" FontSize="11" Foreground="Black" MaxHeight="60" Padding="5" OverflowContentTarget="{Binding ElementName=rtblo5}">
    <Paragraph>
      rtb13 : Lorem ipsum dolor sit amet, consectetur adipisicing elit,<LineBreak/>
      sed do eiusmod tempor incididunt ut labore et dolore magna<LineBreak/>
      Who actually reads the text in a test like this? You do, yes? :D
    </Paragraph>
    <Paragraph>
      rtblo5: aliqua. Ut enim ad minim veniam<LineBreak/>
      Pusheen for president!
    </Paragraph>
  </RichTextBlock>

  <RichTextBlockOverflow Name="rtblo5" MaxLines="1"/>
</StackPanel>

