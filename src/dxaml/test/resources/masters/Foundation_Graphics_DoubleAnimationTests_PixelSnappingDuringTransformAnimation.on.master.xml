<?xml version="1.0" encoding="UTF-8"?>
<CompositionTarget>
  <Visual>
    <Visual />
    <Visual />
    <Visual Tag="PrependVisual">
      <Visual Tag="PrimaryVisual" SizeX="400" SizeY="300">
        <Visual Tag="ContentVisual">
          <Visual Tag="PrependVisual" SizeX="400" SizeY="300">
            <Clip ClipLeft="0" ClipTop="0" ClipRight="0" ClipBottom="0" TransformMatrix="Identity" />
            <Visual PixelSnappingEnabled="True" Tag="PrimaryVisual" SizeX="400" SizeY="300">
              <TransformMatrix>
                <ExpressionAnimation String="Matrix4x4.CreateFromTranslation(V.Offset) * LOCAL.DManip * Matrix4x4.CreateFromTranslation(-V.Offset)">
                  <ReferenceParameter Name="LOCAL">
                    <PropertySet>
                      <Property Name="DManip" Type="Matrix4x4">
                        <ExpressionAnimation String="PS.Matrix">
                          <ReferenceParameter Name="PS">
                            <PropertySet>
                              <Property Name="Matrix" Type="Matrix4x4">
                                <ExpressionAnimation String="transform*manipTransform.Matrix">
                                  <ReferenceParameter Name="manipTransform">
                                    <DuplicatedMatrixTransform>
                                      <ManipulationTransform Transform="Identity" />
                                    </DuplicatedMatrixTransform>
                                  </ReferenceParameter>
                                  <Property Name="transform" Type="Matrix4x4" />
                                </ExpressionAnimation>
                              </Property>
                            </PropertySet>
                          </ReferenceParameter>
                        </ExpressionAnimation>
                      </Property>
                    </PropertySet>
                  </ReferenceParameter>
                  <ReferenceParameter Name="V" />
                </ExpressionAnimation>
              </TransformMatrix>
              <Visual Tag="ContentVisual">
                <wucSpriteVisual SizeX="400" SizeY="300" BorderMode="Soft">
                  <ColorBrush Color="Argb {0, 1, 1, 1}" />
                </wucSpriteVisual>
                <wucSpriteVisual SizeX="400" SizeY="300" BorderMode="Soft">
                  <ColorBrush Color="Argb {0, 1, 1, 1}" />
                </wucSpriteVisual>
                <Visual Tag="PrependVisual" SizeX="10" SizeY="10">
                  <Clip ClipLeft="0" ClipTop="0" ClipRight="-390" ClipBottom="-290" TransformMatrix="Identity" />
                  <Visual PixelSnappingEnabled="True" HasInteraction="True" Tag="PrimaryVisual" SizeX="10" SizeY="10">
                    <TransformMatrix>
                      <ExpressionAnimation String="Matrix4x4(LOCAL.Render) * Matrix4x4.CreateFromTranslation(V.Offset) * LOCAL.DManip * Matrix4x4.CreateFromTranslation(-V.Offset)">
                        <ReferenceParameter Name="LOCAL">
                          <PropertySet>
                            <Property Name="DManip" Type="Matrix4x4">
                              <ExpressionAnimation String="PS.Matrix">
                                <ReferenceParameter Name="PS">
                                  <PropertySet>
                                    <Property Name="Matrix" Type="Matrix4x4">
                                      <ExpressionAnimation String="transform*manipTransform.Matrix">
                                        <ReferenceParameter Name="manipTransform">
                                          <DuplicatedMatrixTransform>
                                            <ManipulationTransform Translation="dxdydz {195, 145, 0}" />
                                          </DuplicatedMatrixTransform>
                                        </ReferenceParameter>
                                        <Property Name="transform" Type="Matrix4x4" />
                                      </ExpressionAnimation>
                                    </Property>
                                  </PropertySet>
                                </ReferenceParameter>
                              </ExpressionAnimation>
                            </Property>
                            <Property Name="Render" Type="Matrix3x2">
                              <ExpressionAnimation String="Matrix3x2.CreateFromTranslation(vector2(PS.X, PS.Y))">
                                <ReferenceParameter Name="PS" />
                                <PropertySet>
                                  <Property Name="X" Type="Scalar" />
                                  <Property Name="Y" Type="Scalar" />
                                </PropertySet>
                              </ExpressionAnimation>
                            </Property>
                          </PropertySet>
                        </ReferenceParameter>
                        <ReferenceParameter Name="V" />
                      </ExpressionAnimation>
                    </TransformMatrix>
                    <Visual Tag="ContentVisual">
                      <wucSpriteVisual SizeX="10" SizeY="10" BorderMode="Soft">
                        <ColorBrush Color="rgb {1, 0, 0}" />
                      </wucSpriteVisual>
                    </Visual>
                  </Visual>
                </Visual>
              </Visual>
            </Visual>
          </Visual>
        </Visual>
      </Visual>
    </Visual>
  </Visual>
</CompositionTarget>