<?xml version="1.0" encoding="UTF-8"?>
<CompositionTarget>
  <Visual>
    <Visual />
    <Visual />
    <Visual Tag="PrependVisual">
      <Visual Tag="PrimaryVisual" SizeX="400" SizeY="400">
        <Visual Tag="ContentVisual">
          <wucSpriteVisual SizeX="200" SizeY="200" BorderMode="Soft" OffsetX="20" OffsetY="20" OffsetZ="0">
            <ColorBrush Color="Argb {0, 1, 1, 1}" />
          </wucSpriteVisual>
          <Visual Tag="PrependVisual" SizeX="2000" SizeY="2000">
            <Clip ClipLeft="0" ClipTop="0" ClipRight="1800" ClipBottom="1800" TransformMatrix="Identity" />
            <TransformMatrix>
              <Translate X="20" Y="20" />
            </TransformMatrix>
            <Visual PixelSnappingEnabled="True" HasInteraction="True" Tag="PrimaryVisual" SizeX="2000" SizeY="2000">
              <TransformMatrix>
                <ExpressionAnimation String="Matrix4x4.CreateFromTranslation(V.Offset) * LOCAL.DManip * Matrix4x4.CreateFromTranslation(-V.Offset)">
                  <ReferenceParameter Name="LOCAL">
                    <PropertySet>
                      <Property Name="DManip" Type="Matrix4x4">
                        <ExpressionAnimation String="PS.Matrix">
                          <ReferenceParameter Name="PS">
                            <PropertySet>
                              <Property Name="Matrix" Type="Matrix4x4">
                                <ExpressionAnimation String="transform*manipTransform.Matrix">
                                  <ReferenceParameter Name="manipTransform">
                                    <DuplicatedMatrixTransform>
                                      <ManipulationTransform Translation="dxdydz {-1800, -1800, 0}" />
                                    </DuplicatedMatrixTransform>
                                  </ReferenceParameter>
                                  <Property Name="transform" Type="Matrix4x4" />
                                </ExpressionAnimation>
                              </Property>
                            </PropertySet>
                          </ReferenceParameter>
                        </ExpressionAnimation>
                      </Property>
                    </PropertySet>
                  </ReferenceParameter>
                  <ReferenceParameter Name="V" />
                </ExpressionAnimation>
              </TransformMatrix>
              <Visual Tag="ContentVisual">
                <wucSpriteVisual SizeX="2000" SizeY="2000" BorderMode="Soft">
                  <SurfaceBrush Stretch="Fill" Transform="Identity" Surface="1" />
                </wucSpriteVisual>
              </Visual>
            </Visual>
          </Visual>
        </Visual>
      </Visual>
    </Visual>
  </Visual>
</CompositionTarget>