<?xml version="1.0" encoding="UTF-8"?>
<CompositionTarget>
  <Visual>
    <Visual />
    <Visual />
    <Visual Tag="PrependVisual">
      <Visual Tag="PrimaryVisual" SizeX="400" SizeY="300">
        <Visual Tag="ContentVisual">
          <Visual Tag="PrependVisual" SizeX="400" SizeY="300">
            <Clip ClipLeft="0" ClipTop="0" ClipRight="0" ClipBottom="0" TransformMatrix="Identity" />
            <Visual PixelSnappingEnabled="True" Tag="PrimaryVisual" SizeX="400" SizeY="300">
              <TransformMatrix>
                <ExpressionAnimation String="Matrix4x4.CreateFromTranslation(V.Offset) * LOCAL.DManip * Matrix4x4.CreateFromTranslation(-V.Offset)">
                  <ReferenceParameter Name="LOCAL">
                    <PropertySet>
                      <Property Name="DManip" Type="Matrix4x4">
                        <ExpressionAnimation String="PS.Matrix">
                          <ReferenceParameter Name="PS">
                            <PropertySet>
                              <Property Name="Matrix" Type="Matrix4x4">
                                <ExpressionAnimation String="transform*manipTransform.Matrix">
                                  <ReferenceParameter Name="manipTransform">
                                    <DuplicatedMatrixTransform>
                                      <ManipulationTransform Transform="Identity" />
                                    </DuplicatedMatrixTransform>
                                  </ReferenceParameter>
                                  <Property Name="transform" Type="Matrix4x4" />
                                </ExpressionAnimation>
                              </Property>
                            </PropertySet>
                          </ReferenceParameter>
                        </ExpressionAnimation>
                      </Property>
                    </PropertySet>
                  </ReferenceParameter>
                  <ReferenceParameter Name="V" />
                </ExpressionAnimation>
              </TransformMatrix>
              <Visual Tag="ContentVisual">
                <wucSpriteVisual SizeX="400" SizeY="300" BorderMode="Soft">
                  <ColorBrush Color="Argb {0, 1, 1, 1}" />
                </wucSpriteVisual>
                <wucShapeVisual SizeX="50" SizeY="50" OffsetX="175" OffsetY="0" OffsetZ="0">
                  <wucSpriteShape StrokeThickness="5">
                    <FillBrush>
                      <ColorBrush Color="rgb {0, 0.502, 0}" />
                    </FillBrush>
                    <StrokeBrush>
                      <ColorBrush Color="rgb {1, 0, 0}" />
                    </StrokeBrush>
                    <CompositionEllipseGeometry CenterX="25" CenterY="25" RadiusX="22.5" RadiusY="22.5" />
                  </wucSpriteShape>
                </wucShapeVisual>
              </Visual>
            </Visual>
          </Visual>
        </Visual>
      </Visual>
    </Visual>
  </Visual>
</CompositionTarget>