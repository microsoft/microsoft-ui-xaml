<?xml version="1.0" encoding="UTF-8"?>
<CompositionTarget>
  <Visual>
    <Visual />
    <Visual />
    <Visual Tag="PrependVisual">
      <Visual Tag="PrimaryVisual" SizeX="800" SizeY="600">
        <Visual Tag="ContentVisual">
          <Visual Tag="PrependVisual" SizeX="800" SizeY="600">
            <Clip ClipLeft="0" ClipTop="0" ClipRight="0" ClipBottom="0" TransformMatrix="Identity" />
            <Visual PixelSnappingEnabled="True" Tag="PrimaryVisual" SizeX="800" SizeY="600">
              <TransformMatrix>
                <ExpressionAnimation String="Matrix4x4.CreateFromTranslation(V.Offset) * LOCAL.DManip * Matrix4x4.CreateFromTranslation(-V.Offset)">
                  <ReferenceParameter Name="LOCAL">
                    <PropertySet>
                      <Property Name="DManip" Type="Matrix4x4">
                        <ExpressionAnimation String="PS.Matrix">
                          <ReferenceParameter Name="PS">
                            <PropertySet>
                              <Property Name="Matrix" Type="Matrix4x4">
                                <ExpressionAnimation String="transform*manipTransform.Matrix">
                                  <ReferenceParameter Name="manipTransform">
                                    <DuplicatedMatrixTransform>
                                      <ManipulationTransform Transform="Identity" />
                                    </DuplicatedMatrixTransform>
                                  </ReferenceParameter>
                                  <Property Name="transform" Type="Matrix4x4" />
                                </ExpressionAnimation>
                              </Property>
                            </PropertySet>
                          </ReferenceParameter>
                        </ExpressionAnimation>
                      </Property>
                    </PropertySet>
                  </ReferenceParameter>
                  <ReferenceParameter Name="V" />
                </ExpressionAnimation>
              </TransformMatrix>
              <Visual Tag="ContentVisual">
                <wucSpriteVisual SizeX="800" SizeY="600" BorderMode="Soft">
                  <ColorBrush Color="Argb {0, 1, 1, 1}" />
                </wucSpriteVisual>
                <wucSpriteVisual SizeX="800" SizeY="350" BorderMode="Soft">
                  <ColorBrush Color="Argb {0, 1, 1, 1}" />
                </wucSpriteVisual>
                <Visual Tag="PrependVisual" SizeX="350" SizeY="350">
                  <Clip ClipLeft="0" ClipTop="0" ClipRight="-450" ClipBottom="0" TransformMatrix="Identity" />
                  <Visual PixelSnappingEnabled="True" HasInteraction="True" Tag="PrimaryVisual" SizeX="350" SizeY="350">
                    <TransformMatrix>
                      <ExpressionAnimation String="Matrix4x4.CreateFromTranslation(V.Offset) * LOCAL.DManip * Matrix4x4.CreateFromTranslation(-V.Offset)">
                        <ReferenceParameter Name="LOCAL">
                          <PropertySet>
                            <Property Name="DManip" Type="Matrix4x4">
                              <ExpressionAnimation String="PS.Matrix">
                                <ReferenceParameter Name="PS">
                                  <PropertySet>
                                    <Property Name="Matrix" Type="Matrix4x4">
                                      <ExpressionAnimation String="transform*manipTransform.Matrix">
                                        <ReferenceParameter Name="manipTransform">
                                          <DuplicatedMatrixTransform>
                                            <ManipulationTransform Translation="dxdydz {225, 0, 0}" />
                                          </DuplicatedMatrixTransform>
                                        </ReferenceParameter>
                                        <Property Name="transform" Type="Matrix4x4" />
                                      </ExpressionAnimation>
                                    </Property>
                                  </PropertySet>
                                </ReferenceParameter>
                              </ExpressionAnimation>
                            </Property>
                          </PropertySet>
                        </ReferenceParameter>
                        <ReferenceParameter Name="V" />
                      </ExpressionAnimation>
                    </TransformMatrix>
                    <Visual Tag="ContentVisual">
                      <Visual Tag="PrependVisual">
                        <Visual Tag="PrimaryVisual" SizeX="50" SizeY="50" OffsetX="10" OffsetY="10" OffsetZ="0">
                          <TransformMatrix>
                            <ExpressionAnimation String="Matrix4x4(LOCAL.Render)">
                              <ReferenceParameter Name="LOCAL">
                                <PropertySet>
                                  <Property Name="Render" Type="Matrix3x2">
                                    <ExpressionAnimation String="Matrix3x2.CreateFromTranslation(vector2(PS.X, PS.Y))">
                                      <ReferenceParameter Name="PS" />
                                      <PropertySet>
                                        <Property Name="X" Type="Scalar">
                                          <KeyFrameAnimation Duration="100">
                                            <KeyFrame Value="10" />
                                            <KeyFrame Time="1" Value="11">
                                              <LinearEasingFunction />
                                            </KeyFrame>
                                          </KeyFrameAnimation>
                                        </Property>
                                        <Property Name="Y" Type="Scalar" />
                                      </PropertySet>
                                    </ExpressionAnimation>
                                  </Property>
                                </PropertySet>
                              </ReferenceParameter>
                            </ExpressionAnimation>
                          </TransformMatrix>
                          <Visual Tag="ContentVisual">
                            <wucSpriteVisual SizeX="50" SizeY="50" BorderMode="Soft">
                              <ColorBrush Color="rgb {0, 0, 0.502}" />
