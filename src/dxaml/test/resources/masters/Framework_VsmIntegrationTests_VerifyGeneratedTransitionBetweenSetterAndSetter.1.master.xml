<?xml version="1.0" encoding="UTF-8"?>
<CompositionTarget>
  <Visual>
    <Visual />
    <Visual />
    <Visual Tag="PrependVisual">
      <Visual Tag="PrimaryVisual" SizeX="400" SizeY="400">
        <Visual Tag="ContentVisual">
          <Visual Tag="PrependVisual" SizeX="400" SizeY="400">
            <Clip ClipLeft="0" ClipTop="0" ClipRight="0" ClipBottom="0" TransformMatrix="Identity" />
            <Visual PixelSnappingEnabled="True" Tag="PrimaryVisual" SizeX="400" SizeY="400">
              <TransformMatrix>
                <ExpressionAnimation String="Matrix4x4.CreateFromTranslation(V.Offset) * LOCAL.DManip * Matrix4x4.CreateFromTranslation(-V.Offset)">
                  <ReferenceParameter Name="LOCAL">
                    <PropertySet>
                      <Property Name="DManip" Type="Matrix4x4">
                        <ExpressionAnimation String="PS.Matrix">
                          <ReferenceParameter Name="PS">
                            <PropertySet>
                              <Property Name="Matrix" Type="Matrix4x4">
                                <ExpressionAnimation String="transform*manipTransform.Matrix">
                                  <ReferenceParameter Name="manipTransform">
                                    <DuplicatedMatrixTransform>
                                      <ManipulationTransform Transform="Identity" />
                                    </DuplicatedMatrixTransform>
                                  </ReferenceParameter>
                                  <Property Name="transform" Type="Matrix4x4" />
                                </ExpressionAnimation>
                              </Property>
                            </PropertySet>
                          </ReferenceParameter>
                        </ExpressionAnimation>
                      </Property>
                    </PropertySet>
                  </ReferenceParameter>
                  <ReferenceParameter Name="V" />
                </ExpressionAnimation>
              </TransformMatrix>
              <Visual Tag="ContentVisual">
                <wucSpriteVisual SizeX="400" SizeY="400" BorderMode="Soft">
                  <ColorBrush Color="Argb {0, 1, 1, 1}" />
                </wucSpriteVisual>
                <Visual Tag="PrependVisual">
                  <Visual Tag="PrimaryVisual" SizeX="400" SizeY="200">
                    <TransformMatrix>
                      <ExpressionAnimation String="Matrix4x4(LOCAL.Render)">
                        <ReferenceParameter Name="LOCAL">
                          <PropertySet>
                            <Property Name="Render" Type="Matrix3x2">
                              <ExpressionAnimation String="Matrix3x2.CreateFromTranslation(vector2(PS.X, PS.Y))">
                                <ReferenceParameter Name="PS" />
                                <PropertySet>
                                  <Property Name="X" Type="Scalar" />
                                  <Property Name="Y" Type="Scalar">
                                    <KeyFrameAnimation Duration="0.5">
                                      <KeyFrame Value="10" />
                                      <KeyFrame Time="1" Value="20">
                                        <LinearEasingFunction />
                                      </KeyFrame>
                                    </KeyFrameAnimation>
                                  </Property>
                                </PropertySet>
                              </ExpressionAnimation>
                            </Property>
                          </PropertySet>
                        </ReferenceParameter>
                      </ExpressionAnimation>
                    </TransformMatrix>
                    <Visual Tag="ContentVisual">
                      <wucSpriteVisual SizeX="400" SizeY="200" BorderMode="Soft">
                        <ColorBrush Color="Argb {0, 1, 1, 1}" />
                      </wucSpriteVisual>
                      <wucSpriteVisual SizeX="200" SizeY="200" BorderMode="Soft">
                        <Color>
                          <KeyFrameAnimation Duration="1">
                            <KeyFrame Color="rgb {0, 1, 0}" />
                            <KeyFrame Time="1" Color="rgb {0, 0, 1}">
                              <LinearEasingFunction />
                            </KeyFrame>
                          </KeyFrameAnimation>
                        </Color>
                      </wucSpriteVisual>
                      <Visual Tag="PrependVisual">
                        <Visual Tag="PrimaryVisual" SizeX="200" SizeY="200" OffsetX="200" OffsetY="0" OffsetZ="0">
                          <Opacity>
                            <ExpressionAnimation String="PS.Opacity">
                              <ReferenceParameter Name="PS" />
                              <PropertySet>
                                <Property Name="Opacity" Type="Scalar">
                                  <KeyFrameAnimation Duration="1">
                                    <KeyFrame Value="0.67" />
                                    <KeyFrame Time="1" Value="0.33">
                                      <LinearEasingFunction />
                                    </KeyFrame>
                                  </KeyFrameAnimation>
                                </Property>
                              </PropertySet>
                            </ExpressionAnimation>
                          </Opacity>
                          <Visual Tag="ContentVisual">
                            <wucSpriteVisual SizeX="200" SizeY="200" BorderMode="Soft">
                              <ColorBrush Color="#ffffffff" />
                            </wucSpriteVisual>
                          </Visual>
                        </Visual>
                      </Visual>
                    </Visual>
                  </Visual>
                </Visual>
              </Visual>
            </Visual>
          </Visual>
        </Visual>
      </Visual>
    </Visual>
  </Visual>
</CompositionTarget>