<?xml version="1.0" encoding="UTF-8"?>
<CompositionTarget>
  <Visual>
    <Visual />
    <Visual />
    <Visual Tag="PrependVisual">
      <Visual Tag="PrimaryVisual" SizeX="100" SizeY="100">
        <Visual Tag="ContentVisual">
          <wucSpriteVisual SizeX="100" SizeY="100" BorderMode="Soft">
            <ColorBrush Color="#ff000000" />
          </wucSpriteVisual>
        </Visual>
        <Visual Tag="PrependVisual" SizeX="100" SizeY="100">
          <Clip ClipLeft="0" ClipTop="0" ClipRight="0" ClipBottom="0" TransformMatrix="Identity" />
          <Visual PixelSnappingEnabled="True" Tag="PrimaryVisual" SizeX="100" SizeY="100">
            <TransformMatrix>
              <ExpressionAnimation String="Matrix4x4.CreateFromTranslation(V.Offset) * LOCAL.DManip * Matrix4x4.CreateFromTranslation(-V.Offset)">
                <ReferenceParameter Name="LOCAL">
                  <PropertySet>
                    <Property Name="DManip" Type="Matrix4x4">
                      <ExpressionAnimation String="PS.Matrix">
                        <ReferenceParameter Name="PS">
                          <PropertySet>
                            <Property Name="Matrix" Type="Matrix4x4">
                              <ExpressionAnimation String="transform*manipTransform.Matrix">
                                <ReferenceParameter Name="manipTransform">
                                  <DuplicatedMatrixTransform>
                                    <ManipulationTransform Transform="Identity" />
                                  </DuplicatedMatrixTransform>
                                </ReferenceParameter>
                                <Property Name="transform" Type="Matrix4x4" />
                              </ExpressionAnimation>
                            </Property>
                          </PropertySet>
                        </ReferenceParameter>
                      </ExpressionAnimation>
                    </Property>
                  </PropertySet>
                </ReferenceParameter>
                <ReferenceParameter Name="V" />
              </ExpressionAnimation>
            </TransformMatrix>
            <Visual Tag="ContentVisual">
              <wucSpriteVisual SizeX="100" SizeY="100" BorderMode="Soft">
                <ColorBrush Color="Argb {0, 1, 1, 1}" />
              </wucSpriteVisual>
              <wucSpriteVisual SizeX="100" SizeY="100" BorderMode="Soft">
                <ColorBrush Color="rgb {1, 0, 0}" />
              </wucSpriteVisual>
              <wucSpriteVisual SizeX="10" SizeY="10" BorderMode="Soft">
                <MaskBrush>
                  <Source>
                    <ColorBrush Color="rgb {1, 1, 0}" />
                  </Source>
                  <Mask>
                    <SurfaceBrush Stretch="Fill" Transform="Identity" />
                  </Mask>
                </MaskBrush>
              </wucSpriteVisual>
              <wucSpriteVisual SizeX="10" SizeY="10" BorderMode="Soft">
                <MaskBrush>
                  <Source>
                    <ColorBrush Color="rgb {0, 0, 1}" />
                  </Source>
                  <Mask>
                    <SurfaceBrush Stretch="Fill" Transform="Identity" />
                  </Mask>
                </MaskBrush>
              </wucSpriteVisual>
              <wucSpriteVisual SizeX="100" SizeY="100" BorderMode="Soft" OffsetX="0" OffsetY="100" OffsetZ="0">
                <Clip ClipLeft="0" ClipTop="-100" ClipRight="0" ClipBottom="100" TransformMatrix="Identity" />
                <SurfaceBrush Stretch="Fill" Transform="Identity" />
              </wucSpriteVisual>
            </Visual>
          </Visual>
        </Visual>
        <Visual Tag="ContentVisual" />
      </Visual>
    </Visual>
  </Visual>
</CompositionTarget>