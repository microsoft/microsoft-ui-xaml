<?xml version="1.0" encoding="UTF-8"?>
<CompositionTarget>
  <Visual>
    <Visual />
    <Visual />
    <Visual Tag="PrependVisual">
      <Visual Tag="PrimaryVisual" SizeX="400" SizeY="300">
        <Visual Tag="ContentVisual">
          <wucSpriteVisual SizeX="100" SizeY="100" BorderMode="Soft">
            <ColorBrush Color="Argb {0, 1, 1, 1}" />
          </wucSpriteVisual>
          <Visual Tag="PrependVisual" SizeX="100" SizeY="100">
            <Clip ClipLeft="0" ClipTop="0" ClipRight="0" ClipBottom="0" TransformMatrix="dxdy {-10, -20}" />
            <TransformMatrix>
              <Translate X="10" Y="20" Z="30" />
            </TransformMatrix>
            <Visual PixelSnappingEnabled="True" HasInteraction="True" Tag="PrimaryVisual" SizeX="100" SizeY="100">
              <TransformMatrix>
                <ExpressionAnimation String="Matrix4x4.CreateFromTranslation(V.Offset) * LOCAL.DManip * Matrix4x4.CreateFromTranslation(-V.Offset)">
                  <ReferenceParameter Name="LOCAL">
                    <PropertySet>
                      <Property Name="DManip" Type="Matrix4x4">
                        <ExpressionAnimation String="PS.Matrix">
                          <ReferenceParameter Name="PS">
                            <PropertySet>
                              <Property Name="Matrix" Type="Matrix4x4">
                                <ExpressionAnimation String="transform*manipTransform.Matrix">
                                  <ReferenceParameter Name="manipTransform">
                                    <DuplicatedMatrixTransform>
                                      <ManipulationTransform Transform="Identity" />
                                    </DuplicatedMatrixTransform>
                                  </ReferenceParameter>
                                  <Property Name="transform" Type="Matrix4x4" />
                                </ExpressionAnimation>
                              </Property>
                            </PropertySet>
                          </ReferenceParameter>
                        </ExpressionAnimation>
                      </Property>
                    </PropertySet>
                  </ReferenceParameter>
                  <ReferenceParameter Name="V" />
                </ExpressionAnimation>
              </TransformMatrix>
              <Visual Tag="ComponentsVisual" SizeX="100" SizeY="100" ScaleX="2" ScaleY="2" ScaleZ="2" RotationAngleInDegrees="45" CenterPointX="50" CenterPointY="50" RotationAxisX="1" RotationAxisY="0" RotationAxisZ="0">
                <Clip ClipLeft="10" ClipTop="20" ClipRight="60" ClipBottom="40" TransformMatrix="Identity" />
                <TransformMatrix>
                  <Scale ScaleX="1.5" ScaleY="1.5" />
                </TransformMatrix>
                <Visual Tag="ContentVisual">
                  <wucSpriteVisual SizeX="100" SizeY="100" BorderMode="Soft">
                    <ColorBrush Color="rgb {0.502, 0, 0.502}" />
                  </wucSpriteVisual>
                </Visual>
              </Visual>
            </Visual>
          </Visual>
        </Visual>
      </Visual>
    </Visual>
  </Visual>
</CompositionTarget>