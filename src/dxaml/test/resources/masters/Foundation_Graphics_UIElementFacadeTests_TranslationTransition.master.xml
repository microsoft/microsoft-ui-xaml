<?xml version="1.0" encoding="UTF-8"?>
<CompositionTarget>
  <Visual>
    <Visual />
    <Visual />
    <Visual Tag="PrependVisual">
      <Visual Tag="PrimaryVisual" SizeX="400" SizeY="300">
        <Visual Tag="ContentVisual">
          <Visual Tag="PrependVisual">
            <TransformMatrix>
              <ExpressionAnimation String="Matrix4x4.CreateFromTranslation(PS.Translation) * prependVisual.PrependTransform">
                <ReferenceParameter Name="PS">
                  <PropertySet>
                    <Property Name="Translation" Type="Vector3">
                      <KeyFrameAnimation Duration="1">
                        <KeyFrame Expression="this.StartingValue" />
                        <KeyFrame Time="1" X="100" Y="200" Z="300">
                          <CubicBezierEasingFunction Offset1X="0.8" Offset1Y="0" Offset2X="0.2" Offset2Y="1" />
                        </KeyFrame>
                      </KeyFrameAnimation>
                    </Property>
                  </PropertySet>
                </ReferenceParameter>
                <ReferenceParameter Name="prependVisual" />
              </ExpressionAnimation>
            </TransformMatrix>
            <Visual Tag="PrimaryVisual" SizeX="100" SizeY="100">
              <Visual Tag="ContentVisual">
                <wucSpriteVisual SizeX="100" SizeY="100" BorderMode="Soft">
                  <ColorBrush Color="rgb {1, 0, 0}" />
                </wucSpriteVisual>
              </Visual>
            </Visual>
          </Visual>
        </Visual>
      </Visual>
    </Visual>
  </Visual>
</CompositionTarget>