                                  <ReferenceParameter Name="hostVisual" />
                                </ExpressionAnimation>
                              </Offset.x>
                              <Offset.y>
                                <ExpressionAnimation String="hostVisual.Offset.y + colorGlowOffsetYAdjustment">
                                  <ReferenceParameter Name="hostVisual" />
                                </ExpressionAnimation>
                              </Offset.y>
