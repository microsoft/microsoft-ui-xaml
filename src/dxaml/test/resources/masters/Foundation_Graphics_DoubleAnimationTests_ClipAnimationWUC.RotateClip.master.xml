<?xml version="1.0" encoding="UTF-8"?>
<CompositionTarget>
  <Visual>
    <Visual />
    <Visual />
    <Visual Tag="PrependVisual">
      <Visual Tag="PrimaryVisual" SizeX="400" SizeY="300">
        <Visual Tag="ContentVisual">
          <Visual Tag="PrependVisual">
            <Visual Tag="PrimaryVisual" SizeX="100" SizeY="100" OffsetX="0" OffsetY="100" OffsetZ="0">
              <Clip ClipLeft="0" ClipTop="0" ClipRight="90" ClipBottom="90">
                <TransformMatrix>
                  <ExpressionAnimation String="Matrix3x2.CreateFromTranslation(-vector2(PS.CenterX, PS.CenterY)) * PS.Scale * PS.Skew * PS.Rotate * Matrix3x2.CreateFromTranslation(vector2(PS.CenterX, PS.CenterY)) * PS.Translate">
                    <ReferenceParameter Name="PS" />
                    <PropertySet>
                      <Property Name="CenterX" Type="Scalar" Value="10" />
                      <Property Name="CenterY" Type="Scalar" Value="50" />
                      <Property Name="Rotate" Type="Matrix3x2">
                        <ExpressionAnimation String="Matrix3x2(cos(PS.RotateAngle * pi / 180.0f), sin(PS.RotateAngle * pi / 180.0f), -sin(PS.RotateAngle * pi / 180.0f), cos(PS.RotateAngle * pi / 180.0f), 0, 0)">
                          <ReferenceParameter Name="PS" />
                          <PropertySet>
                            <Property Name="RotateAngle" Type="Scalar">
                              <KeyFrameAnimation Duration="1">
                                <KeyFrame />
                                <KeyFrame Time="1" Value="75">
                                  <LinearEasingFunction />
                                </KeyFrame>
                              </KeyFrameAnimation>
                            </Property>
                          </PropertySet>
                        </ExpressionAnimation>
                      </Property>
                      <Property Name="Scale" Type="Matrix3x2" Value="Identity" />
                      <Property Name="Skew" Type="Matrix3x2" Value="Identity" />
                      <Property Name="Translate" Type="Matrix3x2" Value="Identity" />
                    </PropertySet>
                  </ExpressionAnimation>
                </TransformMatrix>
              </Clip>
              <Visual Tag="ContentVisual">
                <wucSpriteVisual SizeX="100" SizeY="100" BorderMode="Soft">
                  <ColorBrush Color="rgb {1, 0, 0}" />
                </wucSpriteVisual>
              </Visual>
            </Visual>
          </Visual>
        </Visual>
      </Visual>
    </Visual>
  </Visual>
</CompositionTarget>