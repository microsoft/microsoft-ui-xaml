<?xml version="1.0" encoding="UTF-8"?>
<CompositionTarget>
  <Visual>
    <Visual />
    <Visual />
    <Visual Tag="PrependVisual">
      <Visual Tag="PrimaryVisual" SizeX="400" SizeY="300">
        <Visual Tag="ContentVisual">
          <Visual Tag="PrependVisual">
            <Visual Tag="PrimaryVisual" SizeX="10" SizeY="10">
              <TransformMatrix>
                <ExpressionAnimation String="Matrix4x4(LOCAL.Render)">
                  <ReferenceParameter Name="LOCAL">
                    <PropertySet>
                      <Property Name="Render" Type="Matrix3x2">
                        <ExpressionAnimation String="Matrix3x2.CreateFromTranslation(vector2(PS.X, PS.Y))">
                          <ReferenceParameter Name="PS" />
                          <PropertySet>
                            <Property Name="X" Type="Scalar">
                              <KeyFrameAnimation Duration="10">
                                <KeyFrame />
                                <KeyFrame Time="0.2" Value="70">
                                  <StepEasingFunction StepCount="1" InitialStep="0" FinalStep="1" IsFinalStepSingleFrame="True" />
                                </KeyFrame>
                                <KeyFrame Time="0.4" Value="140">
                                  <StepEasingFunction StepCount="1" InitialStep="0" FinalStep="1" IsFinalStepSingleFrame="True" />
                                </KeyFrame>
                                <KeyFrame Time="1" Value="350">
                                  <LinearEasingFunction />
                                </KeyFrame>
                              </KeyFrameAnimation>
                            </Property>
                            <Property Name="Y" Type="Scalar" />
                          </PropertySet>
                        </ExpressionAnimation>
                      </Property>
                    </PropertySet>
                  </ReferenceParameter>
                </ExpressionAnimation>
              </TransformMatrix>
              <Visual Tag="ContentVisual">
                <wucSpriteVisual SizeX="10" SizeY="10" BorderMode="Soft">
                  <Color>
                    <KeyFrameAnimation Duration="10">
                      <KeyFrame Color="rgb {1, 1, 0}" />
                      <KeyFrame Time="0.2" Color="rgb {1, 0, 0}">
                        <StepEasingFunction StepCount="1" InitialStep="0" FinalStep="1" IsFinalStepSingleFrame="True" />
                      </KeyFrame>
                      <KeyFrame Time="0.4" Color="rgb {0, 1, 0}">
                        <StepEasingFunction StepCount="1" InitialStep="0" FinalStep="1" IsFinalStepSingleFrame="True" />
                      </KeyFrame>
                      <KeyFrame Time="1" Color="rgb {0, 0, 1}">
                        <LinearEasingFunction />
                      </KeyFrame>
                    </KeyFrameAnimation>
                  </Color>
                </wucSpriteVisual>
              </Visual>
            </Visual>
          </Visual>
        </Visual>
      </Visual>
    </Visual>
  </Visual>
</CompositionTarget>