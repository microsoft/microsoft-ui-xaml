<Project DefaultTargets="Build" ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

    <PropertyGroup Label="Globals">
        <ConfigurationType>DynamicLibrary</ConfigurationType>
        <ProjectGuid>{fa82dbdb-93a1-49ce-930c-301381b43aa6}</ProjectGuid>
    </PropertyGroup>

    <Import Project="$([MSBuild]::GetPathOfFileAbove(Xaml.Cpp.props))"/>
    <Import Project="$(XamlSourcePath)\test\common.props"/>

    <!-- Helps an app with loading Microsoft.UI.Xaml.dll from an alternative location and injecting MockDComp.dll on app loading -->
    <!-- assuming it is all in the same directory along with Mock10.dll                                                        -->
    <PropertyGroup>
        <TestCode>true</TestCode>
        <TargetDestination>$(TestBinplaceDestinationPath)</TargetDestination>
        <Dllentry>_DllMainCRTStartup</Dllentry>
        <ProjectPreprocessorDefinitions>$(ProjectPreprocessorDefinitions) UNICODE;</ProjectPreprocessorDefinitions>
        <ProjectIncludeDirectories>$(ProjectIncludeDirectories); $(ProjectRoot)\dxaml\xcp\inc;</ProjectIncludeDirectories>
    </PropertyGroup>

    <ItemDefinitionGroup>
        <ClCompile>
            <ExceptionHandling>Sync</ExceptionHandling>
        </ClCompile>

        <Link>
            <ModuleDefinitionFile>MockDCompInjector.def</ModuleDefinitionFile>

            <AdditionalDependencies>onecoreuap.lib;</AdditionalDependencies>
        </Link>
    </ItemDefinitionGroup>

    <ItemGroup>
        <ClCompile Include="dllmain.cpp"/>
        <ResourceCompile Include="DefaultResource.rc"/>    <!-- Autogenerated file name + version for Device Guard whitelisting effort -->
    </ItemGroup>

    <!-- Autogenerated. Sets file name for Device Guard whitelisting effort, used in RC.exe. -->
    <PropertyGroup>
        <ProjectPreprocessorDefinitions>$(ProjectPreprocessorDefinitions) ___TARGETNAME="""$(TargetName).$(Targettype)""";</ProjectPreprocessorDefinitions>
    </PropertyGroup>

    <Import Project="$([MSBuild]::GetPathOfFileAbove(Microsoft.UI.Xaml.Build.targets))" />
</Project>
