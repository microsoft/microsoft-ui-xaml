<Project DefaultTargets="Build" ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

    <Import Project="$(XamlSourcePath)\common.props"/>

    <ItemDefinitionGroup>
        <ClCompile>
            <WarningLevel>Level4</WarningLevel>
            <TreatWarningAsError>false</TreatWarningAsError>
            <DisableSpecificWarnings>%(DisableSpecificWarnings);4189;4458;4691;4711;4945;34640</DisableSpecificWarnings>
        </ClCompile>
    </ItemDefinitionGroup>

    <Import Project="$(XamlSourcePath)\msbuild\buildsettings\ETWManifestUsage.props"/>
</Project>
