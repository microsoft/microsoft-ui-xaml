<Grid x:Name="rootGrid" Width="400" Height="300" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ScrollViewer x:Name="scrollViewer"
    HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
    Width="300" Height="200" Margin="50">
    <StackPanel x:Name="stackPanel" Orientation="Horizontal" VerticalAlignment="Stretch">
      <Rectangle Width="45" Fill="Blue" MinHeight="100"/>
      <Rectangle Width="55" Fill="White" MinHeight="100"/>
      <Rectangle Width="65" Fill="Red" MinHeight="100"/>
    </StackPanel>
  </ScrollViewer>
</Grid>