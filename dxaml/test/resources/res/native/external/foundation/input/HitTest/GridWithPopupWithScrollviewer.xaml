<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      x:Name="RootGrid"
      HorizontalAlignment="Left"
      VerticalAlignment="Top"
      Width="500"
      Height="500"
      Background="#88FF0000">
  <Button x:Name="FlyoutButton"
          Background="#8800FF00"
          HorizontalAlignment="Left"
          VerticalAlignment="Top"
          Content="Flyout">
    <Button.Flyout>
      <Flyout Placement="Bottom">
        <StackPanel>
          <TextBlock Height="50">
            Tapping here must not hit
          </TextBlock>
          <ScrollViewer x:Name="PopupScrollViewer" Height="200" Width="180">
            <Button x:Name="ChildButton"
                    Width="150"
                    Height="400"
                    Background="Blue"
                    Content="Inner Button" />
          </ScrollViewer>
        </StackPanel>
      </Flyout>
    </Button.Flyout>
  </Button>
</Grid>