<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Margin="0,50,0,0">
    <Canvas Width="250" Height="250">
        <StackPanel>
            <Popup x:Name="myPopup" FlowDirection="RightToLeft" IsOpen="True">
                <Rectangle x:Name="targetRectangle" Width="100" Height="100" Fill="Green"/>
            </Popup>
        </StackPanel>
        <Rectangle x:Name="myRectangle" Width="100" Height="100" Fill="Red"/>
    </Canvas>
</Grid>