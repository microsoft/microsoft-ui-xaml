<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Canvas>
    <Canvas.RenderTransform>
      <ScaleTransform ScaleX="2.0" ScaleY="2.0"/>
    </Canvas.RenderTransform>
    <Canvas x:Name="myCanvas">
      <Canvas.Clip>
        <RectangleGeometry Rect="0,0,0,0"/>
      </Canvas.Clip>
      <RichTextBlock>
        <Paragraph>
          <InlineUIContainer>
            <Image x:Name="myImage" Width="25" Height="25" Source="ms-appx:///resources/native/external/foundation/graphics/image/rainier_2048x1536.png"/>
          </InlineUIContainer>
        </Paragraph>
      </RichTextBlock>
    </Canvas>
  </Canvas>
</Grid>