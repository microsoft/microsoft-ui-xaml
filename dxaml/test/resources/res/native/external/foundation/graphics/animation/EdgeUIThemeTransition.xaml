<StackPanel xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            Orientation="Horizontal">
    <StackPanel.Resources>
        <Style x:Key="StackPanelTransitionStyle" TargetType="StackPanel">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>
        <Style x:Key="RectangleStyle" TargetType="Rectangle">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="Margin" Value="5"/>
        </Style>
    </StackPanel.Resources>
    <StackPanel Style="{StaticResource StackPanelTransitionStyle}">
        <StackPanel.Transitions>
            <EdgeUIThemeTransition Edge="Top"/>
        </StackPanel.Transitions>
        <Rectangle Style="{StaticResource RectangleStyle}" Fill="Red"/>
        <Rectangle Style="{StaticResource RectangleStyle}" Fill="Green"/>
        <Rectangle Style="{StaticResource RectangleStyle}" Fill="Blue"/>
        <Rectangle Style="{StaticResource RectangleStyle}" Fill="Purple"/>
        <Rectangle Style="{StaticResource RectangleStyle}" Fill="Orange"/>
    </StackPanel>
    <StackPanel Style="{StaticResource StackPanelTransitionStyle}">
        <StackPanel.Transitions>
            <EdgeUIThemeTransition Edge="Left"/>
        </StackPanel.Transitions>
        <Rectangle Style="{StaticResource RectangleStyle}" Fill="Red"/>
        <Rectangle Style="{StaticResource RectangleStyle}" Fill="Green"/>
        <Rectangle Style="{StaticResource RectangleStyle}" Fill="Blue"/>
        <Rectangle Style="{StaticResource RectangleStyle}" Fill="Purple"/>
        <Rectangle Style="{StaticResource RectangleStyle}" Fill="Orange"/>
    </StackPanel>
    <StackPanel Style="{StaticResource StackPanelTransitionStyle}">
        <StackPanel.Transitions>
            <EdgeUIThemeTransition Edge="Right"/>
        </StackPanel.Transitions>
        <Rectangle Style="{StaticResource RectangleStyle}" Fill="Red"/>
        <Rectangle Style="{StaticResource RectangleStyle}" Fill="Green"/>
        <Rectangle Style="{StaticResource RectangleStyle}" Fill="Blue"/>
        <Rectangle Style="{StaticResource RectangleStyle}" Fill="Purple"/>
        <Rectangle Style="{StaticResource RectangleStyle}" Fill="Orange"/>
    </StackPanel>
    <StackPanel Style="{StaticResource StackPanelTransitionStyle}">
        <StackPanel.Transitions>
            <EdgeUIThemeTransition Edge="Bottom"/>
        </StackPanel.Transitions>
        <Rectangle Style="{StaticResource RectangleStyle}" Fill="Red"/>
        <Rectangle Style="{StaticResource RectangleStyle}" Fill="Green"/>
        <Rectangle Style="{StaticResource RectangleStyle}" Fill="Blue"/>
        <Rectangle Style="{StaticResource RectangleStyle}" Fill="Purple"/>
        <Rectangle Style="{StaticResource RectangleStyle}" Fill="Orange"/>
    </StackPanel>
</StackPanel>