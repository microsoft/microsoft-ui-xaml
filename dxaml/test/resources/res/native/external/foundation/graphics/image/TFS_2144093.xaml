<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- CornerRadius forces image to decode into software surface -->
    <Border Width="100" Height="100" CornerRadius="10">
        <Border.Background>
            <ImageBrush x:Name="TheBrush" ImageSource="ms-appx:///resources/native/external/foundation/graphics/image/windows.png" Stretch="None"/>
        </Border.Background>
    </Border>
    <Image Visibility="Collapsed" Source="ms-appx:///resources/native/external/foundation/graphics/image/windows.png"/>
</Grid>
