<StackPanel
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Height="300" Width="300"
  HorizontalAlignment="Left"
  VerticalAlignment="Top"
  Background="White">
  <StackPanel Background="LightGray" HorizontalAlignment="Center" Orientation="Horizontal">
    <!-- FontIcon that sizes to its content (House icon) -->
    <FontIcon x:Name="fontIcon" Glyph="&#xE80F;" FontSize="32" Foreground="Black"/>
  </StackPanel>
  <Image x:Name="img" HorizontalAlignment="Center"/>
</StackPanel>
