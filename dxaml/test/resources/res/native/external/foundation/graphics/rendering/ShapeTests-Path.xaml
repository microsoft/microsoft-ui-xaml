<StackPanel x:Name="TestName" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid x:Name="gridParent" Background="Red" Width="100" Height="100" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="0">
    <Path x:Name="shape" Width="10" Height="10" StrokeThickness="1" Stroke="Blue" Data="M0,0 L 10, 10 Z" VerticalAlignment="Top" HorizontalAlignment="Left">
      <Path.RenderTransform>
        <CompositeTransform />
      </Path.RenderTransform>
    </Path>
    
    <Grid.RenderTransform>
      <CompositeTransform />
    </Grid.RenderTransform>
    <Grid.Resources>
      <Storyboard x:Name="shapeAnimation" >
        <DoubleAnimationUsingKeyFrames
            Storyboard.TargetName="shape"
            Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.ScaleX)"
            Duration="0:10:00">
          <LinearDoubleKeyFrame Value="0.01" KeyTime="0:0:0" />
          <LinearDoubleKeyFrame Value="10" KeyTime="0:0:0.03" />
          <LinearDoubleKeyFrame Value="10" KeyTime="0:10:00" />
        </DoubleAnimationUsingKeyFrames>
        <DoubleAnimationUsingKeyFrames
            Storyboard.TargetName="shape"
            Storyboard.TargetProperty="(UIElement.RenderTransform).(CompositeTransform.ScaleY)"
            Duration="0:10:00">
          <LinearDoubleKeyFrame Value="0.01" KeyTime="0:0:0" />
          <LinearDoubleKeyFrame Value="10" KeyTime="0:0:0.03" />
          <LinearDoubleKeyFrame Value="10" KeyTime="0:10:00" />
        </DoubleAnimationUsingKeyFrames>
      </Storyboard>
    </Grid.Resources>
  </Grid>
  <Image x:Name="img" HorizontalAlignment="Center"/>
</StackPanel>