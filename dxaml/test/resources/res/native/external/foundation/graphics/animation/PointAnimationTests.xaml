<Canvas xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Canvas.Resources>
        <Storyboard x:Name="MyStoryboard">
            <PointAnimation 
                    x:Name="MyPointAnimation"
                    EnableDependentAnimation="True"
                    Storyboard.TargetProperty="Center"
                    Storyboard.TargetName="MyEllipseGeometry"
                    Duration="0:0:0.5"
                    To="250,150"/>
        </Storyboard>
    </Canvas.Resources>
    <Path x:Name="MyPath" Canvas.Top="100" Fill="Gold" Stroke="Black" StrokeThickness="1">
        <Path.Data>
            <EllipseGeometry x:Name="MyEllipseGeometry" Center="50,50" RadiusX="50" RadiusY="50"/>
        </Path.Data>
    </Path>
</Canvas>