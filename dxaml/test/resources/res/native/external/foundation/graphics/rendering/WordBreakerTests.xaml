<StackPanel
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Margin="25">
  <TextBlock x:Name="textBlock" IsTextSelectionEnabled="True">
      This is some text. !!! In a text block?
      <LineBreak/>
      Mr. Smith-Jones uses a lot of punctuation -- in his to-do lists.
  </TextBlock>
  <RichTextBlock
      x:Name="richTextBlock"
      Height="30"
      IsTextSelectionEnabled="True"
      OverflowContentTarget="{Binding ElementName=richTextBlockOverflow}">
    <Paragraph>
      This is some text. !!! In a *rich text block?
      <LineBreak/>
      Here's the next line in an overflow.
    </Paragraph>
    <Paragraph>
      And here's a second paragraph.
    </Paragraph>
  </RichTextBlock>
  <RichTextBlockOverflow
      x:Name="richTextBlockOverflow"
      Margin="25">
  </RichTextBlockOverflow>
</StackPanel>
