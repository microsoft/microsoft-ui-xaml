<StackPanel xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Margin="20">
    <Grid x:Name="root">
        <StackPanel>
            <StackPanel.RenderTransform>
                <MatrixTransform Matrix="3,1,-1,3,0,0"/>
            </StackPanel.RenderTransform>
            <TextBlock x:Name="tb1" Text="tb1" />
            <TextBlock x:Name="tb2" Text="tb2" CompositeMode="MinBlend" Margin="10" IsTextSelectionEnabled="True" Loaded="TextBlock_Loaded">
                <TextBlock.RenderTransform>
                    <ScaleTransform ScaleX="2" ScaleY="2"/>
                </TextBlock.RenderTransform>
            </TextBlock>
        </StackPanel>
    </Grid>
</StackPanel>
