<StackPanel xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Margin="10,0,0,0">

    <!-- Test the same strings with a built-in copy of the Segoe UI Emoji font. -->
    <TextBlock x:Name="tb1" Text="tb1 &#x1F601;" FontSize="20" IsColorFontEnabled="true" FontFamily="./seguiemj.ttf" />
    <TextBlock x:Name="tb2" Text="tb2 &#x1F601;" FontSize="20" IsColorFontEnabled="false" FontFamily="./seguiemj.ttf" />

    <!-- Test Glyphs with a color glyph, with and without color, and with a different color palette index. -->
    <Glyphs x:Name="g1" Indices="1059" FontRenderingEmSize="20" IsColorFontEnabled="true" FontUri="./resources/native/external/foundation/graphics/rendering/seguiemj.ttf" Fill="White" />
    <Glyphs x:Name="g2" Indices="1059" FontRenderingEmSize="20" IsColorFontEnabled="false" FontUri="./resources/native/external/foundation/graphics/rendering/seguiemj.ttf" Fill="White" />
    <Glyphs x:Name="g3" Indices="1059" FontRenderingEmSize="20" IsColorFontEnabled="true" ColorFontPaletteIndex="0" FontUri="./resources/native/external/foundation/graphics/rendering/seguiemj.ttf" Fill="White" />
    <Glyphs x:Name="g4" Indices="1059" FontRenderingEmSize="20" IsColorFontEnabled="true" ColorFontPaletteIndex="0" FontUri="./resources/native/external/foundation/graphics/rendering/seguiemj.ttf" Fill="White" />

</StackPanel>

