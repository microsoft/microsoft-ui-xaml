<StackPanel
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Height="300" Width="300"
  HorizontalAlignment="Left"
  VerticalAlignment="Top"
  Background="White">
  <StackPanel Background="LightGray" HorizontalAlignment="Center" Orientation="Horizontal">
    <!-- BitmapIcon that sizes to its content -->
    <BitmapIcon x:Name="bitmapIcon" UriSource="ms-appx:///resources/native/external/foundation/graphics/image/80x80Checker.png" ShowAsMonochrome="False"/>
  </StackPanel>
  <Image x:Name="img" HorizontalAlignment="Center"/>
</StackPanel>
