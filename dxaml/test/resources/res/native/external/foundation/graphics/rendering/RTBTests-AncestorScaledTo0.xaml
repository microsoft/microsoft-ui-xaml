<StackPanel
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <StackPanel.RenderTransform>
        <ScaleTransform ScaleX = "0" ScaleY = "0"/>
    </StackPanel.RenderTransform>

    <StackPanel x:Name="colors" Orientation="Horizontal" HorizontalAlignment="Center">
        <Rectangle Height="100" Width="40" Fill="Blue"/>
        <Rectangle Height="100" Width="40" Fill="White"/>
        <Rectangle Height="100" Width="40" Fill="Red"/>
    </StackPanel>
    
    <Image x:Name="img" HorizontalAlignment="Center"/>
</StackPanel>