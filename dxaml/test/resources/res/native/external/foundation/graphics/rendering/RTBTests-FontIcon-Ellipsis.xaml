<StackPanel
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Height="300" Width="300"
  HorizontalAlignment="Left"
  VerticalAlignment="Top"
  Background="White">
  <StackPanel Background="LightGray" HorizontalAlignment="Center" Orientation="Horizontal">
    <!-- FontIcon with the ellipsis (More) glyph - an odd-sized glyph that may have different width/height -->
    <FontIcon x:Name="fontIcon" Glyph="&#xE712;" FontSize="20" Foreground="Blue"/>
  </StackPanel>
  <Image x:Name="img" HorizontalAlignment="Center"/>
</StackPanel>
