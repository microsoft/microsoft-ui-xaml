<StackPanel xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Margin="20">
<!-- Test animation of shared transform used with different RenderTransformOrigins -->
  <Border Width="100" Height="50" CornerRadius="200,100,0,0" BorderBrush="Green" BorderThickness="10">
    <Rectangle Width="100" Height="100" Fill="Red"/>
  </Border>
  <Border Width="100" Height="50" CornerRadius="0,0,200,100" BorderBrush="Green" BorderThickness="10">
    <Rectangle Width="100" Height="100" Fill="Red"/>
  </Border>
  <Border Width="100" Height="50" CornerRadius="100,0,0,50" BorderBrush="Green" BorderThickness="10">
    <Rectangle Width="100" Height="100" Fill="Red"/>
  </Border>
  <Border Width="100" Height="50" CornerRadius="0,100,50,0" BorderBrush="Green" BorderThickness="10">
    <Rectangle Width="100" Height="100" Fill="Red"/>
  </Border>
</StackPanel>
