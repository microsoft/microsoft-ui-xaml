<StackPanel xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Margin="20">
    <Border Width="40" Height="40" Background="Red" BorderThickness="5" BorderBrush="Yellow" CornerRadius="10">
        <Rectangle Width="40" Height="40" Fill="Green"/>
    </Border> 
    <Border Width="41" Height="41" Background="Red" BorderThickness="5" BorderBrush="Yellow" CornerRadius="0"> 
        <Rectangle Width="40" Height="40" Fill="Green"/>
    </Border>
    <Grid Width="42" Height="42" Background="Red" BorderThickness="5" BorderBrush="Yellow" CornerRadius="10"> 
        <Rectangle Width="40" Height="40" Fill="Green"/>
    </Grid>
    <ContentPresenter Width="43" Height="43" Background="Red" BorderThickness="5" BorderBrush="Yellow" CornerRadius="10"> 
        <Rectangle Width="40" Height="40" Fill="Green"/>
    </ContentPresenter>
    <RelativePanel Width="44" Height="44" Background="Red" BorderThickness="5" BorderBrush="Yellow" CornerRadius="10"> 
        <Rectangle Width="40" Height="40" Fill="Green"/>
    </RelativePanel>
    <StackPanel Width="45" Height="45" Background="Red" BorderThickness="5" BorderBrush="Yellow" CornerRadius="10"> 
        <Rectangle Width="40" Height="40" Fill="Green"/>
    </StackPanel>
</StackPanel>
