<StackPanel xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Margin="20">
    <Grid x:Name="myGrid" Width="100" Height="100" Background="Red" BorderBrush="Green" BorderThickness="10">
        <Grid.Triggers>
            <EventTrigger RoutedEvent="Grid.Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <ColorAnimation
                                Storyboard.TargetName="myGrid"
                                Storyboard.TargetProperty="(Grid.BorderBrush).(SolidColorBrush.Color)"
                                To="Yellow" Duration="0:0:2" AutoReverse="True" RepeatBehavior="Forever" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>
    </Grid>
</StackPanel>
