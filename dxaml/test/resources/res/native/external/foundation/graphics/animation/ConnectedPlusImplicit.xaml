<StackPanel x:Name="root" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Margin="20">
    <Canvas x:Name="sourceParent" Width="400" Height="400" Background="Blue">
        <TextBlock x:Name="source" Text="source"/>
    </Canvas>
    <Canvas x:Name="destinationParent" Width="400" Height="400" Background="Red">
        <TextBlock x:Name="destination" Text="destination" Canvas.Left="200"/>
    </Canvas>
</StackPanel>
