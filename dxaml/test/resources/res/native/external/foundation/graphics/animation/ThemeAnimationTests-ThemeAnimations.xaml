<Canvas xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Canvas.Resources>
        <Storyboard x:Name="_dragItem">
            <DragItemThemeAnimation Storyboard.TargetName="r"/>
        </Storyboard>
        <Storyboard x:Name="_dragOver">
            <DragOverThemeAnimation Storyboard.TargetName="r" Direction="Right" ToOffset="100" />
        </Storyboard>
        <Storyboard x:Name="_dropTarget">
            <DropTargetItemThemeAnimation Storyboard.TargetName="r"/>
        </Storyboard>
        <Storyboard x:Name="_fadeIn">
            <FadeInThemeAnimation Storyboard.TargetName="r" />
        </Storyboard>
        <Storyboard x:Name="_fadeOut">
            <FadeOutThemeAnimation Storyboard.TargetName="r" />
        </Storyboard>
        <Storyboard x:Name="_pointerDown">
            <PointerDownThemeAnimation Storyboard.TargetName="r" />
        </Storyboard>
        <Storyboard x:Name="_pointerUp">
            <PointerUpThemeAnimation Storyboard.TargetName="r" />
        </Storyboard>
        <Storyboard x:Name="_popIn">
            <PopInThemeAnimation Storyboard.TargetName="r" FromHorizontalOffset="100" />
        </Storyboard>
        <Storyboard x:Name="_popOut">
            <PopOutThemeAnimation Storyboard.TargetName="r" />
        </Storyboard>
        <Storyboard x:Name="_reposition">
            <RepositionThemeAnimation Storyboard.TargetName="r" FromHorizontalOffset="100" />
        </Storyboard>
        <Storyboard x:Name="_swipeBack">
            <SwipeBackThemeAnimation Storyboard.TargetName="r" />
        </Storyboard>
        <Storyboard x:Name="_swipeHint">
            <SwipeHintThemeAnimation Storyboard.TargetName="r" />
        </Storyboard>
        <!-- SplitOpen and SplitClosed require multiple targets. They're tested separately. -->
    </Canvas.Resources>

    <Rectangle Width="50" Height="50" Fill="Red" Canvas.Top="100" x:Name="r" />

</Canvas>