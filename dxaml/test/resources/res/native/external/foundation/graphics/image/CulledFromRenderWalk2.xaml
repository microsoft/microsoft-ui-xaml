<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Canvas>
    <Canvas.RenderTransform>
      <ScaleTransform ScaleX="2.0" ScaleY="2.0"/>
    </Canvas.RenderTransform>
    <Canvas x:Name="myCanvas" Width="50" Height="50">
      <Canvas.Clip>
        <RectangleGeometry Rect="0,0,0,0"/>
      </Canvas.Clip>
      <Canvas.Background>
        <ImageBrush ImageSource="ms-appx:///resources/native/external/foundation/graphics/image/rainier_2048x1536.png"/>
      </Canvas.Background>
    </Canvas>
  </Canvas>
</Grid>