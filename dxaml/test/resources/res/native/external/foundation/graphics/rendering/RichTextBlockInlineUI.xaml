<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Background="Green">
    <Grid.Resources>
        <DataTemplate x:Key="MessageItemTemplate">
            <RichTextBlock>
                <Paragraph>
                    <InlineUIContainer>
                        <Rectangle Fill="Blue" Width="20" Height="20" />
                    </InlineUIContainer>
                </Paragraph>
            </RichTextBlock>
        </DataTemplate>        
    </Grid.Resources>
    <ListView ItemTemplate="{StaticResource MessageItemTemplate}">
        <ListView.Items>
           <x:Int32>0</x:Int32>
           <x:Int32>1</x:Int32>
           <x:Int32>2</x:Int32>
        </ListView.Items>
    </ListView>
</Grid>
