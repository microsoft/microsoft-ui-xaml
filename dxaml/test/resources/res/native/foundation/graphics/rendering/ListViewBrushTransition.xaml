<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid.Resources>
        <Style x:Key="MyCustomListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="Margin" Value="0,0,18,2"/>
            <Setter Property="MinHeight" Value="10"/>
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <ListViewItemPresenter Width="60" Height="40" HorizontalContentAlignment="Left"
                            PointerOverBackground="Red"
                            PressedBackground="Orange"
                            SelectedBackground="Yellow"
                            SelectedPointerOverBackground="Green"
                            SelectedPressedBackground="Blue" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Grid.Resources>

    <ListView x:Name="listView" ItemContainerStyle="{StaticResource MyCustomListViewItemStyle}" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.HorizontalScrollMode="Disabled" ScrollViewer.VerticalScrollBarVisibility="Hidden">
      <Rectangle Fill="Black" Width="30" Height="20"/>
    </ListView>
</Grid>

