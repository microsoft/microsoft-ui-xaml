<Grid 
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
  <Page x:Name="PageControl" Margin="20,20,20,20" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
      <Grid.RowDefinitions>
        <RowDefinition Height="auto"/>
        <RowDefinition Height="*"  />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
          <ColumnDefinition Width="250"/>
          <ColumnDefinition Width="150"/>
      </Grid.ColumnDefinitions>
      <Button x:Name="FocusButton" Content="Focus Button" HorizontalAlignment="Center" VerticalAlignment="Center"/>
      <UserControl Name="OuterUserControl" Grid.Row="2" Margin="20,20,20,20" HorizontalAlignment="Center" VerticalAlignment="Center" IsTabStop="True">
        <Border Background="Green">
          <Border.RenderTransform>
            <TransformGroup>
              <RotateTransform x:Name="BorderRotateTransform"/>
              <TranslateTransform x:Name="BorderTranslateTransform"/>        
            </TransformGroup>
          </Border.RenderTransform>
          <UserControl Name="InnerUserControl" Margin="20,20,20,20">
            <Border Height="100" Width="200" Background="Yellow"/>
          </UserControl>
        </Border>
      </UserControl>
      <ScrollViewer VerticalScrollMode="Auto" Grid.Row="2"  Grid.Column="2" Height="200" HorizontalAlignment="Stretch" VerticalAlignment="Center">
        <StackPanel HorizontalAlignment="Stretch">
          <Border Background="Blue" Height="100" HorizontalAlignment="Stretch"/>
          <UserControl Name="ScrollableUserControl" Margin="20,20,20,20">
            <Border Height="50" Width="100" Background="Orange"/>
          </UserControl>
          <Border Background="Red" Height="100" HorizontalAlignment="Stretch"/>
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Page>
</Grid>
