<Grid
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
        <Grid.Resources>
        <Style TargetType="Button">
            <Setter Property="Width" Value="250"/>
            <Setter Property="Height" Value="100"/>
            </Style>
         </Grid.Resources>
                <Hub x:Name="hub">
                    <HubSection x:Name="Sec1" Header=" " Margin="0">
                        <DataTemplate>
                            <StackPanel Margin="4,0,0,0">
                                <Button x:Name="btn00" Content="Log out"/>
                                <Button x:Name="btn01" Content="Settings" />
                                <Button x:Name="btn02" Content="Upgrade to Premiere Gold+" />
                            </StackPanel>
                        </DataTemplate>
                    </HubSection>

                    <HubSection x:Uid="Section1Header" Header="TEST" >
                        <DataTemplate>
                            <GridView x:Name="itemGridView" Grid.RowSpan="2"
                                    Padding="0"
                                    SelectionMode="None"
                                    IsSwipeEnabled="false"
                                    IsItemClickEnabled="True">
                                <Button Width="250" Height="250" Content="Lorem"/>
                                <Button Width="250" Height="250" Content="Lorem"/>
                                <Button Width="250" Height="250" Content="Lorem"/>
                                <Button Width="250" Height="250" Content="Lorem"/>
                            </GridView>
                        </DataTemplate>
                    </HubSection>


                    <HubSection x:Uid="Section2Header" Header="FEATURED" >
                        <DataTemplate>
                            <Grid Margin="-8,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid Margin="4,0,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Content="Lorem" x:Name="btn20" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                                    <Button Content="Lorem" x:Name="btn21" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                                    <Button Content="Lorem" x:Name="btn22" Grid.Column="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                                </Grid>
                                <Grid Margin="4,0,0,0" Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Content="Lorem" x:Name="btn23" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                                    <Button Content="Lorem" x:Name="btn24" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                                    <Button Content="Lorem" x:Name="btn25" Grid.Column="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                                </Grid>
                                <Grid Margin="4,0,0,0" Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Content="Lorem" x:Name="btn26" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                                    <Button Content="Lorem" x:Name="btn27" Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                                    <Button Content="Lorem" x:Name="btn28" Grid.Column="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </HubSection>
                    <HubSection x:Uid="Section3Header" Header="NEW">
                        <DataTemplate>
                            <Grid Margin="-8,0,0,0">
                                <StackPanel Margin="4,0,0,0">
                                    <Button Content="Lorem" x:Name="btn30" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                                    <Button Content="Lorem" x:Name="btn31" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                                    <Button Content="Lorem" x:Name="btn32" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </HubSection>
                    <HubSection IsHeaderInteractive="True"
                        x:Uid="Section4Header" x:Name="Section4" Header="COMMUNITY FAVORITES">
                        <DataTemplate>
                            <Grid Margin="-8,0,0,0">
                                <StackPanel Margin="4,0,0,0">
                                    <Button Content="Lorem" x:Name="btn40" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                                    <Button Content="Lorem" x:Name="btn41" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                                    <Button Content="Lorem" x:Name="btn42" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </HubSection>
                </Hub>
    </Grid>

