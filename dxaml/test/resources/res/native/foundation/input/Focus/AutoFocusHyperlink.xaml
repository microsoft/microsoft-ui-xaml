<StackPanel
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="rootStackPanel">

    <Button x:Name="Btn" Content="Button" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
    <TextBlock Name="TxB1">
        <Run>Pre-hyperlink:</Run>
        <Hyperlink  x:Name="hyperlink" NavigateUri="www.bing.com">Bing</Hyperlink>
        <Run>Post-hyperlink</Run>
    </TextBlock>
    <TextBlock>Here's some header text</TextBlock>
    <RichTextBlock x:Name="TxB2">
        <Paragraph FontSize="22">Please click on this
            <Hyperlink x:Name="hyperlinkRTB" NavigateUri="http://www.bing.com">link</Hyperlink>, thanks!
        </Paragraph>
    </RichTextBlock>
</StackPanel>