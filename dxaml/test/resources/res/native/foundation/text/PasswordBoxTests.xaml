<StackPanel Width="400" Height="400" VerticalAlignment="Top" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <StackPanel.Resources>
    <!-- Restore old TextControlThemePadding padding value when TextBox defaulted to 15 font size instead of 14 -->
    <Style TargetType="PasswordBox">
      <Setter Property="Padding" Value="10,3,6,5"/>
    </Style>
    <Style TargetType="Button">
      <Setter Property="FontSize" Value="15"/>
      <Setter Property="Padding" Value="8,4,8,4"/>
    </Style>
  </StackPanel.Resources>
  <Button x:Name="button" Content="Discard SIP" Margin="20,40,20,0"/>
  <PasswordBox x:Name="passwordBox" ContextFlyout="{x:Null}" SelectionFlyout="{x:Null}" FontSize="20" Width="200" Margin="20,5,20,0"/>
</StackPanel>
