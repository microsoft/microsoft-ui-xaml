<StackPanel Width="400" Height="400" VerticalAlignment="Top" Margin="20,20,20,0" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
        <Button x:Name="button" Content="过入" FontSize="30" />
        <TextBox x:Name="textBox" Text="过入" Width="100" FontSize="30" />
        <TextBlock x:Name="fastPathTextBlock" Text="过入" Width="100"  FontFamily="Segoe UI" FontSize="30" />
        <TextBlock x:Name="slowPathTextBlock" Text="过入" Width="100"  FontFamily="Segoe UI" TextTrimming="Clip" FontSize="30" />
</StackPanel>

