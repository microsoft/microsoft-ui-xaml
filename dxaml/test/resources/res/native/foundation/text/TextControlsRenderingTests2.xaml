<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Width="800" Height="600" Background="RoyalBlue">
  <Grid.Resources>
    <Style TargetType="TextBox">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontFamily" Value="Segoe UI"/>
      <Setter Property="Foreground" Value="Black"/>
    </Style>
    <Style TargetType="RichEditBox">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontFamily" Value="Segoe UI"/>
      <Setter Property="Foreground" Value="Black"/>
    </Style>
    <Style TargetType="Border">
      <Setter Property="Margin" Value="1"/>
      <Setter Property="Background" Value="Beige"/>
      <Setter Property="VerticalAlignment" Value="Top"/>
    </Style>
    <Style x:Key="borderRotate" TargetType="Border">
      <Setter Property="VerticalAlignment" Value="Top"/>
      <Setter Property="HorizontalAlignment" Value="Left"/>
      <Setter Property="Margin" Value="5"/>
      <Setter Property="BorderBrush" Value="Red"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="RenderTransform">
        <Setter.Value>
          <RotateTransform Angle="10"/>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="borderScale" TargetType="Border">
      <Setter Property="Margin" Value="-3"/>
      <Setter Property="BorderBrush" Value="Green"/>
      <Setter Property="BorderThickness" Value="0.5"/>
      <Setter Property="RenderTransform">
        <Setter.Value>
          <ScaleTransform ScaleX="2" ScaleY="2"/>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="borderShift" TargetType="Border">
      <Setter Property="Margin" Value="-3"/>
      <Setter Property="BorderBrush" Value="Blue"/>
      <Setter Property="BorderThickness" Value="0.5"/>
      <Setter Property="RenderTransform">
        <Setter.Value>
          <TranslateTransform X="10" Y="-5"/>
        </Setter.Value>
      </Setter>
    </Style>
    <Style TargetType="TextBlock">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontFamily" Value="Segoe UI"/>
      <Setter Property="Foreground" Value="Black"/>
    </Style>
    <Style TargetType="RichTextBlock">
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontFamily" Value="Segoe UI"/>
      <Setter Property="Foreground" Value="Black"/>
    </Style>
    <Style TargetType="Glyphs">
      <Setter Property="FontRenderingEmSize" Value="14"/>
      <Setter Property="FontUri" Value="Arial.ttf"/>
      <Setter Property="Fill" Value="Black"/>
    </Style>
    <LinearGradientBrush x:Key="brushLGB" StartPoint="0,0" EndPoint="1,1">
      <GradientStop Color="Yellow" Offset="0.0" />
      <GradientStop Color="Red" Offset="0.25" />
      <GradientStop Color="Green" Offset="0.5" />
      <GradientStop Color="Blue" Offset="0.75" />
      <GradientStop Color="LimeGreen" Offset="1.0" />
    </LinearGradientBrush>
  </Grid.Resources>
  <Grid.ColumnDefinitions>
    <ColumnDefinition Width="*"/>
    <ColumnDefinition Width="*"/>
    <ColumnDefinition Width="*"/>
    <ColumnDefinition Width="*"/>
  </Grid.ColumnDefinitions>
  <Grid.RowDefinitions>
    <RowDefinition Height="Auto"/>
    <RowDefinition Height="Auto"/>
    <RowDefinition Height="Auto"/>
    <RowDefinition Height="Auto"/>
    <RowDefinition Height="Auto"/>
    <RowDefinition Height="Auto"/>
    <RowDefinition Height="Auto"/>
    <RowDefinition Height="Auto"/>
    <RowDefinition Height="Auto"/>
    <RowDefinition Height="Auto"/>
  </Grid.RowDefinitions>
  <Border Grid.Column="0" Grid.Row="0" Height="70">
    <Border Style="{StaticResource borderRotate}">
      <Border Style="{StaticResource borderScale}">
        <Border Style="{StaticResource borderShift}">
          <TextBlock Margin="5" Text="The quick"/>
        </Border>
      </Border>
    </Border>
  </Border>
  <Border Grid.Column="1" Grid.Row="0" Height="70" CacheMode="BitmapCache">
    <Border Style="{StaticResource borderRotate}">
      <Border Style="{StaticResource borderScale}">
        <Border Style="{StaticResource borderShift}">
          <TextBlock Margin="5" Text="The quick"/>
        </Border>
      </Border>
    </Border>
  </Border>
  <Border Grid.Column="2" Grid.Row="0" Height="70">
    <Border Style="{StaticResource borderRotate}">
      <Border Style="{StaticResource borderScale}">
        <Border Style="{StaticResource borderShift}">
          <RichTextBlock Margin="5">
            <Paragraph>
              <Run>The quick</Run>
            </Paragraph>
          </RichTextBlock>
        </Border>
      </Border>
    </Border>
  </Border>
  <Border Grid.Column="3" Grid.Row="0" Height="70" CacheMode="BitmapCache">
    <Border Style="{StaticResource borderRotate}">
      <Border Style="{StaticResource borderScale}">
        <Border Style="{StaticResource borderShift}">
          <RichTextBlock Margin="5">
            <Paragraph>
              <Run>The quick</Run>
            </Paragraph>
          </RichTextBlock>
        </Border>
      </Border>
    </Border>
  </Border>
  <Border Grid.Column="0" Grid.Row="1" Height="100">
    <Border Style="{StaticResource borderRotate}">
      <Border Style="{StaticResource borderScale}">
        <Border Style="{StaticResource borderShift}">
          <TextBox Margin="5" Text="The quick" Width="80" Height="20" />
        </Border>
      </Border>
    </Border>
  </Border>
  <Border Grid.Column="1" Grid.Row="1" Height="100" CacheMode="BitmapCache">
    <Border Style="{StaticResource borderRotate}">
      <Border Style="{StaticResource borderScale}">
        <Border Style="{StaticResource borderShift}">
          <TextBox Margin="5" Text="The quick" Width="80" Height="20" />
        </Border>
      </Border>
    </Border>
  </Border>
  <Border Grid.Column="2" Grid.Row="1" Height="100">
    <Border Style="{StaticResource borderRotate}">
      <Border Style="{StaticResource borderScale}">
        <Border Style="{StaticResource borderShift}">
          <Glyphs UnicodeString="The quick" />
        </Border>
      </Border>
    </Border>
  </Border>
  <Border Grid.Column="3" Grid.Row="1" Height="100" CacheMode="BitmapCache">
    <Border Style="{StaticResource borderRotate}">
      <Border Style="{StaticResource borderScale}">
        <Border Style="{StaticResource borderShift}">
          <Glyphs UnicodeString="The quick" />
        </Border>
      </Border>
    </Border>
  </Border>
  <Border Grid.Column="0" Grid.Row="2">
    <Canvas Height="40">
      <TextBox Canvas.Left="3" Canvas.Top="3" Text="The quick brown &#x05D0;&#x05D1;" />
    </Canvas>
  </Border>
  <Border Grid.Column="1" Grid.Row="2">
    <Canvas Height="40">
      <TextBox Canvas.Left="3" Canvas.Top="3" Text="The quick brown &#x05D0;&#x05D1;" CacheMode="BitmapCache" />
    </Canvas>
  </Border>
  <Border Grid.Column="2" Grid.Row="2">
    <TextBox Text="The quick brown &#x05D0;&#x05D1;" TextAlignment="Right" />
  </Border>
  <Border Grid.Column="3" Grid.Row="2">
    <TextBox Text="The quick brown &#x05D0;&#x05D1;" TextAlignment="Right" CacheMode="BitmapCache" />
  </Border>
  <Border Grid.Column="0" Grid.Row="3">
    <Canvas Height="75">
      <TextBox Canvas.Left="10" Canvas.Top="5" Text="The &#x05D0;&#x05D1;">
        <TextBox.RenderTransform>
          <ScaleTransform ScaleX="1.75" ScaleY="1.75" />
        </TextBox.RenderTransform>
      </TextBox>
    </Canvas>
  </Border>
  <Border Grid.Column="1" Grid.Row="3">
    <Canvas Height="75">
      <TextBox Canvas.Left="10" Canvas.Top="5" Text="The &#x05D0;&#x05D1;" CacheMode="BitmapCache">
        <TextBox.RenderTransform>
          <ScaleTransform ScaleX="1.75" ScaleY="1.75" />
        </TextBox.RenderTransform>
      </TextBox>
    </Canvas>
  </Border>
  <Border Grid.Column="2" Grid.Row="3">
    <Canvas Height="55">
      <TextBox Canvas.Left="20" Canvas.Top="-10" Text="The &#x05D0;&#x05D1;" Width="100">
        <TextBox.RenderTransform>
          <TransformGroup>
            <ScaleTransform ScaleX="2" ScaleY="2" />
            <RotateTransform Angle="15" />
          </TransformGroup>
        </TextBox.RenderTransform>
      </TextBox>
    </Canvas>
  </Border>
  <Border Grid.Column="75" Grid.Row="3">
    <Canvas Height="55">
      <TextBox Canvas.Left="20" Canvas.Top="-10" Text="The &#x05D0;&#x05D1;" CacheMode="BitmapCache" Width="100">
        <TextBox.RenderTransform>
          <TransformGroup>
            <ScaleTransform ScaleX="2" ScaleY="2" />
            <RotateTransform Angle="15" />
          </TransformGroup>
        </TextBox.RenderTransform>
      </TextBox>
    </Canvas>
  </Border>
  <Border Grid.Column="0" Grid.Row="4">
    <TextBox Text="The quick brown" FlowDirection="RightToLeft" TextAlignment="Left"/>
  </Border>
  <Border Grid.Column="1" Grid.Row="4">
    <TextBox Text="The quick brown" FlowDirection="RightToLeft" TextAlignment="Left" CacheMode="BitmapCache" />
  </Border>
  <Border Grid.Column="2" Grid.Row="4">
    <TextBox Text="The quick brown" IsReadOnly="True" />
  </Border>
  <Border Grid.Column="3" Grid.Row="4">
    <TextBox Text="The quick brown" IsReadOnly="True" CacheMode="BitmapCache" />
  </Border>
  <Border Grid.Column="0" Grid.Row="5">
    <TextBox Text="The quick brown fox jumps over the lazy dog." TextWrapping="Wrap"/>
  </Border>
  <Border Grid.Column="1" Grid.Row="5">
    <TextBox Text="The quick brown fox jumps over the lazy dog." TextWrapping="Wrap" CacheMode="BitmapCache"/>
  </Border>
  <Border Grid.Column="2" Grid.Row="5">
    <TextBox Text="The quick brown fox jumps over the lazy dog." TextWrapping="Wrap" Height="50"/>
  </Border>
  <Border Grid.Column="3" Grid.Row="5">
    <TextBox Text="The quick brown fox jumps over the lazy dog." TextWrapping="Wrap" Height="50" CacheMode="BitmapCache"/>
  </Border>
  <Border Grid.Column="0" Grid.Row="6">
    <TextBox Text="The quick brown" IsEnabled="False" />
  </Border>
  <Border Grid.Column="1" Grid.Row="6">
    <TextBox Text="The quick brown" IsEnabled="False" CacheMode="BitmapCache" />
  </Border>
  <Border Grid.Column="2" Grid.Row="6">
    <TextBox Text="The quick brown" Foreground="Red" Background="DarkGreen" BorderBrush="LightGreen" />
  </Border>
  <Border Grid.Column="3" Grid.Row="6">
    <TextBox Text="The quick brown" Foreground="Red" Background="DarkGreen" BorderBrush="LightGreen" CacheMode="BitmapCache" />
  </Border>
  <Border Grid.Column="0" Grid.Row="7">
    <TextBox Text="The quick brown" FontSize="36" />
  </Border>
  <Border Grid.Column="1" Grid.Row="7">
    <TextBox Text="The quick brown" FontSize="36" CacheMode="BitmapCache" />
  </Border>
  <Border Grid.Column="2" Grid.Row="7">
    <TextBox Text="The quick brown" Height="50" />
  </Border>
  <Border Grid.Column="3" Grid.Row="7">
    <TextBox Text="The quick brown" Height="50" CacheMode="BitmapCache" />
  </Border>
  <Border Grid.Column="0" Grid.Row="8">
    <TextBlock FontFamily="Arial">
      The <Span Foreground="{StaticResource brushLGB}">quick brown</Span> fox
    </TextBlock>
  </Border>
  <Border Grid.Column="1" Grid.Row="8">
    <TextBlock FontFamily="Arial" CacheMode="BitmapCache">
      The <Span Foreground="{StaticResource brushLGB}">quick brown</Span> fox
    </TextBlock>
  </Border>
  <Border Grid.Column="2" Grid.Row="8">
    <RichTextBlock FontFamily="Arial">
      <Paragraph>
        The <Span Foreground="{StaticResource brushLGB}">quick brown</Span> fox
      </Paragraph>
    </RichTextBlock>
  </Border>
  <Border Grid.Column="3" Grid.Row="8">
    <RichTextBlock FontFamily="Arial" CacheMode="BitmapCache">
      <Paragraph>
        The <Span Foreground="{StaticResource brushLGB}">quick brown</Span> fox
      </Paragraph>
    </RichTextBlock>
  </Border>
  <Border Grid.Column="0" Grid.Row="9">
    <TextBlock FontFamily="Arial" FontSize="16" Text="The quick brown fox jumps over the lazy dog." TextAlignment="Right" TextWrapping="Wrap" Foreground="{StaticResource brushLGB}" />
  </Border>
  <Border Grid.Column="1" Grid.Row="9">
    <TextBlock FontFamily="Arial" FontSize="16" Text="The quick brown fox jumps over the lazy dog." TextAlignment="Right" TextWrapping="Wrap" Foreground="{StaticResource brushLGB}" CacheMode="BitmapCache"/>
  </Border>
  <Border Grid.Column="2" Grid.Row="9">
    <RichTextBlock FontFamily="Arial" FontSize="16" Foreground="{StaticResource brushLGB}" TextAlignment="Right">
      <Paragraph>The quick brown fox jumps over the lazy dog.</Paragraph>
    </RichTextBlock>
  </Border>
  <Border Grid.Column="3" Grid.Row="9">
    <RichTextBlock FontFamily="Arial" FontSize="16" Foreground="{StaticResource brushLGB}" TextAlignment="Right" CacheMode="BitmapCache">
      <Paragraph>The quick brown fox jumps over the lazy dog.</Paragraph>
    </RichTextBlock>
  </Border>
</Grid>
