    <Rectangle Fill="Red" Width="120" Height="120"/>
    <Rectangle Fill="Yellow" Width="120" Height="120"/>
    <Rectangle Fill="Blue" Width="120" Height="120"/>
    <Rectangle Fill="Green" Width="120" Height="120"/>
    <Rectangle Fill="Red" Width="120" Height="120"/>
    <Rectangle Fill="Yellow" Width="120" Height="120"/>
    <Rectangle Fill="Blue" Width="120" Height="120"/>
    <Rectangle Fill="Green" Width="120" Height="120"/>
    <Rectangle Fill="Red" Width="120" Height="120"/>
    <Rectangle Fill="Yellow" Width="120" Height="120"/>
    <Rectangle Fill="Blue" Width="120" Height="120"/>
    <Rectangle Fill="Green" Width="120" Height="120"/>
    <Rectangle Fill="Red" Width="120" Height="120"/>
