<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid.Resources>
    <Style TargetType="TextBox">
      <Setter Property="Padding" Value="10,3,6,5"/>
    </Style>
  </Grid.Resources>
  <GridView
    x:Name="gridView"
    Background="Magenta"
    Height="380" Width="380"
    Margin="10"
    ScrollViewer.HorizontalScrollBarVisibility="Auto"
    ScrollViewer.VerticalScrollBarVisibility="Disabled"
    ScrollViewer.HorizontalScrollMode="Enabled"
    ScrollViewer.IsHorizontalRailEnabled="True"
    ScrollViewer.VerticalScrollMode="Disabled"
    ScrollViewer.IsVerticalRailEnabled="False">
    <GridView.ItemsPanel>
      <ItemsPanelTemplate>
        <ItemsWrapGrid Orientation="Vertical" />
      </ItemsPanelTemplate>
    </GridView.ItemsPanel>
    <GridView.Header>
      <StackPanel
        Margin="10"
        Background="Cyan"
        VerticalAlignment="Center">
        <TextBlock FontSize="15" Text="Header Top"/>
        <TextBox FontSize="15" Text="Header Middle"/>
        <TextBlock FontSize="15" Text="Header Bottom"/>
      </StackPanel>
    </GridView.Header>
    <GridView.Footer>
      <StackPanel
        Margin="10"
        Background="Violet"
        VerticalAlignment="Center">
        <TextBlock FontSize="15" Text="Footer Top"/>
        <TextBox FontSize="15" Text="Footer Middle"/>
        <TextBlock FontSize="15" Text="Footer Bottom"/>
      </StackPanel>
    </GridView.Footer>
    <Rectangle Fill="Blue" Width="120" Height="120"/>
    <Rectangle Fill="Green" Width="120" Height="120"/>
    <Rectangle Fill="Red" Width="120" Height="120"/>
    <Rectangle Fill="Yellow" Width="120" Height="120"/>
