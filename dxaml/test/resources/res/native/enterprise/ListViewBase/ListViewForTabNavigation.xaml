<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Button
      x:Name="BeforeButton"
      Content="Before Button"
      Tag="B"/>

    <StackPanel Grid.Row="1">
      <ListView x:Name="MainListView" Visibility="Collapsed">
        <ListView.Header>
          <Button Visibility="Collapsed" Tag="H" Content="MainListView Header"/>
        </ListView.Header>
        <ListView.Footer>
          <Button Visibility="Collapsed" Tag="F" Content="MainListView Footer"/>
        </ListView.Footer>
        <ListView.ItemContainerStyle>
          <Style TargetType="ListViewItem">
            <Setter Property="IsTabStop" Value="False"/>
          </Style>
        </ListView.ItemContainerStyle>
        <ListView.ItemTemplate>
          <DataTemplate>
            <StackPanel>
              <Button Content="{Binding}" Tag="{Binding}"/>
              <ListView SelectionMode="None">
                <ListView.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                  </ItemsPanelTemplate>
                </ListView.ItemsPanel>
                <ListView.ItemContainerStyle>
                  <Style TargetType="ListViewItem">
                    <Setter Property="IsTabStop" Value="False"/>
                  </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                  <DataTemplate>
                    <Button Content="{Binding}" Tag="{Binding}"/>
                  </DataTemplate>
                </ListView.ItemTemplate>
                <x:String>.1</x:String>
                <x:String>.2</x:String>
                <x:String>.3</x:String>
              </ListView>
            </StackPanel>
          </DataTemplate>
        </ListView.ItemTemplate>
        <x:String>1</x:String>
        <x:String>2</x:String>
        <x:String>3</x:String>
      </ListView>
      
      <ListView x:Name="MainVirtualizedListView" SelectionMode="None" Visibility="Collapsed" TabNavigation="Local" MaxHeight="250">
        <ListView.ItemsPanel>
          <ItemsPanelTemplate>
            <ItemsStackPanel CacheLength="1"/>
          </ItemsPanelTemplate>
        </ListView.ItemsPanel>
        <ListView.ItemContainerStyle>
          <Style TargetType="ListViewItem">
            <Setter Property="IsTabStop" Value="False"/>
          </Style>
        </ListView.ItemContainerStyle>
        <ListView.ItemTemplate>
          <DataTemplate>
            <StackPanel>
              <Button Content="{Binding}" Tag="{Binding}"/>
              <ListView SelectionMode="None" SingleSelectionFollowsFocus="False">
                <ListView.ItemsPanel>
                  <ItemsPanelTemplate>
                    <ItemsWrapGrid
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        MaximumRowsOrColumns="1"
                        Orientation="Vertical"/>
                  </ItemsPanelTemplate>
                </ListView.ItemsPanel>
                <ListView.ItemContainerStyle>
                  <Style TargetType="ListViewItem">
                    <Setter Property="IsTabStop" Value="False"/>
                  </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                  <DataTemplate>
                    <Button Content="{Binding}" Tag="{Binding}"/>
                  </DataTemplate>
                </ListView.ItemTemplate>
                <x:String>.1</x:String>
                <x:String>.2</x:String>
                <x:String>.3</x:String>
              </ListView>
            </StackPanel>
          </DataTemplate>
        </ListView.ItemTemplate>
        <x:String>1</x:String>
        <x:String>2</x:String>
        <x:String>3</x:String>
        <x:String>4</x:String>
        <x:String>5</x:String>
        <x:String>6</x:String>
        <x:String>7</x:String>
        <x:String>8</x:String>
        <x:String>9</x:String>
        <x:String>10</x:String>
        <x:String>11</x:String>
        <x:String>12</x:String>
        <x:String>13</x:String>
        <x:String>14</x:String>
        <x:String>15</x:String>
      </ListView>

      <ListView x:Name="MainListViewWithVirtualizingStackPanel" Visibility="Collapsed">
        <ListView.Header>
          <Button Visibility="Collapsed" Tag="H" Content="MainListView Header"/>
        </ListView.Header>
        <ListView.Footer>
          <Button Visibility="Collapsed" Tag="F" Content="MainListView Footer"/>
        </ListView.Footer>
        <ListView.ItemContainerStyle>
          <Style TargetType="ListViewItem">
            <Setter Property="IsTabStop" Value="False"/>
          </Style>
        </ListView.ItemContainerStyle>
        <ListView.ItemTemplate>
          <DataTemplate>
            <StackPanel>
              <Button Content="{Binding}" Tag="{Binding}"/>
              <ListView SelectionMode="None">
                <ListView.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                  </ItemsPanelTemplate>
                </ListView.ItemsPanel>
                <ListView.ItemContainerStyle>
                  <Style TargetType="ListViewItem">
                    <Setter Property="IsTabStop" Value="False"/>
                  </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                  <DataTemplate>
                    <Button Content="{Binding}" Tag="{Binding}"/>
                  </DataTemplate>
                </ListView.ItemTemplate>
                <x:String>.1</x:String>
                <x:String>.2</x:String>
                <x:String>.3</x:String>
              </ListView>
            </StackPanel>
          </DataTemplate>
        </ListView.ItemTemplate>
        <ListView.ItemsPanel>
          <ItemsPanelTemplate>
            <VirtualizingStackPanel/>
          </ItemsPanelTemplate>
        </ListView.ItemsPanel>
        <x:String>1</x:String>
        <x:String>2</x:String>
        <x:String>3</x:String>
      </ListView>

      <ListView x:Name="MainListViewWithStackPanel" Visibility="Collapsed">
        <ListView.Header>
          <Button Visibility="Collapsed" Tag="H" Content="MainListView Header"/>
        </ListView.Header>
        <ListView.Footer>
          <Button Visibility="Collapsed" Tag="F" Content="MainListView Footer"/>
        </ListView.Footer>
        <ListView.ItemContainerStyle>
          <Style TargetType="ListViewItem">
            <Setter Property="IsTabStop" Value="False"/>
          </Style>
        </ListView.ItemContainerStyle>
        <ListView.ItemTemplate>
          <DataTemplate>
            <StackPanel>
              <Button Content="{Binding}" Tag="{Binding}"/>
              <ListView SelectionMode="None">
                <ListView.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                  </ItemsPanelTemplate>
                </ListView.ItemsPanel>
                <ListView.ItemContainerStyle>
                  <Style TargetType="ListViewItem">
                    <Setter Property="IsTabStop" Value="False"/>
                  </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                  <DataTemplate>
                    <Button Content="{Binding}" Tag="{Binding}"/>
                  </DataTemplate>
                </ListView.ItemTemplate>
                <x:String>.1</x:String>
                <x:String>.2</x:String>
                <x:String>.3</x:String>
              </ListView>
            </StackPanel>
          </DataTemplate>
        </ListView.ItemTemplate>
        <ListView.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel/>
          </ItemsPanelTemplate>
        </ListView.ItemsPanel>
        <x:String>1</x:String>
        <x:String>2</x:String>
        <x:String>3</x:String>
      </ListView>

      <ListView x:Name="MainListViewWithNestedButtons" SelectionMode="None" Visibility="Collapsed" TabNavigation="Local" MaxHeight="250">
        <ListView.ItemContainerStyle>
          <Style TargetType="ListViewItem">
            <Setter Property="IsTabStop" Value="False"/>
          </Style>
        </ListView.ItemContainerStyle>
        <ListView.ItemTemplate>
          <DataTemplate>
            <Grid RowDefinitions="Auto, Auto">
              <TextBlock Text="{Binding}"/>
              <GridView
                  Grid.Row="1"
                  SelectionMode="None"
                  SingleSelectionFollowsFocus="False"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.HorizontalScrollMode="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Disabled"
                  ScrollViewer.VerticalScrollMode="Disabled">
                <GridView.ItemsPanel>
                  <ItemsPanelTemplate>
                    <ItemsWrapGrid
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        MaximumRowsOrColumns="1"
                        Orientation="Vertical"/>
                  </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemTemplate>
                  <DataTemplate>
                    <Grid Width="80" Height="50">
                      <TextBlock
                          HorizontalTextAlignment="Center"
                          VerticalAlignment="Top"
                          Text="{Binding}"/>
                      <Button
                          HorizontalAlignment="Center"
                          VerticalAlignment="Bottom"
                          Content="{Binding}" Tag="{Binding}"/>
                    </Grid>
                  </DataTemplate>
                </GridView.ItemTemplate>

                <x:String>one</x:String>
                <x:String>two</x:String>
                <x:String>three</x:String>
              </GridView>
            </Grid>
          </DataTemplate>
        </ListView.ItemTemplate>

        <x:String>First Nested GridView</x:String>
        <x:String>Second Nested GridView</x:String>
        <x:String>Third Nested GridView</x:String>
      </ListView>
    </StackPanel>

    <Button
      x:Name="AfterButton"
      Content="After Button"
      Tag="A"
      Grid.Row="2"/>
  </Grid>
</Page>

