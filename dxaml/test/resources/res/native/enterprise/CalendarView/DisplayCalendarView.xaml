                                                <LinearDoubleKeyFrame KeyTime="0:0:0.200" Value="0" />
                                                <SplineDoubleKeyFrame KeyTime="0:0:0.500" Value="1" KeySpline="{StaticResource ControlFastOutSlowInKeySpline}" />
