<StackPanel
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    Orientation="Horizontal"
    Margin="5">
        <StackPanel Orientation="Vertical">
            <Button x:Name="BackButtonN1" Style="{StaticResource NavigationBackButtonNormalStyle}"/>
            <Button x:Name="BackButtonN2" Style="{StaticResource NavigationBackButtonNormalStyle}"/>
            <Button x:Name="BackButtonN3" Style="{StaticResource NavigationBackButtonNormalStyle}"/>
            <Button x:Name="BackButtonN4" Style="{StaticResource NavigationBackButtonNormalStyle}"/>
        </StackPanel>
        <StackPanel Orientation="Vertical" Margin="5,0,0,0">
            <Button x:Name="BackButtonS1" Style="{StaticResource NavigationBackButtonSmallStyle}"/>
            <Button x:Name="BackButtonS2" Style="{StaticResource NavigationBackButtonSmallStyle}"/>
            <Button x:Name="BackButtonS3" Style="{StaticResource NavigationBackButtonSmallStyle}"/>
            <Button x:Name="BackButtonS4" Style="{StaticResource NavigationBackButtonSmallStyle}"/>
        </StackPanel>
</StackPanel>
