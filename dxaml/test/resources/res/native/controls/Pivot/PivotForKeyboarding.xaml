<StackPanel xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Button Name="B0" Content="Button outside before Pivot" />
    <Pivot Name="P">
        <Pivot.Title>
          <Button Name="T">Test Pivot</Button>
        </Pivot.Title>
        <Pivot.LeftHeader>
          <Button Name="LH">Left Header</Button>
        </Pivot.LeftHeader>
        <Pivot.RightHeader>
          <Button Name="RH">Right Header</Button>
        </Pivot.RightHeader>
        <PivotItem Header="Test PivotItem1">
            <StackPanel Margin="20">
                <Button Name="B1" Content="Button for PivotItem1" />
            </StackPanel>
        </PivotItem>
        <PivotItem Header="Test PivotItem2">
            <StackPanel Margin="20">
                <Button Name="B2" Content="Button for PivotItem2" />
            </StackPanel>
        </PivotItem>
        <PivotItem Header="Test PivotItem3">
            <StackPanel Margin="20">
                <Button Name="B3" Content="Button for PivotItem3" />
            </StackPanel>
        </PivotItem>
    </Pivot>
    <Button Name="B4" Content="Button outside after Pivot" />
</StackPanel>