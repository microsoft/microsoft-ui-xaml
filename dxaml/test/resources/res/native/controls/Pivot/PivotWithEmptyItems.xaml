<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid.Resources>
        <Style TargetType="PivotItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PivotItem">
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Grid.Resources>
    <StackPanel>
        <Pivot Name="P">
            <PivotItem Header="Item 1">
            </PivotItem>
            <PivotItem Header="Item 2">
                <TextBox />
            </PivotItem>
        </Pivot>
    </StackPanel>
    <Button Name="B" Content="Button outside after Pivot" />
</Grid>