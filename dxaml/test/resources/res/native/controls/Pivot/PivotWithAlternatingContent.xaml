<StackPanel xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Button Content="Button for initial focus" />
    <Pivot x:Name="Pivot" Title="Test Pivot" Width="150">
        <PivotItem Header="Test PivotItem1">
            <StackPanel Margin="20">
                <TextBox TextWrapping="NoWrap" Text="Test SampleText for PivotItem1" />
            </StackPanel>
        </PivotItem>
        <PivotItem Header="Test PivotItem2">
            <StackPanel Margin="20">
                <TextBlock TextWrapping="Wrap" Text="Test SampleText for PivotItem2" />
            </StackPanel>
        </PivotItem>
        <PivotItem Header="Test PivotItem3">
            <StackPanel Margin="20">
                <TextBox TextWrapping="NoWrap" Text="Test SampleText for PivotItem3" />
            </StackPanel>
        </PivotItem>
        <PivotItem Header="Test PivotItem4">
            <StackPanel Margin="20">
                <TextBlock TextWrapping="Wrap" Text="Test SampleText for PivotItem4" />
            </StackPanel>
        </PivotItem>
    </Pivot>
</StackPanel>