<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
      <Grid x:Name='root' xmlns='http://schemas.microsoft.com/winfx/2006/xaml/presentation' xmlns:x='http://schemas.microsoft.com/winfx/2006/xaml' Background='Red'>
        <Grid.Resources>
          <Style x:Key='testStyle' TargetType='Button'>
            <Setter Property='BorderThickness' Value='{ThemeResource ButtonBorderThemeThickness}'/>
            <Setter Property='Background' Value='Green' />
          </Style>
        </Grid.Resources>
        <Button x:Name='button' Style='{StaticResource testStyle}' />
      </Grid>
</Page>