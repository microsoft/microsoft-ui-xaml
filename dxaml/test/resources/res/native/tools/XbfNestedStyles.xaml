<Page
    xmlns='http://schemas.microsoft.com/winfx/2006/xaml/presentation'
    xmlns:x='http://schemas.microsoft.com/winfx/2006/xaml'>

    <Page.Resources>
      <Style TargetType="ListView" x:Key="ListViewStyle1">
        <Setter Property="ItemContainerStyle">
          <Setter.Value>
            <Style TargetType="ListViewItem">
              <Setter Property="Background" Value="Blue" />
            </Style>
          </Setter.Value>
        </Setter>
      </Style>
    </Page.Resources>
    
    <ListView Style="{StaticResource ListViewStyle1}" x:Name="theView">
      <ListViewItem>Item1a</ListViewItem>
      <ListViewItem>Item1b</ListViewItem>
    </ListView>
    
</Page>