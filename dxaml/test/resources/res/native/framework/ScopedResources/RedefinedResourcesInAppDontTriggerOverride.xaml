<Application
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Application.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Key='ButtonBackground' Color='{StaticResource SystemAltHighColor}'/>"
            <SolidColorBrush x:Key='SystemControlForegroundBaseHighBrush' Color='{StaticResource SystemAltHighColor}'/>"
            <StaticResource x:Key='ButtonBorderBrush' ResourceKey='SystemControlBackgroundBaseLowBrush'/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
