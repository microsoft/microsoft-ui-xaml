<StackPanel xmlns='http://schemas.microsoft.com/winfx/2006/xaml/presentation'
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel.Resources>
        <x:String x:Key="ReusableLevelString01" >Blue</x:String>
        <x:String x:Key="ReusableLevelString02" >Green</x:String>
        <SolidColorBrush x:Key="ReusableColorlevel0101" Color="{StaticResource ResourceKey=ReusableLevelString01}" />
        <SolidColorBrush x:Key="ReusableColorLevel0102" Color="{StaticResource ResourceKey=ReusableLevelString02}" />
    </StackPanel.Resources>

    <Grid x:Name="MainGrid">
        <Grid.Resources>
            <ResourceDictionary x:Key="TestRD">
                <x:String x:Key="AppRes01">AppRes01 Redef MainPageGrid</x:String>
            </ResourceDictionary>
        </Grid.Resources>
        <ScrollViewer>
            <StackPanel x:Name="mainPageItemPanel">
                <StackPanel.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Foreground" Value="{StaticResource ResourceKey=ReusableColorlevel0101}" />
                        <Setter Property="Content" Value="TargetTypeResource" />
                    </Style>
                    <Style x:Key="MultiLevelResource" TargetType="Button">
                        <Setter Property="Foreground" Value="{StaticResource ResourceKey=ReusableColorLevel0102}" />
                        <Setter Property="Content" Value="MultiLevelResource" />
                    </Style>
                </StackPanel.Resources>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</StackPanel>