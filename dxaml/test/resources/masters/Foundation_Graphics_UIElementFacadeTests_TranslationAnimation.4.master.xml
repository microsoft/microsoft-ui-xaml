<?xml version="1.0" encoding="UTF-8"?>
<CompositionTarget>
  <Visual>
    <Visual />
    <Visual />
    <Visual Tag="PrependVisual">
      <Visual Tag="PrimaryVisual" SizeX="400" SizeY="300">
        <Visual Tag="ContentVisual">
          <Visual Tag="PrependVisual">
            <TransformMatrix>
              <ExpressionAnimation String="Matrix4x4.CreateFromTranslation(PS.Translation) * prependVisual.PrependTransform">
                <ReferenceParameter Name="PS">
                  <PropertySet>
                    <Property Name="Translation" Type="Vector3">
                      <KeyFrameAnimation Duration="1000">
                        <KeyFrame Time="1" X="100" Y="200" />
                      </KeyFrameAnimation>
                    </Property>
                  </PropertySet>
                </ReferenceParameter>
                <ReferenceParameter Name="prependVisual" />
              </ExpressionAnimation>
            </TransformMatrix>
            <Visual Tag="PrimaryVisual" SizeX="100" SizeY="100">
              <Visual Tag="ContentVisual">
                <wucSpriteVisual SizeX="100" SizeY="100" BorderMode="Soft">
                  <ColorBrush Color="rgb {0.502, 0, 0.502}" />
                </wucSpriteVisual>
              </Visual>
            </Visual>
          </Visual>
        </Visual>
      </Visual>
    </Visual>
  </Visual>
</CompositionTarget>