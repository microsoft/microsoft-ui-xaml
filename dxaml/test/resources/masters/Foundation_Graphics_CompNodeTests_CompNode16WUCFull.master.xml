<?xml version="1.0" encoding="UTF-8"?>
<CompositionTarget>
  <Visual>
    <Visual />
    <Visual />
    <Visual Tag="PrependVisual">
      <Visual Tag="PrimaryVisual" SizeX="400" SizeY="400">
        <Visual Tag="ContentVisual">
          <Visual Tag="PrependVisual" SizeX="400" SizeY="400">
            <Clip ClipLeft="0" ClipTop="0" ClipRight="0" ClipBottom="0" TransformMatrix="Identity" />
            <Visual PixelSnappingEnabled="True" Tag="PrimaryVisual" SizeX="400" SizeY="400">
              <TransformMatrix>
                <ExpressionAnimation String="Matrix4x4.CreateFromTranslation(V.Offset) * LOCAL.DManip * Matrix4x4.CreateFromTranslation(-V.Offset)">
                  <ReferenceParameter Name="LOCAL">
                    <PropertySet>
                      <Property Name="DManip" Type="Matrix4x4">
                        <ExpressionAnimation String="PS.Matrix">
                          <ReferenceParameter Name="PS">
                            <PropertySet>
                              <Property Name="Matrix" Type="Matrix4x4">
                                <ExpressionAnimation String="transform*manipTransform.Matrix">
                                  <ReferenceParameter Name="manipTransform">
                                    <DuplicatedMatrixTransform>
                                      <ManipulationTransform Transform="Identity" />
                                    </DuplicatedMatrixTransform>
                                  </ReferenceParameter>
                                  <Property Name="transform" Type="Matrix4x4" />
                                </ExpressionAnimation>
                              </Property>
                            </PropertySet>
                          </ReferenceParameter>
                        </ExpressionAnimation>
                      </Property>
                    </PropertySet>
                  </ReferenceParameter>
                  <ReferenceParameter Name="V" />
                </ExpressionAnimation>
              </TransformMatrix>
              <Visual Tag="ContentVisual">
                <wucSpriteVisual SizeX="400" SizeY="400" BorderMode="Soft">
                  <ColorBrush Color="Argb {0, 1, 1, 1}" />
                </wucSpriteVisual>
                <Visual Tag="PrependVisual">
                  <TransformMatrix>
                    <Translate X="20" Y="20" />
                  </TransformMatrix>
                  <Visual Tag="PrimaryVisual" CompositeMode="SourceOver" SizeX="10" SizeY="10">
                    <TransformMatrix>
                      <ExpressionAnimation String="Matrix4x4(LOCAL.Render)">
                        <ReferenceParameter Name="LOCAL">
                          <PropertySet>
                            <Property Name="Render" Type="Matrix3x2">
                              <ExpressionAnimation String="Matrix3x2.CreateFromTranslation(vector2(PS.X, PS.Y))">
                                <ReferenceParameter Name="PS" />
                                <PropertySet>
                                  <Property Name="X" Type="Scalar">
                                    <KeyFrameAnimation Duration="2">
                                      <KeyFrame />
                                      <KeyFrame Time="1" Value="100">
                                        <LinearEasingFunction />
                                      </KeyFrame>
                                    </KeyFrameAnimation>
                                  </Property>
                                  <Property Name="Y" Type="Scalar" />
                                </PropertySet>
                              </ExpressionAnimation>
                            </Property>
                          </PropertySet>
                        </ReferenceParameter>
                      </ExpressionAnimation>
                    </TransformMatrix>
                    <Visual Tag="ContentVisual">
                      <wucSpriteVisual SizeX="10" SizeY="10" BorderMode="Soft">
                        <ColorBrush Color="rgb {1, 0, 0}" />
                      </wucSpriteVisual>
                    </Visual>
                  </Visual>
                </Visual>
                <Visual Tag="PrependVisual">
                  <TransformMatrix>
                    <Translate X="20" Y="20" />
                  </TransformMatrix>
                  <Visual Tag="PrimaryVisual" CompositeMode="SourceOver" SizeX="200" SizeY="100" OffsetX="0" OffsetY="100" OffsetZ="0">
                    <Clip ClipLeft="0" ClipTop="0" ClipRight="190" ClipBottom="90">
                      <TransformMatrix>
                        <ExpressionAnimation String="Matrix3x2.CreateFromTranslation(vector2(PS.X, PS.Y))">
                          <ReferenceParameter Name="PS" />
                          <PropertySet>
                            <Property Name="X" Type="Scalar">
                              <KeyFrameAnimation Duration="2">
                                <KeyFrame />
                                <KeyFrame Time="1" Value="100">
                                  <LinearEasingFunction />
                                </KeyFrame>
                              </KeyFrameAnimation>
                            </Property>
                            <Property Name="Y" Type="Scalar" />
                          </PropertySet>
                        </ExpressionAnimation>
                      </TransformMatrix>
                    </Clip>
                    <Visual Tag="ContentVisual">
                      <wucSpriteVisual SizeX="200" SizeY="100" BorderMode="Soft">
                        <ColorBrush Color="rgb {0, 0.502, 0}" />
                      </wucSpriteVisual>
                    </Visual>
                  </Visual>
                </Visual>
              </Visual>
            </Visual>
          </Visual>
        </Visual>
      </Visual>
    </Visual>
  </Visual>
</CompositionTarget>