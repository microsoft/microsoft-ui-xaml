<?xml version="1.0" encoding="UTF-8"?>
<CompositionTarget>
  <Visual>
    <Visual />
    <Visual />
    <Visual Tag="PrependVisual">
      <Visual Tag="PrimaryVisual" SizeX="400" SizeY="300">
        <Visual Tag="ContentVisual">
          <Visual Tag="PrependVisual">
            <Visual Tag="PrimaryVisual" SizeX="30" SizeY="30" OffsetX="10" OffsetY="10" OffsetZ="0">
              <TransformMatrix>
                <ExpressionAnimation String="Matrix4x4(LOCAL.Render)">
                  <ReferenceParameter Name="LOCAL">
                    <PropertySet>
                      <Property Name="Render" Type="Matrix3x2">
                        <ExpressionAnimation String="PS.Expr0 * PS.Expr1 * PS.Expr2 * PS.Expr3 * PS.Expr4 * PS.Expr5">
                          <ReferenceParameter Name="PS" />
                          <PropertySet>
                            <Property Name="Expr0" Type="Matrix3x2">
                              <ExpressionAnimation String="Matrix3x2.CreateFromTranslation(vector2(PS.X, PS.Y))">
                                <ReferenceParameter Name="PS" />
                                <PropertySet>
                                  <Property Name="X" Type="Scalar">
                                    <KeyFrameAnimation Duration="60">
                                      <KeyFrame />
                                      <KeyFrame Time="1">
                                        <LinearEasingFunction />
                                      </KeyFrame>
                                    </KeyFrameAnimation>
                                  </Property>
                                  <Property Name="Y" Type="Scalar" Value="2" />
                                </PropertySet>
                              </ExpressionAnimation>
                            </Property>
                            <Property Name="Expr1" Type="Matrix3x2">
                              <ExpressionAnimation String="Matrix3x2.CreateFromTranslation(-vector2(PS.CenterX, PS.CenterY)) * Matrix3x2.CreateFromScale(vector2(PS.ScaleX, PS.ScaleY)) * Matrix3x2.CreateFromTranslation(vector2(PS.CenterX, PS.CenterY))">
                                <ReferenceParameter Name="PS" />
                                <PropertySet>
                                  <Property Name="CenterX" Type="Scalar" Value="2" />
                                  <Property Name="CenterY" Type="Scalar" Value="2" />
                                  <Property Name="ScaleX" Type="Scalar" Value="2" />
                                  <Property Name="ScaleY" Type="Scalar" Value="2" />
                                </PropertySet>
                              </ExpressionAnimation>
                            </Property>
                            <Property Name="Expr2" Type="Matrix3x2">
                              <ExpressionAnimation String="Matrix3x2.CreateSkew(PS.SkewAngleX * pi / 180.0f, PS.SkewAngleY * pi / 180.0f, Vector2(PS.CenterX, PS.CenterY))">
                                <ReferenceParameter Name="PS" />
                                <PropertySet>
                                  <Property Name="CenterX" Type="Scalar" Value="2" />
                                  <Property Name="CenterY" Type="Scalar" Value="2" />
                                  <Property Name="SkewAngleX" Type="Scalar" Value="2" />
                                  <Property Name="SkewAngleY" Type="Scalar" Value="2" />
                                </PropertySet>
                              </ExpressionAnimation>
                            </Property>
                            <Property Name="Expr3" Type="Matrix3x2">
                              <ExpressionAnimation String="Matrix3x2.CreateFromTranslation(-vector2(PS.CenterX, PS.CenterY)) * Matrix3x2(cos(PS.RotateAngle * pi / 180.0f), sin(PS.RotateAngle * pi / 180.0f), -sin(PS.RotateAngle * pi / 180.0f), cos(PS.RotateAngle * pi / 180.0f), 0, 0) * Matrix3x2.CreateFromTranslation(vector2(PS.CenterX, PS.CenterY))">
                                <ReferenceParameter Name="PS" />
                                <PropertySet>
                                  <Property Name="CenterX" Type="Scalar" Value="2" />
                                  <Property Name="CenterY" Type="Scalar" Value="2" />
                                  <Property Name="RotateAngle" Type="Scalar" Value="2" />
                                </PropertySet>
                              </ExpressionAnimation>
                            </Property>
                            <Property Name="Expr4" Type="Matrix3x2">
                              <ExpressionAnimation String="Matrix3x2.CreateFromTranslation(-vector2(PS.CenterX, PS.CenterY)) * PS.Scale * PS.Skew * PS.Rotate * Matrix3x2.CreateFromTranslation(vector2(PS.CenterX, PS.CenterY)) * PS.Translate">
                                <ReferenceParameter Name="PS" />
                                <PropertySet>
                                  <Property Name="CenterX" Type="Scalar" Value="1" />
                                  <Property Name="CenterY" Type="Scalar" Value="1" />
                                  <Property Name="Rotate" Type="Matrix3x2">
                                    <ExpressionAnimation String="Matrix3x2(cos(PS.RotateAngle * pi / 180.0f), sin(PS.RotateAngle * pi / 180.0f), -sin(PS.RotateAngle * pi / 180.0f), cos(PS.RotateAngle * pi / 180.0f), 0, 0)">
                                      <ReferenceParameter Name="PS" />
                                      <PropertySet>
                                        <Property Name="RotateAngle" Type="Scalar" Value="1" />
                                      </PropertySet>
                                    </ExpressionAnimation>
                                  </Property>
                                  <Property Name="Scale" Type="Matrix3x2" Value="Identity" />
                                  <Property Name="Skew" Type="Matrix3x2">
                                    <ExpressionAnimation String="Matrix3x2.CreateSkew(PS.SkewAngleX * pi / 180.0f, PS.SkewAngleY * pi / 180.0f, Vector2(0, 0))">
                                      <ReferenceParameter Name="PS" />
                                      <PropertySet>
                                        <Property Name="SkewAngleX" Type="Scalar" Value="1" />
                                        <Property Name="SkewAngleY" Type="Scalar" Value="1" />
                                      </PropertySet>
                                    </ExpressionAnimation>
                                  </Property>
                                  <Property Name="Translate" Type="Matrix3x2">
                                    <ExpressionAnimation String="Matrix3x2.CreateFromTranslation(vector2(PS.X, PS.Y))">
                                      <ReferenceParameter Name="PS" />
                                      <PropertySet>
                                        <Property Name="X" Type="Scalar" Value="2" />
                                        <Property Name="Y" Type="Scalar" Value="2" />
                                      </PropertySet>
                                    </ExpressionAnimation>
                                  </Property>
                                </PropertySet>
                              </ExpressionAnimation>
                            </Property>
                            <Property Name="Expr5" Type="Matrix3x2">
                              <ExpressionAnimation String="Matrix3x2(PS.M11, PS.M12, PS.M21, PS.M22, PS.Tx, PS.Ty)">
                                <ReferenceParameter Name="PS" />
                                <PropertySet>
                                  <Property Name="M11" Type="Scalar" Value="1" />
                                  <Property Name="M12" Type="Scalar" Value="2" />
                                  <Property Name="M21" Type="Scalar" Value="3" />
                                  <Property Name="M22" Type="Scalar" Value="4" />
                                  <Property Name="Tx" Type="Scalar" Value="5" />
                                  <Property Name="Ty" Type="Scalar" Value="6" />
                                </PropertySet>
                              </ExpressionAnimation>
                            </Property>
                          </PropertySet>
                        </ExpressionAnimation>
                      </Property>
                    </PropertySet>
                  </ReferenceParameter>
                </ExpressionAnimation>
              </TransformMatrix>
              <Visual Tag="ContentVisual">
                <wucSpriteVisual SizeX="30" SizeY="30" BorderMode="Soft">
                  <ColorBrush Color="#ffffffff" />
                </wucSpriteVisual>
              </Visual>
            </Visual>
          </Visual>
          <Visual Tag="PrependVisual">
            <Visual Tag="PrimaryVisual" SizeX="30" SizeY="30" OffsetX="10" OffsetY="60" OffsetZ="0">
              <TransformMatrix>
                <ExpressionAnimation String="LOCAL.Projection">
                  <ReferenceParameter Name="LOCAL">
                    <PropertySet>
                      <Property Name="Projection" Type="Matrix4x4">
                        <ExpressionAnimation String="PS.LocalXYZ * PS.Rotation * PS.GlobalXYZ * PS.Perspective">
                          <ReferenceParameter Name="PS" />
                          <PropertySet>
                            <Property Name="GlobalXYZ" Type="Matrix4x4">
                              <ExpressionAnimation String="Matrix4x4.CreateFromTranslation(vector3(PS.X, PS.Y, PS.Z))">
                                <ReferenceParameter Name="PS" />
                                <PropertySet>
                                  <Property Name="X" Type="Scalar" Value="1" />
                                  <Property Name="Y" Type="Scalar" Value="1" />
                                  <Property Name="Z" Type="Scalar" Value="1" />
                                </PropertySet>
                              </ExpressionAnimation>
                            </Property>
                            <Property Name="LocalXYZ" Type="Matrix4x4">
                              <ExpressionAnimation String="Matrix4x4.CreateFromTranslation(vector3(PS.X, PS.Y, PS.Z))">
                                <ReferenceParameter Name="PS" />
                                <PropertySet>
                                  <Property Name="X" Type="Scalar" Value="1" />
                                  <Property Name="Y" Type="Scalar" Value="1" />
                                  <Property Name="Z" Type="Scalar" Value="1" />
                                </PropertySet>
                              </ExpressionAnimation>
                            </Property>
                            <Property Name="Perspective" Type="Matrix4x4">
                              <ExpressionAnimation String="Matrix4x4.CreateFromTranslation(vector3(PS.Width / -2, PS.Height / -2, 0)) * PS.PerspectiveMatrix * Matrix4x4.CreateFromTranslation(vector3(PS.Width / 2, PS.Height / 2, 0))">
                                <ReferenceParameter Name="PS" />
                                <PropertySet>
                                  <Property Name="Height" Type="Scalar" Value="30" />
                                  <Property Name="PerspectiveMatrix" Type="Matrix4x4">
                                    <Value>
                                      <Row1 M11="1000" M12="0" M13="0" M14="0" />
                                      <Row2 M21="0" M22="1000" M13="0" M14="0" />
                                      <Row3 M31="0" M32="0" M33="-1.001" M34="-1" />
                                      <Row4 M41="0" M42="0" M43="999" M44="999" />
                                    </Value>
                                  </Property>
                                  <Property Name="Width" Type="Scalar" Value="30" />
                                </PropertySet>
                              </ExpressionAnimation>
                            </Property>
                            <Property Name="Rotation" Type="Matrix4x4">
                              <ExpressionAnimation String="PS.RotateCenter * PS.RotateX * PS.RotateY * PS.RotateZ * PS.UndoRotateCenter">
                                <ReferenceParameter Name="PS" />
                                <PropertySet>
                                  <Property Name="RotateCenter" Type="Matrix4x4">
                                    <ExpressionAnimation String="Matrix4x4.CreateFromScale(vector3(-1 / PS.Width, -1 / PS.Height, 1)) * Matrix4x4.CreateFromTranslation(vector3(PS.CenterX, PS.CenterY, 0)) * Matrix4x4.CreateFromScale(vector3(-PS.Width, -PS.Height, 1))">
                                      <ReferenceParameter Name="PS" />
                                      <PropertySet>
                                        <Property Name="CenterX" Type="Scalar">
                                          <KeyFrameAnimation Duration="60">
                                            <KeyFrame />
                                            <KeyFrame Time="1">
                                              <LinearEasingFunction />
                                            </KeyFrame>
                                          </KeyFrameAnimation>
                                        </Property>
                                        <Property Name="CenterY" Type="Scalar" Value="1" />
                                        <Property Name="Height" Type="Scalar" Value="30" />
                                        <Property Name="Width" Type="Scalar" Value="30" />
                                      </PropertySet>
                                    </ExpressionAnimation>
                                  </Property>
                                  <Property Name="RotateX" Type="Matrix4x4">
                                    <ExpressionAnimation String="Matrix4x4.CreateFromTranslation(-vector3(PS.CenterX, PS.CenterY, PS.CenterZ))* Matrix4x4.CreateFromAxisAngle(vector3(-1, 0, 0), PS.RotateAngle * pi / 180.0f) * Matrix4x4.CreateFromTranslation(vector3(PS.CenterX, PS.CenterY, PS.CenterZ))">
                                      <ReferenceParameter Name="PS" />
                                      <PropertySet>
                                        <Property Name="CenterX" Type="Scalar" />
                                        <Property Name="CenterY" Type="Scalar" />
                                        <Property Name="CenterZ" Type="Scalar" Value="1" />
                                        <Property Name="RotateAngle" Type="Scalar" Value="1" />
                                      </PropertySet>
                                    </ExpressionAnimation>
                                  </Property>
                                  <Property Name="RotateY" Type="Matrix4x4">
                                    <ExpressionAnimation String="Matrix4x4.CreateFromTranslation(-vector3(PS.CenterX, PS.CenterY, PS.CenterZ))* Matrix4x4.CreateFromAxisAngle(vector3(0, -1, 0), PS.RotateAngle * pi / 180.0f) * Matrix4x4.CreateFromTranslation(vector3(PS.CenterX, PS.CenterY, PS.CenterZ))">
                                      <ReferenceParameter Name="PS" />
                                      <PropertySet>
                                        <Property Name="CenterX" Type="Scalar" />
                                        <Property Name="CenterY" Type="Scalar" />
                                        <Property Name="CenterZ" Type="Scalar" Value="1" />
                                        <Property Name="RotateAngle" Type="Scalar" Value="1" />
                                      </PropertySet>
                                    </ExpressionAnimation>
                                  </Property>
                                  <Property Name="RotateZ" Type="Matrix4x4">
                                    <ExpressionAnimation String="Matrix4x4.CreateFromTranslation(-vector3(PS.CenterX, PS.CenterY, PS.CenterZ))* Matrix4x4.CreateFromAxisAngle(vector3(0, 0, -1), PS.RotateAngle * pi / 180.0f) * Matrix4x4.CreateFromTranslation(vector3(PS.CenterX, PS.CenterY, PS.CenterZ))">
                                      <ReferenceParameter Name="PS" />
                                      <PropertySet>
                                        <Property Name="CenterX" Type="Scalar" />
                                        <Property Name="CenterY" Type="Scalar" />
                                        <Property Name="CenterZ" Type="Scalar" Value="1" />
                                        <Property Name="RotateAngle" Type="Scalar" Value="1" />
                                      </PropertySet>
                                    </ExpressionAnimation>
                                  </Property>
                                  <Property Name="UndoRotateCenter" Type="Matrix4x4">
                                    <ExpressionAnimation String="Matrix4x4.CreateFromScale(vector3(1 / PS.Width, 1 / PS.Height, 1)) * Matrix4x4.CreateFromTranslation(vector3(PS.CenterX, PS.CenterY, 0)) * Matrix4x4.CreateFromScale(vector3(PS.Width, PS.Height, 1))">
                                      <ReferenceParameter Name="PS" />
                                      <PropertySet>
                                        <Property Name="CenterX" Type="Scalar">
                                          <KeyFrameAnimation Duration="60">
                                            <KeyFrame />
                                            <KeyFrame Time="1">
                                              <LinearEasingFunction />
                                            </KeyFrame>
                                          </KeyFrameAnimation>
                                        </Property>
                                        <Property Name="CenterY" Type="Scalar" Value="1" />
                                        <Property Name="Height" Type="Scalar" Value="30" />
                                        <Property Name="Width" Type="Scalar" Value="30" />
                                      </PropertySet>
                                    </ExpressionAnimation>
                                  </Property>
                                </PropertySet>
                              </ExpressionAnimation>
                            </Property>
                          </PropertySet>
                        </ExpressionAnimation>
                      </Property>
                    </PropertySet>
                  </ReferenceParameter>
                </ExpressionAnimation>
              </TransformMatrix>
              <Visual Tag="ContentVisual">
                <wucSpriteVisual SizeX="30" SizeY="30" BorderMode="Soft">
                  <ColorBrush Color="#ffffffff" />
                </wucSpriteVisual>
              </Visual>
            </Visual>
          </Visual>
          <Visual Tag="PrependVisual">
            <Visual Tag="PrimaryVisual" SizeX="30" SizeY="30" OffsetX="60" OffsetY="60" OffsetZ="0">
              <TransformMatrix>
                <Row1 M11="1" M12="2" M13="3" M14="4" />
                <Row2 M21="5" M22="6" M13="7" M14="8" />
                <Row3 M31="9" M32="10" M33="11" M34="12" />
                <Row4 M41="13" M42="14" M43="15" M44="16" />
              </TransformMatrix>
              <Visual Tag="ContentVisual">
                <wucSpriteVisual SizeX="30" SizeY="30" BorderMode="Soft">
                  <ColorBrush Color="#ffffffff" />
                </wucSpriteVisual>
              </Visual>
            </Visual>
          </Visual>
          <Visual Tag="PrependVisual">
            <Visual Tag="PrimaryVisual" SizeX="30" SizeY="30" OffsetX="110" OffsetY="60" OffsetZ="0">
              <TransformMatrix>
                <ExpressionAnimation String="LOCAL.Transform3D">
                  <ReferenceParameter Name="LOCAL">
                    <PropertySet>
                      <Property Name="Transform3D" Type="Matrix4x4">
                        <ExpressionAnimation String="Matrix4x4.CreateFromTranslation(-vector3(PS.CenterX, PS.CenterY, PS.CenterZ)) * PS.Scale * PS.RotateX * PS.RotateY * PS.RotateZ * Matrix4x4.CreateFromTranslation(vector3(PS.CenterX, PS.CenterY, PS.CenterZ)) * PS.Translate">
                          <ReferenceParameter Name="PS" />
                          <PropertySet>
                            <Property Name="CenterX" Type="Scalar">
                              <KeyFrameAnimation Duration="60">
                                <KeyFrame />
                                <KeyFrame Time="1">
                                  <LinearEasingFunction />
                                </KeyFrame>
                              </KeyFrameAnimation>
                            </Property>
                            <Property Name="CenterY" Type="Scalar" Value="1" />
                            <Property Name="CenterZ" Type="Scalar" Value="1" />
                            <Property Name="RotateX" Type="Matrix4x4">
                              <ExpressionAnimation String="Matrix4x4.CreateFromAxisAngle(vector3(-1, 0, 0), PS.RotateAngle * pi / 180.0f)">
                                <ReferenceParameter Name="PS" />
                                <PropertySet>
                                  <Property Name="RotateAngle" Type="Scalar" Value="1" />
                                </PropertySet>
                              </ExpressionAnimation>
                            </Property>
                            <Property Name="RotateY" Type="Matrix4x4">
                              <ExpressionAnimation String="Matrix4x4.CreateFromAxisAngle(vector3(0, -1, 0), PS.RotateAngle * pi / 180.0f)">
                                <ReferenceParameter Name="PS" />
                                <PropertySet>
                                  <Property Name="RotateAngle" Type="Scalar" Value="1" />
                                </PropertySet>
                              </ExpressionAnimation>
                            </Property>
                            <Property Name="RotateZ" Type="Matrix4x4">
                              <ExpressionAnimation String="Matrix4x4.CreateFromAxisAngle(vector3(0, 0, -1), PS.RotateAngle * pi / 180.0f)">
                                <ReferenceParameter Name="PS" />
                                <PropertySet>
                                  <Property Name="RotateAngle" Type="Scalar" Value="1" />
                                </PropertySet>
                              </ExpressionAnimation>
                            </Property>
                            <Property Name="Scale" Type="Matrix4x4" />
                            <Property Name="Translate" Type="Matrix4x4">
                              <ExpressionAnimation String="Matrix4x4.CreateFromTranslation(vector3(PS.X, PS.Y, PS.Z))">
                                <ReferenceParameter Name="PS" />
                                <PropertySet>
                                  <Property Name="X" Type="Scalar" Value="1" />
                                  <Property Name="Y" Type="Scalar" Value="1" />
                                  <Property Name="Z" Type="Scalar" Value="1" />
                                </PropertySet>
                              </ExpressionAnimation>
                            </Property>
                          </PropertySet>
                        </ExpressionAnimation>
                      </Property>
                    </PropertySet>
                  </ReferenceParameter>
                </ExpressionAnimation>
              </TransformMatrix>
              <Visual Tag="ContentVisual">
                <wucSpriteVisual SizeX="30" SizeY="30" BorderMode="Soft">
                  <ColorBrush Color="#ffffffff" />
                </wucSpriteVisual>
              </Visual>
            </Visual>
          </Visual>
          <Visual Tag="PrependVisual">
            <Visual Tag="PrimaryVisual" SizeX="30" SizeY="30" OffsetX="160" OffsetY="60" OffsetZ="0">
              <TransformMatrix>
                <Row1 M11="1" M12="0" M13="0" M14="0" />
                <Row2 M21="0" M22="1" M13="0" M14="0" />
                <Row3 M31="-16" M32="-16" M33="1" M34="-1" />
                <Row4 M41="0" M42="0" M43="0" M44="1" />
              </TransformMatrix>
              <Visual Tag="ContentVisual">
                <wucSpriteVisual SizeX="30" SizeY="30" BorderMode="Soft">
                  <ColorBrush Color="#ffffffff" />
                </wucSpriteVisual>
              </Visual>
            </Visual>
          </Visual>
        </Visual>
      </Visual>
    </Visual>
  </Visual>
</CompositionTarget>