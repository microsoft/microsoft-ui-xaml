<?xml version="1.0" encoding="UTF-8"?>
<CompositionTarget>
  <Visual>
    <Visual />
    <Visual />
    <Visual Tag="PrependVisual">
      <Visual Tag="PrimaryVisual" SizeX="400" SizeY="300">
        <Visual Tag="ContentVisual">
          <wucSpriteVisual SizeX="400" SizeY="300" BorderMode="Soft">
            <ColorBrush Color="#ff000000" />
          </wucSpriteVisual>
          <Visual Tag="PrependVisual">
            <Visual Tag="PrimaryVisual" SizeX="50" SizeY="50">
              <Offset>
                <ExpressionAnimation String="Vector3(PS.X, PS.Y, 0)">
                  <ReferenceParameter Name="PS" />
                  <PropertySet>
                    <Property Name="X" Type="Scalar">
                      <KeyFrameAnimation Duration="10" IterationCount="2" Direction="Alternate">
                        <KeyFrame />
                        <KeyFrame Time="1" Value="100">
                          <LinearEasingFunction />
                        </KeyFrame>
                      </KeyFrameAnimation>
                    </Property>
                    <Property Name="Y" Type="Scalar" />
                  </PropertySet>
                </ExpressionAnimation>
              </Offset>
              <Visual Tag="ContentVisual">
                <wucSpriteVisual SizeX="50" SizeY="50" BorderMode="Soft">
                  <Color>
                    <KeyFrameAnimation Duration="10">
                      <KeyFrame Color="rgb {1, 0, 0}" />
                      <KeyFrame Time="1" Color="rgb {0, 1, 0}">
                        <LinearEasingFunction />
                      </KeyFrame>
                    </KeyFrameAnimation>
                  </Color>
                </wucSpriteVisual>
              </Visual>
            </Visual>
          </Visual>
          <Visual Tag="PrependVisual">
            <Visual Tag="PrimaryVisual" SizeX="50" SizeY="50">
              <Offset>
                <ExpressionAnimation String="Vector3(PS.X, PS.Y, 0)">
                  <ReferenceParameter Name="PS" />
                  <PropertySet>
                    <Property Name="X" Type="Scalar" />
                    <Property Name="Y" Type="Scalar">
                      <KeyFrameAnimation Duration="10" IterationCount="Forever">
                        <KeyFrame />
                        <KeyFrame Time="0.1" Value="100">
                          <CubicBezierEasingFunction Offset2X="1" Offset2Y="1" />
                        </KeyFrame>
                      </KeyFrameAnimation>
                    </Property>
                  </PropertySet>
                </ExpressionAnimation>
              </Offset>
              <Visual Tag="ContentVisual">
                <wucSpriteVisual SizeX="50" SizeY="50" BorderMode="Soft">
                  <Color>
                    <KeyFrameAnimation Duration="10">
                      <KeyFrame Color="rgb {1, 0, 0}" />
                      <KeyFrame Time="0.1" Color="rgb {0, 0, 1}">
                        <CircleEasingFunction EasingMode="Out" />
                      </KeyFrame>
                    </KeyFrameAnimation>
                  </Color>
                </wucSpriteVisual>
              </Visual>
            </Visual>
          </Visual>
        </Visual>
      </Visual>
    </Visual>
  </Visual>
</CompositionTarget>