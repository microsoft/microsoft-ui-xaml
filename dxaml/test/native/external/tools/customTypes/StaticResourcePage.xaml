<Page
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Tests.Tools.Shared">

    <Page.Resources>
      <ResourceDictionary>
        <ResourceDictionary.MergedDictionaries>
            <ResourceDictionary Source="CommonStyles.xaml"/>
        </ResourceDictionary.MergedDictionaries>
        <!--<Style x:Key="UnresolvableStyle" TargetType="Button">
          <Setter Property="Background" Value="{StaticResource Foo}"/>
        </Style>-->
        <x:Double x:Key="RectWidthSize">300</x:Double>
        <SolidColorBrush x:Key="SRP_MyBrush" Color="Blue"/>
        <Style TargetType="ListView" x:Key="SRP_MyBrushTemplatedListViewStyle">
          <Setter Property="ItemTemplate">
            <Setter.Value>
              <DataTemplate>
                <Grid Background="{StaticResource SRP_MyBrush}" x:Name="SRP_MyBrushListViewRoot">
                  <TextBlock x:Name="Text" Text="{Binding}" Foreground="White" />
                </Grid>
              </DataTemplate>
            </Setter.Value>
          </Setter>
        </Style>
      </ResourceDictionary>
    </Page.Resources>
    <Grid x:Name="LayoutRoot" Background="Transparent">
      <VisualStateManager.VisualStateGroups>
        <VisualStateGroup>
          <VisualState>
            <VisualState.StateTriggers>
              <!-- really low so it's always active -->
              <AdaptiveTrigger MinWindowWidth="10"/>
            </VisualState.StateTriggers>
            <VisualState.Setters>
              <Setter Target="bananas1.Background" Value="{StaticResource Foo}" />
              <Setter Target="bananas2.Background" Value="Pink" />
            </VisualState.Setters>
          </VisualState>
        </VisualStateGroup>
      </VisualStateManager.VisualStateGroups>
      <Grid.Resources>
        <SolidColorBrush x:Key="Foo">Blue</SolidColorBrush>
      </Grid.Resources>
      <StackPanel x:Name="stack">
        <StackPanel.Resources>
          <!--- Define Foo in this scope as well. The Visual state setters should not resolve to either of these values.-->
          <SolidColorBrush x:Key="Foo">Black</SolidColorBrush>
          <Style TargetType="Rectangle" x:Key="RectStyle">
            <Setter Property="Width" Value="200" />
          </Style>
        </StackPanel.Resources>
        <!-- Verify that visualStateFoo's color is set by the setter-->
        <Button Width="100" Height="100" Content="Bananas1" x:Name="bananas1"/>
        <Button Width="100" Height="100" Content="Bananas2" x:Name="bananas2"/>
        <!-- defer this button. should fail when we call find name-->
        <Button x:DeferLoadStrategy="Lazy" Style="{StaticResource UnresolvableStyle}" Width="100" Height="100" Content="DeferredBananas" x:Name="deferredBananas"/>
        <Rectangle Style="{StaticResource RectStyle}" Fill="Red" Height="100" x:Name="rect"/>
        <ListView Style="{StaticResource SRP_MyBrushTemplatedListViewStyle}" Width="100" Height="100" x:Name="myBrushListView">
          <x:String>Hello World</x:String>
        </ListView>
      </StackPanel>
    </Grid>
</Page>

