<Page
    x:Class="Tests.Tools.Shared.VisualStatePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Tests.Tools.Shared">

  <!-- Since VSM related goodies require the VSM components to be declared at the top of the
      page, we have this special page that we use. It's in your best interest not to do source
      info related tests based on this page because changing VSM will result in every elements
      source info changing. -->
    <Page.Resources>
      <ResourceDictionary>
        <ResourceDictionary.MergedDictionaries>
            <ResourceDictionary Source="CommonStyles.xaml"/>
        </ResourceDictionary.MergedDictionaries>
        <SolidColorBrush x:Key="triggerDefaultBrush">Red</SolidColorBrush>
        <SolidColorBrush x:Key="unnamedDefaultBrush">Purple</SolidColorBrush>
         <Color x:Key="manualForegroundBrushColor">Blue</Color>
      </ResourceDictionary>
    </Page.Resources>
    <StackPanel x:Name="LayoutRoot">
      <VisualStateManager.VisualStateGroups>
        <VisualStateGroup x:Name="Trigger">
          <VisualState x:Name="VisualStateTriggerTest">
            <VisualState.StateTriggers>
              <AdaptiveTrigger MinWindowWidth="500" />
            </VisualState.StateTriggers>
            <Storyboard x:Name="myStoryboard">
              <DoubleAnimation EnableDependentAnimation="True" From="110" To="300" Duration="00:00:1"
                Storyboard.TargetName="visualStateTriggerTest"
                Storyboard.TargetProperty="Height">
                <DoubleAnimation.EasingFunction>
                  <BounceEase Bounces="2" EasingMode="EaseOut" Bounciness="2" />
                </DoubleAnimation.EasingFunction>
              </DoubleAnimation>
              <ColorAnimation Storyboard.TargetName="visualStateTriggerForegroundBrush"
                              Storyboard.TargetProperty="Color"
                              To="Yellow"/>
            </Storyboard>
            <VisualState.Setters>
              <Setter Target="visualStateTriggerTest.Width" Value="300" />
            </VisualState.Setters>
          </VisualState>
        </VisualStateGroup>
        <VisualStateGroup x:Name="Manual">
          <VisualState x:Name="VisualStateManualTest">
            <Storyboard x:Name="myStoryboard2">
              <DoubleAnimation EnableDependentAnimation="True" From="110" To="300" Duration="00:00:1"
              Storyboard.TargetName="visualStateManualTest"
              Storyboard.TargetProperty="Height">
                <DoubleAnimation.EasingFunction>
                  <BounceEase Bounces="2" EasingMode="EaseOut" Bounciness="2" />
                </DoubleAnimation.EasingFunction>
              </DoubleAnimation>
              <ObjectAnimationUsingKeyFrames
                  Storyboard.TargetName="visualStateManualTest" 
                  Storyboard.TargetProperty="Foreground">
                      <DiscreteObjectKeyFrame KeyTime="0" Value="Blue" />
              </ObjectAnimationUsingKeyFrames>
            </Storyboard>
            <VisualState.Setters>
              <Setter Target="visualStateManualTest.Width" Value="300" />
              <Setter Target="visualStateManualTest.(Button.Foreground).(SolidColorBrush.Color)" Value="{StaticResource manualForegroundBrushColor}" />
            </VisualState.Setters>
          </VisualState>
        </VisualStateGroup>
        <VisualStateGroup x:Name="UnnamedStateGroup">
          <VisualState>
            <VisualState.StateTriggers>
              <AdaptiveTrigger MinWindowWidth="300" />
            </VisualState.StateTriggers>
            <VisualState.Setters>
              <Setter Target="unnamedVisualStateTest.Width" Value="200" />
            </VisualState.Setters>
          </VisualState>
        </VisualStateGroup>
      </VisualStateManager.VisualStateGroups>
      
      <!-- To make life easier, give these buttons different colors so they can be distinguished when watching tests.-->
      <Button x:Name="visualStateTriggerTest" Height="100" Width="100" Background="{StaticResource triggerDefaultBrush}" Content="Trigger">
        <Button.Foreground>
          <SolidColorBrush x:Name="visualStateTriggerForegroundBrush" Color="Black"/>
        </Button.Foreground>
      </Button>
      <Button x:Name="visualStateManualTest" Height="100" Width="100" Content="Manual" Foreground="Yellow">
        <Button.Background>
          <SolidColorBrush x:Name="visualStateManualTestBrush" Color="Green"/>
        </Button.Background>
      </Button>
      <Button x:Name="unnamedVisualStateTest" Height="100" Width="100" Background="{StaticResource unnamedDefaultBrush}" Content="Unnamed"/>
      <Button x:Name="visualStateTemplateTest" Width="100" Height="100" Content="Template">
        <Button.Template>
          <ControlTemplate TargetType="Button">
            <Grid x:Name="TemplatedLayoutRoot">
              <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="CommonStates">
                  <VisualState x:Name="Normal"/>
                </VisualStateGroup>
                <VisualStateGroup x:Name="OtherStates">
                  <VisualState x:Name="StoryboardState">
                    <Storyboard>
                      <DoubleAnimation
                          EnableDependentAnimation="True" From="110" To="300" Duration="00:00:1"
                          Storyboard.TargetName="InsetBackground"
                          Storyboard.TargetProperty="Height"/>
                    </Storyboard>
                  </VisualState>
                </VisualStateGroup>
              </VisualStateManager.VisualStateGroups>
              <Grid.Background>
                <SolidColorBrush x:Name="ButtonBrush" Color="White"/>
              </Grid.Background>
              <!-- Make this smaller than half of the layout root so that when we hover over visualStateManualTest, we go to the pointerover state -->
              <Grid x:Name="InsetBackground" Width ="25" Height="25" VerticalAlignment="Bottom" HorizontalAlignment="Right">
                <Grid.Background>
                  <SolidColorBrush x:Name="InsetBrush" Color="Red"/>
                </Grid.Background>
              </Grid>
            </Grid>
          </ControlTemplate>
        </Button.Template>
      </Button>
    </StackPanel>
</Page>

