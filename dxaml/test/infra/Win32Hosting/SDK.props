<Project DefaultTargets="Build" ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup Label="Globals">
    <TargetPlatformVersion Condition="'$(TargetPlatformVersion)'==''">$(WindowsSdkTargetPlatformVersion)</TargetPlatformVersion>
    <WindowsKitsReferencesDir Condition=" '$(WindowsKitsReferencesDir)' == '' ">$(Registry:HKEY_LOCAL_MACHINE\SOFTWARE\Microsoft\Windows Kits\Installed Roots@KitsRoot10)\References\$(TargetPlatformVersion)</WindowsKitsReferencesDir>
  </PropertyGroup>
</Project>
