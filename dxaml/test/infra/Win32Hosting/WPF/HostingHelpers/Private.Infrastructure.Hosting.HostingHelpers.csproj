<Project Sdk="Microsoft.NET.Sdk">
  <Sdk Name="Microsoft.Build.CentralPackageVersions" Version="2.0.1" />
  <PropertyGroup>
    <TargetFramework>$(DotNetCoreTargetFrameworkMoniker)</TargetFramework>
    <Platforms>x64;x86</Platforms>
    <RuntimeIdentifiers>win10-x86;win10-x64</RuntimeIdentifiers>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <UseWPF>true</UseWPF>
  </PropertyGroup>
  
  <PropertyGroup>
    <AssemblyVersion>1.0.0.0</AssemblyVersion>
    <CsWinRTWindowsMetadata>$(WindowsTargetPlatformVersion)</CsWinRTWindowsMetadata>
    <CsWinRTComponent>true</CsWinRTComponent>
    <CsWinRTEnableLogging>true</CsWinRTEnableLogging>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <GeneratedFilesDir Condition="'$(GeneratedFilesDir)'==''">$([MSBuild]::NormalizeDirectory('$(MSBuildProjectDirectory)', '$(IntermediateOutputPath)', 'Generated Files'))</GeneratedFilesDir>

    <DefineConstants Condition="'$(Platform)'=='ARM64'">_ARM64_</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Windows.CsWinRT" />
  </ItemGroup>

  <ItemGroup Condition="'$(Platform)'!='ARM64'" >
    <ProjectReference Include="..\netcore\Private.Infrastructure.Hosting.WPF.csproj" />
    <ProjectReference Include="..\..\..\client\cswinrt\Private.Infrastructure.CsWinRT.csproj" />
  </ItemGroup>

  <!--Temporary workaround to address https://github.com/microsoft/CsWinRT/issues/1156 -->
  <Target Name="CsWinRTUpdatePreferredPackages" BeforeTargets="_HandlePackageFileConflicts" AfterTargets="ResolveTargetingPackAssets">
    <PropertyGroup>
      <PackageConflictPreferredPackages>Microsoft.Windows.CsWinRT;$(PackageConflictPreferredPackages)</PackageConflictPreferredPackages>
    </PropertyGroup>
  </Target>

</Project>
