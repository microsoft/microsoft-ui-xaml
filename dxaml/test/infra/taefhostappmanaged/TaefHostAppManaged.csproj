  </PropertyGroup>
  <!-- We don't want to actually use an AppX for tests - we run our tests from a directory that we get to act like the root of an AppX
       but whose contents are actually just loose files.  However, packing everything in an AppX has us collect in one nice bundle
       everything we need to run this app - our root exe + entrypoint exe, plus AppX dependencies, are all collected together in a form
       that we can easily deploy and run. To facilitate that deployment, we'll unzip those AppX packages to a location and then binplace
       their contents. -->
  <Target Name="UnpackPackages" AfterTargets="AddBinplaceItems" BeforeTargets="Binplace" Condition="'$(BuildingInsideVisualStudio)' != 'true'">
    <PropertyGroup>
      <TargetDestination>$(TestBinplaceDestinationPath)</TargetDestination>
      <UcrtBaseDLocation Condition="'%(InstalledSDKLocations.SDKName)' == 'Microsoft.UniversalCRT.Debug, Version=$(WindowsSdkTargetPlatformVersion)'">@(InstalledSDKLocations)Redist\Debug\$(DependencyPlatform)\</UcrtBaseDLocation>
      <VCLibsDesktopDebugLocation Condition="'%(InstalledSDKLocations.SDKName)' == 'Microsoft.VCLibs.Desktop, Version=14.0'">@(InstalledSDKLocations)AppX\Debug\$(DependencyPlatform)\</VCLibsDesktopDebugLocation>
    </PropertyGroup>
    <Unzip SourceFiles="$(OutDir)AppPackages\$(PackageName)_Test\$(PackageName).msix" DestinationFolder="$(TempDir)AppPackages_Unzipped\$(PackageName)" />
    <Unzip SourceFiles="$(OutDir)AppPackages\$(PackageName)_Test\Dependencies\$(DependencyPlatform)\$(CoreFrameworkName).appx" DestinationFolder="$(TempDir)AppPackages_Unzipped\$(CoreFrameworkName)" />
    <Unzip SourceFiles="$(OutDir)AppPackages\$(PackageName)_Test\Dependencies\$(DependencyPlatform)\$(CoreRuntimeName).appx" DestinationFolder="$(TempDir)AppPackages_Unzipped\$(CoreRuntimeName)" />
    <Unzip SourceFiles="$(VCLibsDesktopDebugLocation)Microsoft.VCLibs.$(DependencyPlatform).Debug.14.00.Desktop.appx" DestinationFolder="$(TempDir)AppPackages_Unzipped\Microsoft.VCLibs.Debug.14.00.Desktop" Condition="'$(Configuration)' == 'Debug'" />
    <ItemGroup>
      <BinplaceItem Remove="@(BinplaceItem)" />
      <BinplaceItem Include="$(OutDir)resources.pri">
        <Destination>$(TargetDestination)\managed</Destination>
      </BinplaceItem>
      <BinplaceItem Include="$(TempDir)AppPackages_Unzipped\$(PackageName)\$(AssemblyName).exe" />
      <BinplaceItem Include="$(TempDir)AppPackages_Unzipped\$(PackageName)\entrypoint\$(AssemblyName).exe">
        <Destination>$(TargetDestination)\entrypoint</Destination>
      </BinplaceItem>
      <BinplaceItem Include="$(OutDir)TE.AppxUnitTestClient.Managed.dll">
        <Destination>$(TargetDestination)</Destination>
      </BinplaceItem>
      <BinplaceItem Include="$(UcrtBaseDLocation)ucrtbased.dll" Condition="'$(Configuration)' == 'Debug'">
        <Destination>$(TargetDestination)</Destination>
      </BinplaceItem>
      <BinplaceItem Include="$(TempDir)AppPackages_Unzipped\Microsoft.VCLibs.Debug.14.00.Desktop\*d.dll" Condition="'$(Configuration)' == 'Debug'">
        <Destination>$(TargetDestination)</Destination>
      </BinplaceItem>
      <BinplaceItem Include="$(OutDir)AppPackages\$(PackageName)_Test\Dependencies\$(DependencyPlatform)\*.appx">
        <Destination>$(TestDependenciesResourcesDestinationPath)\AppX</Destination>
      </BinplaceItem>
    </ItemGroup>
    <ItemGroup Condition="'$(arch)'=='x86' or '$(arch)'=='amd64'">
      <BinplaceItem Include="$(NugetPackageDirectory)\microsoft.diagnostics.tracing.traceevent.2.0.45\lib\native\$(arch)\KernelTraceControl.dll">
        <Destination>$(TestDependenciesResourcesDestinationPath)</Destination>
      </BinplaceItem>
    </ItemGroup>
    <!-- Copy mini_installer.exe if the Microsoft.UI.DCPP.Dependencies.Edge package has been restored (which only happens in the pipelines) -->
    <ItemGroup Condition="('$(arch)'=='x86' or '$(arch)'=='amd64') and Exists('$(NugetPackageDirectory)\Microsoft.UI.DCPP.Dependencies.Edge.144.0.3719.82')">
      <BinplaceItem Include="$(NugetPackageDirectory)\Microsoft.UI.DCPP.Dependencies.Edge.144.0.3719.82\edge\mini_installer\$(DependencyPlatform)\mini_installer.exe">
        <Destination>$(TestDependenciesResourcesDestinationPath)</Destination>
      </BinplaceItem>
    </ItemGroup>
  </Target>
  <Target Name="AppxExternalBinaries" BeforeTargets="GetPackagingOutputs" DependsOnTargets="ChooseExternalBinaries">
    <ItemGroup>
      <Content Include="@(ExternalBinaries)">
        <Link>%(Filename)%(Extension)</Link>
