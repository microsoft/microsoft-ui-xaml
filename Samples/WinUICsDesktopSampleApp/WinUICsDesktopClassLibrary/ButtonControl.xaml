<UserControl
    x:Class="WinUICsDesktopClassLibrary.ButtonControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WinUICsDesktopClassLibrary"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        
        <StackPanel Orientation="Vertical">
            <TextBlock x:Name="TestTextBlock" AutomationProperties.Name="TestTextBlock" Text="Loaded"/>
            <TextBlock x:Name="NavigationPaneStatusBlk" AutomationProperties.Name="NavigationPaneStatusBlk" Text="Loaded"/>
            <Button AutomationProperties.Name="MyButton" x:Name="myButton" Click="myButton_Click">Click Me</Button>
        </StackPanel>

        <local:MuxcIxmpTestUserControl Grid.Column="1"/>

    </Grid>
    
</UserControl>
