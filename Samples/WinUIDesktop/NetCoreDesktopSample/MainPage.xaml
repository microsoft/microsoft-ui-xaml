<Page x:Class="NetCoreDesktopSample.MainPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="NetCoreDesktopSample"
        mc:Ignorable="d"
        Height="450" Width="800">
    <StackPanel>
        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Text="Hello from WinUI Desktop!" x:Name="text" />
        <Button Click="UpdateTextBlockAsync" Content="Click To Update the Text Block" x:Name="button"/>
        
        <TextBlock Text="{x:Bind Text, Mode=OneWay}" />
        <TextBox Height="200" Width="200" x:Name="textBox" Text="{x:Bind Text, Mode=TwoWay}"/>
    </StackPanel>
</Page>
