<Window
    x:Class="WinUICppDesktopSampleApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WinUICppDesktopSampleApp"
    xmlns:helpers="using:AppTestAutomationHelpers"
    xmlns:library="using:WinUICppRuntimeComponent">

    <StackPanel x:Name="stackPanelRoot" HorizontalAlignment="Stretch" VerticalAlignment="Top">
        <local:AttachedPropSampleExtensions.MyAttachedProp>
            <TextBlock x:Name="elementNameBindingSource" Text="lorem ipsum" />
        </local:AttachedPropSampleExtensions.MyAttachedProp>

        <helpers:TestAutomationHelpersPanel/>
        <!-- Custom title bar  start block -->
        <StackPanel x:Name="myTitleBar" Height="32" HorizontalAlignment="Stretch" VerticalAlignment="Top">
            <StackPanel HorizontalAlignment="Stretch" VerticalAlignment="Center">
                <TextBlock x:Name="titleBarText" HorizontalAlignment="Stretch" Margin="30,0,0,0" AutomationProperties.AutomationId="customTitleBarText">Custom Title Bar</TextBlock>
            </StackPanel>
        </StackPanel>
        <!-- Custom title bar  end block -->
        <TextBlock Text="WinUICppDesktopSampleApp" FontSize="20" Margin="2"/>
        <ContentDialog x:Name="contentDialogWindowChromeTest"
            PrimaryButtonText="Accept" IsPrimaryButtonEnabled="False"
            CloseButtonText="Cancel">
            <ContentDialog.Title>Hello
            </ContentDialog.Title>
            <StackPanel>
                <TextBlock TextWrapping="WrapWholeWords">
        <Run>Lorem ipsum dolor sit amet, consectetuer adipiscing elit. Maecenas porttitor
                congue massa. Fusce posuere, magna sed pulvinar ultricies, purus lectus
                malesuada libero, sit amet commodo magna eros quis urna.</Run><LineBreak/>
        <Run>Nunc viverra imperdiet enim. Fusce est. Vivamus a tellus.</Run><LineBreak/>
        <Run>Pellentesque habitant morbi tristique senectus et netus et malesuada fames
                ac turpis egestas. Proin pharetra nonummy pede. Mauris et orci.</Run><LineBreak/>
        <Run>Suspendisse dui purus, scelerisque at, vulputate vitae, pretium mattis, nunc.
                Mauris eget neque at sem venenatis eleifend. Ut nonummy.</Run>
                </TextBlock>
                <CheckBox x:Name="ConfirmAgeCheckBox" Content="I am over 13 years of age."/>
            </StackPanel>
        </ContentDialog>
        <StackPanel Orientation="Horizontal">
            <Button x:Name="titlebarChange" AutomationProperties.Name="titlebarChange" Click="titlebarChange_Click">Reset titlebar</Button>
            <DropDownButton x:Name="windowChromeSpecialTests" AutomationProperties.AutomationId="windowChromeSpecialTests" Content="Special tests">
                <DropDownButton.Flyout>
                    <MenuFlyout Placement="Bottom">
                        <MenuFlyoutItem Text="Change titlebar size" AutomationProperties.AutomationId="titlebarSizeChange" Click="titlebarSizeChange_Click"/>
                        <MenuFlyoutItem Text="Set nullptr as titlebar" AutomationProperties.AutomationId="titlebarnullptr" Click="titlebarNullptr_Click" />
                        <MenuFlyoutItem Text="Content Dialog w/ titlebar" AutomationProperties.AutomationId="contentDialogWithTitlebar" Click="contentDialogWithTitlebar_Click" />
                        <MenuFlyoutItem Text="Set extreme margins on titlebar" AutomationProperties.AutomationId="extremeMarginTitlebar" Click="extremeMarginTitlebar_Click" />
                        <MenuFlyoutItem Text="Test appwindow api" AutomationProperties.AutomationId="appwindowobj" Click="AppWindowObj_Click" />
                    </MenuFlyout>
                </DropDownButton.Flyout>
            </DropDownButton>
            <TextBlock Text="Margin :" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            <TextBox x:Name="left" PlaceholderText="Left" TextChanged="TextBox_TextChanged"  />
            <TextBox x:Name="top" PlaceholderText="Top" TextChanged="TextBox_TextChanged" />
            <TextBox x:Name="right" PlaceholderText="Right"  TextChanged="TextBox_TextChanged"/>
            <TextBox x:Name="bottom" PlaceholderText="Bottom" TextChanged="TextBox_TextChanged" />
            <DatePicker AutomationProperties.Name="DatePicker" />
            <TextBlock x:Name="ViewModelBindingTextBlock" AutomationProperties.AutomationId="ViewModelBindingTextBlock" Text="{Binding Text}" />
        </StackPanel>
        <TabView CanDragTabs="False" IsAddTabButtonVisible="False" TabWidthMode="SizeToContent" Margin="2">
            <TabView.TabItems>
                <!-- Controls from Microsoft.UI.Xaml.dll -->
                <TabViewItem x:Name="tviMUXControls" AutomationProperties.Name="tviMUXControls" Header="MUX Controls">
                    <TabViewItem.IconSource>
                        <SymbolIconSource Symbol="ZeroBars"/>
                    </TabViewItem.IconSource>

                    <Grid ColumnDefinitions="200, Auto">
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="textBlockMUXControls" AutomationProperties.Name="textBlockMUXControls" Text="Loaded" Margin="2"/>
                            <CheckBox x:Name="checkBox" AutomationProperties.Name="checkBox" Margin="2"/>
                            <Button x:Name="button" AutomationProperties.Name="button" Content="Button" Click="Button_Click" Margin="2"/>
                            <ToggleButton x:Name="toggleButton" AutomationProperties.Name="toggleButton" Content="ToggleButton" Margin="2"
                                Click="ToggleButton_Click" Checked="ToggleButton_Checked" Unchecked="ToggleButton_Unchecked"/>
                            <Button x:Name="buttonWithFlyout" AutomationProperties.Name="buttonWithFlyout" Content="Button with Flyout" Click="ButtonWithFlyout_Click" Margin="2">
                                <Button.Flyout>
                                    <MenuFlyout x:Name="buttonFlyout" Opened="ButtonFlyout_Opened" Closed="ButtonFlyout_Closed">
                                        <MenuFlyoutItem Text="Share" >
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE72D;"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem Text="Copy" Icon="Copy"/>
                                        <MenuFlyoutItem Text="Delete" Icon="Delete"/>
                                        <MenuFlyoutSeparator/>
                                        <MenuFlyoutItem Text="Rename"/>
                                        <MenuFlyoutItem Text="Select"/>
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>

                            <Button x:Name="buttonWithContextFlyout" AutomationProperties.Name="buttonWithContextFlyout" Content="Button with ContextFlyout"
                                    RightTapped="ButtonWithContextFlyout_RightTapped" Margin="2">
                                <Button.ContextFlyout>
                                    <MenuFlyout x:Name="buttonContextFlyout" Opened="ButtonContextFlyout_Opened" Closed="ButtonContextFlyout_Closed">
                                        <MenuFlyoutItem Text="Share" Click="ShareMenuFlyoutItem_Click">
                                            <MenuFlyoutItem.Icon>
                                                <FontIcon Glyph="&#xE72D;"/>
                                            </MenuFlyoutItem.Icon>
                                        </MenuFlyoutItem>
                                        <MenuFlyoutItem Text="Copy" Icon="Copy"/>
                                        <MenuFlyoutItem Text="Delete" Icon="Delete"/>
                                        <MenuFlyoutSeparator/>
                                        <MenuFlyoutItem Text="Rename"/>
                                        <MenuFlyoutItem Text="Select"/>
                                    </MenuFlyout>
                                </Button.ContextFlyout>
                            </Button>
                            <Button x:Name="btnChangeBackground" AutomationProperties.Name="ChangeBackgroundButton" Content="Change Background" Click="ChangeBackgroundButton_Click" Margin="2"/>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="themeChangeBtn" AutomationProperties.Name="themeChangeBtn" Content="Change Theme" Click="themeChangeBtn_Click" Margin="2"/>
                            </StackPanel>
                        </StackPanel>

                        <Border Grid.Column="1" BorderThickness="1" BorderBrush="Black" Margin="2" HorizontalAlignment="Left">
                            <StackPanel>
                                <TextBlock Text="Custom MPE" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <local:CustomMediaPlayerElement Source="ms-appx:///Media/608test.mp4" Width="496" Height="372" AutoPlay="True" AreTransportControlsEnabled="True" HorizontalAlignment="Left">
                                    <local:CustomMediaPlayerElement.TransportControls>
                                        <MediaTransportControls
                                            IsCompact="False"
                                            IsFastForwardButtonVisible="True"
                                            IsFastForwardEnabled="True"
                                            IsFastRewindButtonVisible="True"
                                            IsFastRewindEnabled="True"
                                            IsPreviousTrackButtonVisible="True"
                                            IsNextTrackButtonVisible="True"
                                            IsPlaybackRateButtonVisible="True"
                                            IsPlaybackRateEnabled="True"
                                            IsRepeatButtonVisible="True"
                                            IsRepeatEnabled="True"
                                            IsSeekBarVisible="True"
                                            IsSeekEnabled="True"
                                            IsSkipBackwardButtonVisible="True"
                                            IsSkipBackwardEnabled ="True"
                                            IsSkipForwardButtonVisible="True"
                                            IsSkipForwardEnabled ="True"
                                            IsStopButtonVisible="True"
                                            IsStopEnabled="True"
                                            IsVolumeButtonVisible="True"
                                            IsVolumeEnabled="True"
                                            IsZoomButtonVisible="True"
                                            IsZoomEnabled="True"
                                            ShowAndHideAutomatically="True"/>
                                    </local:CustomMediaPlayerElement.TransportControls>
                                </local:CustomMediaPlayerElement>
                            </StackPanel>
                        </Border>
                    </Grid>

                </TabViewItem>

                <!-- Controls from Microsoft.UI.Xaml.Controls.dll -->
                <TabViewItem x:Name="tviMUXCControls" AutomationProperties.Name="tviMUXCControls" Header="MUXC Controls">
                    <TabViewItem.IconSource>
                        <SymbolIconSource Symbol="OneBar"/>
                    </TabViewItem.IconSource>

                    <StackPanel x:Name="stackPanelMUXCControls" AutomationProperties.Name="stackPanelMUXCControls" Orientation="Horizontal">
                        <TextBlock x:Name="textBlockMUXCControls" AutomationProperties.Name="textBlockMUXCControls" MinWidth="150" Margin="2"/>

                        <StackPanel>
                            <SplitButton x:Name="splitButton" AutomationProperties.Name="splitButton" Content="SplitButton" Click="SplitButton_Click" Margin="2">
                                <SplitButton.Flyout>
                                    <Flyout x:Name="splitButtonFlyout" Opened="SplitButtonFlyout_Opened" Closed="SplitButtonFlyout_Closed">
                                        <TextBlock Text="Flyout"/>
                                    </Flyout>
                                </SplitButton.Flyout>
                            </SplitButton>

                            <DropDownButton x:Name="dropDownButton" AutomationProperties.Name="dropDownButton" Content="DropDownButton" Click="DropDownButton_Click" Margin="2">
                                <DropDownButton.Flyout>
                                    <Flyout>
                                        <Flyout.Content>
                                            <TextBlock Text="Flyout"/>
                                        </Flyout.Content>
                                    </Flyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>

                            <RatingControl x:Name="ratingControl" AutomationProperties.Name="ratingControl" Margin="2"/>

                            <TreeView x:Name="treeView" AutomationProperties.Name="treeView" Margin="2">
                                <TreeView.RootNodes>
                                    <TreeViewNode Content="Flavors" IsExpanded="True">
                                        <TreeViewNode.Children>
                                            <TreeViewNode Content="Vanilla"/>
                                            <TreeViewNode Content="Strawberry">
                                                <TreeViewNode.Children>
                                                    <TreeViewNode Content="Wild"/>
                                                    <TreeViewNode Content="Field"/>
                                                </TreeViewNode.Children>
                                            </TreeViewNode>
                                            <TreeViewNode Content="Chocolate"/>
                                        </TreeViewNode.Children>
                                    </TreeViewNode>
                                </TreeView.RootNodes>
                            </TreeView>
                        </StackPanel>

                        <ColorPicker x:Name="colorPicker" AutomationProperties.Name="colorPicker" Margin="2"/>
                        <StackPanel Orientation="Vertical">
                            <Button x:Name="loadWebView2Button" AutomationProperties.Name="loadWebView2Button" Click="LoadWebView2Button_Click">Load WebView2</Button>
                            <WebView2 x:Name="myWebView2" AutomationProperties.Name="myWebView2" Width="640" Height="480" AllowDrop="True"/>
                        </StackPanel>

                    </StackPanel>
                </TabViewItem>

                <!-- Controls from separate project -->
                <TabViewItem x:Name="tviExternalControls" AutomationProperties.Name="tviExternalControls" Header="External Controls">
                    <TabViewItem.IconSource>
                        <SymbolIconSource Symbol="TwoBars"/>
                    </TabViewItem.IconSource>

                    <StackPanel x:Name="stackPanelExternalControls" AutomationProperties.Name="stackPanelExternalControls" Orientation="Horizontal">
                        <TextBlock x:Name="textBlockExternalControls" AutomationProperties.Name="textBlockExternalControls" MinWidth="150" Margin="2"/>

                        <!-- This control also includes a control from Microsoft.UI.Xaml.Phone.dll -->
                        <library:UserControl1 x:Name="userControl1" AutomationProperties.Name="userControl1" MaxWidth="800"/>
                    </StackPanel>
                </TabViewItem>

                <!-- Window APIs -->
                <TabViewItem x:Name="tviWindowClass" AutomationProperties.Name="tviWindowClass" Header="Window Class">
                    <TabViewItem.IconSource>
                        <SymbolIconSource Symbol="ViewAll"/>
                    </TabViewItem.IconSource>

                    <StackPanel x:Name="stackPanelWindowClass" AutomationProperties.Name="stackPanelWindowClass">
                        <StackPanel Orientation="Horizontal">
                            <StackPanel>
                                <Button x:Name="buttonSetWindowFree" AutomationProperties.Name="buttonSetWindowFree" Content="Release Window on Close" HorizontalAlignment="Stretch" Click="ButtonSetWindowFree_Click" Margin="2" IsEnabled="True"/>
                                <Button x:Name="buttonCreateWindow" AutomationProperties.Name="buttonCreateWindow" Content="Create Window on same thread" HorizontalAlignment="Stretch" Click="ButtonCreateWindow_Click" Margin="2" IsEnabled="True"/>
                                <Button x:Name="buttonExitAppFromWinUI" AutomationProperties.Name="buttonExitAppFromWinUI" Content="Exit Application" HorizontalAlignment="Stretch" Click="ButtonExitApplication_Click" Margin="2"/>
                                <StackPanel Orientation="Horizontal">
                                    <RadioButtons x:Name="radioButtonWindowGroup" AutomationProperties.Name="radioButtonWindowGroup" SelectedIndex="0">
                                        <RadioButton x:Name="radioButtonRuntimeWindow" AutomationProperties.Name="radioButtonRuntimeWindow" Content="Runtime" Margin="2,0,0,0" IsChecked="True"/>
                                        <RadioButton x:Name="radioButtonBlankCustomWindow" AutomationProperties.Name="radioButtonBlankCustomWindow" Content="Custom"/>
                                        <RadioButton x:Name="radioButtonMarkupWindow" AutomationProperties.Name="radioButtonMarkupWindow" Content="Markup"/>
                                        <RadioButton x:Name="radioButtonMainWindow" AutomationProperties.Name="radioButtonMainWindow" Content="Main Window (will use this window instead of creating a new one)"/>
                                        <RadioButton x:Name="radioButtonChildWindow" AutomationProperties.Name="radioButtonChildWindow" Content="Runtime Window (top level) + Markup Window (child window)"/>
                                    </RadioButtons>
                                </StackPanel>
                            </StackPanel>
                            <Button x:Name="buttonActivateWindow" AutomationProperties.Name="buttonActivateWindow" VerticalAlignment="Stretch" Content="Activate Window" Click="ButtonActivateWindow_Click" Margin="2" IsEnabled="False"/>
                            <Button x:Name="buttonCloseWindow" AutomationProperties.Name="buttonCloseWindow" VerticalAlignment="Stretch" Content="Close Window" Click="ButtonCloseWindow_Click" Margin="2" IsEnabled="False"/>
                            <Button x:Name="buttonDiscardWindow" AutomationProperties.Name="buttonDiscardWindow" VerticalAlignment="Stretch" Content="Discard Window" Click="ButtonDiscardWindow_Click" Margin="2" IsEnabled="False"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <StackPanel>
                                <TextBlock Text="Properties" FontSize="16" FontWeight="SemiBold" Margin="2"/>

                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="buttonResetBounds" AutomationProperties.Name="buttonResetBounds" Content="Reset" Click="ButtonResetBounds_Click" Margin="2"/>
                                    <Button x:Name="buttonGetBounds" AutomationProperties.Name="buttonGetBounds" Content="Get" Click="ButtonGetBounds_Click" Margin="2"/>
                                    <TextBlock Text="Bounds:" VerticalAlignment="Center" Margin="2"/>
                                    <TextBlock x:Name="textBlockBoundsX" VerticalAlignment="Center" AutomationProperties.Name="textBlockBoundsX" Margin="2"/>
                                    <TextBlock x:Name="textBlockBoundsY" VerticalAlignment="Center" AutomationProperties.Name="textBlockBoundsY" Margin="2"/>
                                    <TextBlock x:Name="textBlockBoundsWidth" VerticalAlignment="Center" AutomationProperties.Name="textBlockBoundsWidth" Margin="2"/>
                                    <TextBlock x:Name="textBlockBoundsHeight" VerticalAlignment="Center" AutomationProperties.Name="textBlockBoundsHeight" Margin="2"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="buttonResetVisible" AutomationProperties.Name="buttonResetVisible" Content="Reset" Click="ButtonResetVisible_Click" Margin="2"/>
                                    <Button x:Name="buttonGetVisible" AutomationProperties.Name="buttonGetVisible" Content="Get" Click="ButtonGetVisible_Click" Margin="2"/>
                                    <TextBlock Text="Visible:" VerticalAlignment="Center" Margin="2"/>
                                    <TextBlock x:Name="textBlockVisible" VerticalAlignment="Center" AutomationProperties.Name="textBlockVisible" Margin="2"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="buttonResetContent" AutomationProperties.Name="buttonResetContent" Content="Reset" Click="ButtonResetContent_Click" Margin="2"/>
                                    <Button x:Name="buttonGetContent" AutomationProperties.Name="buttonGetContent" Content="Get" Click="ButtonGetContent_Click" Margin="2"/>
                                    <TextBlock Text="Content:" VerticalAlignment="Center" Margin="2"/>
                                    <TextBlock x:Name="textBlockContent" VerticalAlignment="Center" AutomationProperties.Name="textBlockContent" Margin="2"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="buttonResetTitle" AutomationProperties.Name="buttonResetTitle" Content="Reset" Click="ButtonResetTitle_Click" Margin="2"/>
                                    <Button x:Name="buttonGetTitle" AutomationProperties.Name="buttonGetTitle" Content="Get" Click="ButtonGetTitle_Click" Margin="2"/>
                                    <Button x:Name="buttonSetTitle" AutomationProperties.Name="buttonSetTitle" Content="Set" Click="ButtonSetTitle_Click" Margin="2"/>
                                    <TextBlock Text="Title:" VerticalAlignment="Center" Margin="2"/>
                                    <TextBox x:Name="textBoxTitle" VerticalAlignment="Center" AutomationProperties.Name="textBoxTitle" Margin="2" MinWidth="200"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Methods" FontSize="16" FontWeight="SemiBold" Margin="2"/>

                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="buttonResetHandle" AutomationProperties.Name="buttonResetHandle" Content="Reset" Click="ButtonResetHandle_Click" Margin="2"/>
                                    <Button x:Name="buttonGetHandle" AutomationProperties.Name="buttonGetHandle" Content="Get" Click="ButtonGetHandle_Click" Margin="2"/>
                                    <TextBlock Text="IWindowNative Handle:" VerticalAlignment="Center" Margin="2"/>
                                    <TextBlock x:Name="textBlockHandle" VerticalAlignment="Center" AutomationProperties.Name="textBlockHandle" MinWidth="60" Margin="2"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="buttonSetSize" AutomationProperties.Name="buttonSetSize" Content="Set Size" Click="ButtonSetSize_Click" Margin="2"/>
                                    <TextBlock VerticalAlignment="Center" Text="Width:" Margin="2"/>
                                    <TextBox x:Name="textBoxWidth" Text="1024" VerticalAlignment="Center" AutomationProperties.Name="textBoxWidth" Margin="2"/>
                                    <TextBlock VerticalAlignment="Center" Text="Height:" Margin="2"/>
                                    <TextBox x:Name="textBoxHeight" Text="768" VerticalAlignment="Center" AutomationProperties.Name="textBoxHeight" Margin="2"/>
                                </StackPanel>
                                <CheckBox x:Name="closingCheckbox" AutomationProperties.Name="closingCheckbox" Content="Mark closing event as handled (prevents closing)" IsChecked="False"/>
                                <CheckBox x:Name="testShutdownCheckbox" AutomationProperties.Name="testShutdownCheckbox" Content="Test Shutdown Order" />
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Events" FontSize="16" FontWeight="SemiBold" Margin="2"/>

                                <Button x:Name="buttonClearEvents" AutomationProperties.Name="buttonClearEvents" Content="Clear" Click="ButtonClearEvents_Click" Margin="2"/>
                                <TextBox x:Name="textBoxLastEvent" AutomationProperties.Name="textBoxLastEvent" Margin="2" MinWidth="200"/>
                                <ComboBox x:Name="comboBoxEvents" AutomationProperties.Name="comboBoxEvents" Margin="2" MinWidth="200"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="buttonClearError" AutomationProperties.Name="buttonClearError" Content="Clear" Click="ButtonClearError_Click" Margin="2"/>
                            <TextBlock Text="Error:" VerticalAlignment="Center" Margin="2"/>
                            <TextBox x:Name="textBoxError" VerticalAlignment="Center" AutomationProperties.Name="textBoxError" IsReadOnly="True" Margin="2"/>
                        </StackPanel>
                    </StackPanel>
                </TabViewItem>

                <!-- UIElement Manipulation APIs -->
                <TabViewItem x:Name="tviUIElementManipulation" AutomationProperties.Name="tviUIElementManipulation" Header="UIElement Manipulation">
                    <TabViewItem.IconSource>
                        <SymbolIconSource Symbol="TouchPointer"/>
                    </TabViewItem.IconSource>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Canvas x:Name="canvas" Width="500" Height="500" Background="Bisque" Margin="2">
                                <Rectangle x:Name="rectangleManipulated" Width="100" Height="100" Fill="Brown"
                                           ManipulationMode="TranslateX,TranslateY,TranslateInertia"
                                           ManipulationStarting="RectangleManipulated_ManipulationStarting"
                                           ManipulationStarted="RectangleManipulated_ManipulationStarted"
                                           ManipulationDelta="RectangleManipulated_ManipulationDelta"
                                           ManipulationInertiaStarting="RectangleManipulated_ManipulationInertiaStarting"
                                           ManipulationCompleted="RectangleManipulated_ManipulationCompleted"/>
                            </Canvas>
                            <StackPanel Margin="2">
                                <TextBlock Text="Events" FontSize="16" FontWeight="SemiBold" Margin="2"/>

                                <Button x:Name="buttonClearEvents2" AutomationProperties.Name="buttonClearEvents2" Content="Clear" Click="ButtonClearEvents2_Click" Margin="2"/>
                                <TextBox x:Name="textBoxLastEvent2" AutomationProperties.Name="textBoxLastEvent2" Margin="2" MinWidth="200"/>
                                <ComboBox x:Name="comboBoxEvents2" AutomationProperties.Name="comboBoxEvents2" Margin="2" MinWidth="200"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="buttonClearError2" AutomationProperties.Name="buttonClearError2" Content="Clear" Click="ButtonClearError2_Click" Margin="2"/>
                            <TextBlock Text="Error:" VerticalAlignment="Center" Margin="2"/>
                            <TextBox x:Name="textBoxError2" VerticalAlignment="Center" AutomationProperties.Name="textBoxError2" IsReadOnly="True" Margin="2"/>
                        </StackPanel>
                    </StackPanel>
                </TabViewItem>

                <!-- Application APIs -->
                <TabViewItem x:Name="tviApplicationClass" AutomationProperties.Name="tviApplicationClass" Header="Application Class">
                    <TabViewItem.IconSource>
                        <SymbolIconSource Symbol="GoToStart"/>
                    </TabViewItem.IconSource>

                    <StackPanel x:Name="stackPanelApplicationClass" AutomationProperties.Name="stackPanelApplicationClass">
                        <Button x:Name="buttonExitApplication" AutomationProperties.Name="buttonExitApplication" Content="Exit Application" Click="ButtonExitApplication_Click" Margin="2"/>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="buttonClearError3" AutomationProperties.Name="buttonClearError3" Content="Clear" Click="ButtonClearError3_Click" Margin="2"/>
                            <TextBlock Text="Error:" VerticalAlignment="Center" Margin="2"/>
                            <TextBox x:Name="textBoxError3" VerticalAlignment="Center" AutomationProperties.Name="textBoxError3" IsReadOnly="True" Margin="2"/>
                        </StackPanel>
                    </StackPanel>
                </TabViewItem>

                <!-- Binding -->
                <TabViewItem x:Name="tviBinding" AutomationProperties.Name="tviBinding" Header="Binding">
                    <TabViewItem.IconSource>
                        <SymbolIconSource Symbol="Switch"/>
                    </TabViewItem.IconSource>

                    <StackPanel x:Name="stackPanelBinding" AutomationProperties.Name="stackPanelBinding">
                        <TextBlock Text="{Binding Text,ElementName=elementNameBindingSource}" x:Name="elementNameBindingTextBlock" AutomationProperties.Name="elementNameBindingTextBlock"/>
                    </StackPanel>
                </TabViewItem>
            </TabView.TabItems>
        </TabView>
        <Frame x:Name="m_rootFrame" />
    </StackPanel>
</Window>
