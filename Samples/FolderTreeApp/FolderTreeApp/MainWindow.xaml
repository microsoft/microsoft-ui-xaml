<Window
    x:Class="FolderTreeApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FolderTreeApp"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Title="Folder Tree Browser">

    <Grid x:Name="RootGrid" Padding="16" RowSpacing="16" Loaded="RootGrid_Loaded">
        <!-- Override the default (blue) accent palette with a non-blue green so no element
             on this window — including accent-tinted cards, icons and TreeView selection —
             renders blue. -->
        <Grid.Resources>
            <Color x:Key="SystemAccentColor">#2E9E5B</Color>
            <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="#2E9E5B" />
            <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="#2B9354" />
            <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="#3DAE6A" />
            <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="#1B6E3C" />
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header card: rounded, accent-filled, with a ThemeShadow (Translation Z lifts it
             so the shadow casts onto the content below — a real shadow visual in the comp tree). -->
        <Border x:Name="HeaderCard" Grid.Row="0"
                Padding="20,16" CornerRadius="12" Translation="0,0,32"
                Background="{ThemeResource AccentFillColorDefaultBrush}">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="2" VerticalAlignment="Center">
                    <TextBlock Text="Folder Tree Browser"
                               Style="{StaticResource TitleTextBlockStyle}" Foreground="White" />
                    <TextBlock Text="A richer composition showcase — shapes, layers, shadows &amp; injected visuals"
                               Foreground="#CCFFFFFF" />
                </StackPanel>
                <Button Grid.Column="1" Click="OpenAnimations_Click"
                        VerticalAlignment="Center" Padding="16,10" CornerRadius="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE945;" FontSize="16" />
                        <TextBlock Text="Animations" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="380" />
            </Grid.ColumnDefinitions>

            <!-- TreeView in a card -->
            <Border Grid.Column="0" CornerRadius="12" Padding="12" Translation="0,0,16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <Border.Shadow>
                    <ThemeShadow />
                </Border.Shadow>
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="4,0,0,0">
                        <FontIcon Glyph="&#xE8B7;"
                                  Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock Text="TreeStructure"
                                   Style="{StaticResource SubtitleTextBlockStyle}" />
                    </StackPanel>

                    <muxc:TreeView
                        x:Name="FolderTreeView"
                        Grid.Row="1"
                        ItemsSource="{x:Bind RootNodes}"
                        Expanding="FolderTreeView_Expanding"
                        SelectionChanged="FolderTreeView_SelectionChanged"
                        SelectionMode="Single">
                        <muxc:TreeView.ItemTemplate>
                            <DataTemplate x:DataType="local:FolderNode">
                                <muxc:TreeViewItem
                                    ItemsSource="{x:Bind Children}"
                                    HasUnrealizedChildren="{x:Bind HasUnrealizedChildren}"
                                    ToolTipService.ToolTip="{x:Bind FullPath}">
                                    <Grid ColumnSpacing="10" Padding="2,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Width="30" Height="30" CornerRadius="6"
                                                VerticalAlignment="Center"
                                                Background="{ThemeResource AccentFillColorTertiaryBrush}">
                                            <FontIcon Glyph="{x:Bind Glyph}" FontSize="15"
                                                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Name}"
                                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{x:Bind FullPath}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Grid>
                                </muxc:TreeViewItem>
                            </DataTemplate>
                        </muxc:TreeView.ItemTemplate>
                    </muxc:TreeView>
                </Grid>
            </Border>

            <!-- Right showcase pane (scrollable so it also spins up interaction/redirect visuals) -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
                <StackPanel Spacing="16">

                    <!-- XAML Shapes: Ellipse / rounded Rectangle / Path -->
                    <Border CornerRadius="12" Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel Spacing="10">
                            <TextBlock Text="XAML Shapes" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <Canvas Height="100">
                                <Ellipse Width="84" Height="84" Fill="MediumPurple" Canvas.Left="0" />
                                <Rectangle Width="84" Height="84" RadiusX="18" RadiusY="18"
                                           Fill="MediumOrchid" Canvas.Left="104" />
                                <Path Fill="Coral" Canvas.Left="208" Data="M 0,84 L 42,0 L 84,84 Z" />
                            </Canvas>
                        </StackPanel>
                    </Border>

                    <!-- Opacity layer: a partly-transparent panel forces XAML to emit a LayerVisual -->
                    <Border CornerRadius="12" Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Opacity layer (LayerVisual)"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <StackPanel Orientation="Horizontal" Spacing="8" Opacity="0.55">
                                <Rectangle Width="44" Height="44" Fill="Tomato" />
                                <Rectangle Width="44" Height="44" Fill="Gold" />
                                <Rectangle Width="44" Height="44" Fill="MediumSeaGreen" />
                                <Rectangle Width="44" Height="44" Fill="Goldenrod" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Acrylic backdrop -->
                    <Border CornerRadius="12" Padding="16" Height="96">
                        <Border.Background>
                            <AcrylicBrush TintColor="Plum" TintOpacity="0.4" FallbackColor="Thistle" />
                        </Border.Background>
                        <TextBlock Text="Acrylic backdrop brush" VerticalAlignment="Center"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                    </Border>

                    <!-- Hosts for the directly-injected composition visuals (filled in code-behind) -->
                    <Border CornerRadius="12" Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Injected composition visuals"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="A rotating ShapeVisual and a ContainerVisual with child SpriteVisuals"
                                       TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <Border x:Name="ShapeVisualHost" Width="140" Height="140" HorizontalAlignment="Left" />
                            <Border x:Name="ContainerVisualHost" Width="200" Height="80" HorizontalAlignment="Left" />
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <TextBlock x:Name="StatusText" Grid.Row="2"
                   Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
    </Grid>
</Window>
