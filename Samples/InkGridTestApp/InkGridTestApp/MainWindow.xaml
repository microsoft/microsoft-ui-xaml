<Window
    x:Class="InkGridTestApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:InkGridTestApp"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowSpacing="8" Padding="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header: compositor toggle + restart -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
            <ToggleSwitch x:Name="CompositorToggle"
                          Header="Compositor path"
                          OffContent="Lifted (topmost overlay)"
                          OnContent="System (ContentExternalOutputLink)"
                          Toggled="OnCompositorToggled" />
            <Button x:Name="RestartButton" Content="Restart to apply" Click="OnRestartClick" VerticalAlignment="Bottom" />
            <TextBlock x:Name="ModeStatusText" VerticalAlignment="Bottom" TextWrapping="Wrap" MaxWidth="360" />
        </StackPanel>

        <!-- Drawing controls (apply uniformly to ALL 16 cells) -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
            <ComboBox x:Name="ToolCombo" Header="Tool" SelectedIndex="0" SelectionChanged="OnDrawingAttributesChanged" Width="130">
                <ComboBoxItem Content="Pen" />
                <ComboBoxItem Content="Highlighter" />
                <ComboBoxItem Content="Eraser" />
            </ComboBox>
            <ComboBox x:Name="ColorCombo" Header="Color" SelectedIndex="0" SelectionChanged="OnDrawingAttributesChanged" Width="110">
                <ComboBoxItem Content="Black" />
                <ComboBoxItem Content="Red" />
                <ComboBoxItem Content="Blue" />
                <ComboBoxItem Content="Green" />
                <ComboBoxItem Content="Orange" />
                <ComboBoxItem Content="Purple" />
            </ComboBox>
            <Slider x:Name="SizeSlider" Header="Size" Minimum="1" Maximum="48" Value="6" Width="200" ValueChanged="OnDrawingAttributesChanged" />
            <TextBlock Text="These apply to every cell." VerticalAlignment="Bottom" Opacity="0.7" />
        </StackPanel>

        <!-- Scenario buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Button Content="Count strokes (all)" Click="OnCountAllClick" />
            <Button Content="Clear all" Click="OnClearAllClick" />
            <Button Content="Save + reload (all)" Click="OnSaveReloadAllClick" />
            <Button Content="Analyze focused" Click="OnAnalyzeFocusedClick" />
            <TextBlock x:Name="ScenarioStatusText" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="560"
                       Text="Draw in any cell. Tool/Color/Size above apply to all cells." />
        </StackPanel>

        <!-- InkToolBar test: retargets the last-touched cell so all toolbar buttons/glyphs work -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
            <controls:InkToolBar x:Name="Toolbar" />
            <TextBlock x:Name="ToolbarStatusText" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="420"
                       Text="InkToolBar targets the last-touched cell. Click a cell, then use the toolbar (pen / pencil / highlighter / eraser / stencil)." />
        </StackPanel>

        <!-- 4x4 grid of InkCanvas hosted in a ScrollViewer so scroll + z-order can be tested -->
        <ScrollViewer Grid.Row="4"
                      HorizontalScrollMode="Auto" HorizontalScrollBarVisibility="Auto"
                      VerticalScrollMode="Auto" VerticalScrollBarVisibility="Auto"
                      ZoomMode="Disabled">
            <Grid x:Name="InkGridHost" Padding="4" />
        </ScrollViewer>
    </Grid>
</Window>
