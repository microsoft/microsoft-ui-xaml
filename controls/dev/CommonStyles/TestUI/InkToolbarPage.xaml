<Page
    x:Class="MUXControlsTestApp.InkToolbarPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
    <Grid Padding="12" RowSpacing="8" ColumnSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Horizontal toolbar with the default tool set (pens + eraser + ruler). -->
        <InkToolBar x:Name="InkToolBar"
                    Grid.Row="0" Grid.Column="0"
                    HorizontalAlignment="Left"
                    TargetInkCanvas="{x:Bind inkCanvas}"/>

        <!-- Status readout so the new events are observable during manual testing. -->
        <TextBlock x:Name="StatusText"
                   Grid.Row="0" Grid.Column="1"
                   VerticalAlignment="Center"
                   Text="Ready"/>

        <!-- The drawing surface. -->
        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                BorderBrush="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                BorderThickness="1"
                CornerRadius="4">
            <InkCanvas x:Name="inkCanvas" Height="400"/>
        </Border>
    </Grid>
</Page>
